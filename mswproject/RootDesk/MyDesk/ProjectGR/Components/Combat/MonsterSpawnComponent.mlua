@Component
script MonsterSpawnComponent extends Component

    property string SpawnConfigTableName = "SpawnConfig"
    property string MonsterDataTableName = "MonsterData"
    property string ModeMonsterDataTableName = "ModeMonsterData"
    property string BossDataTableName = "BossData"
    property string SpawnWaveTableName = ""

    @Sync
    property boolean IsSpawnActive = false
    @Sync
    property boolean IsBossPhase = false
    property Entity MonsterParentEntity = nil

    property string MonsterContainerName = "MonsterContainer"
    property number StateMonitorInterval = 0.2
    property boolean EnableDebugLogs = false
    property number DebugLogThrottleSeconds = 1.0
    property boolean AutoBindPlacedMonsterEntities = true
    property number PlacedMonsterBindDelay = 0.2
    property number MonsterDeathEffectLeadTime = 0
    property number MonsterDeathFadeDuration = 0.25
    property number MonsterDeathFadeTick = 0.05
    property boolean EnableMonsterHPBar = true
    property integer MonsterHPBarSegments = 10
    property number MonsterHPBarOffsetY = -0.65
    property number MonsterHPBarFontSize = 7
    property number MonsterHPBarModelScaleXMultiplier = 0.25
    property number MonsterHPBarModelScaleYMultiplier = 0.25
    property integer MonsterHPBarMinSegments = 2
    property integer MonsterHPBarMinFontSize = 2
    property boolean MonsterHPBarShowNumeric = true
    property boolean RestrictMonstersToBackdrop = true
    property string BackdropBootstrapPath = "/maps/games/LobbyBootstrap"
    property number BackdropBoundsRefreshInterval = 1.0

    -- Server initializes all runtime caches once so spawn flow remains deterministic after hot-reload.
    @ExecSpace("ServerOnly")
    method void OnInitialize()
        self:EnsureGRUtil()

        self._T.SpawnTimerId = 0
        self._T.StateMonitorTimerId = 0
        self._T.SpawnedMonsters = {}
        self._T.SpawnMetaByEntity = {}
        self._T.Config = nil
        self._T.MonsterRows = {}
        self._T.BossRows = {}
        self._T.ModelTypeByMonType = nil
        self._T.RowFallbackModelById = nil
        self._T.OptionalColumnAvailability = {}
        self._T.OptionalColumnMissingWarned = {}
        self._T.RequiredColumnWarned = {}
        self._T.CreepScoreByMonsterId = {}
        self._T.BossSpawnedEntity = nil
        self._T.BossDefeatedByStage = {}
        self._T.WarnedMissingContainer = false
        self._T.HasMapPhysicsSimulator = nil
        self._T.WarnedMissingPhysicsSimulator = false
        self._T.UseModeMonsterData = false
        self._T.CurrentSpawnElapsedSec = 0
        self._T.DataReady = false
        self._T.LastSpawnGateAllowed = nil
        self._T.LastSpawnGateReason = ""
        self._T.LastSpawnGateLogAt = -9999
        self._T.SpawnTickCounter = 0
        self._T.PlacedMonsterBindTimerId = 0
        self._T.AutoBoundPlacedMonsters = {}
        self._T.DefaultPlacedMonsterRow = nil
        self._T.MonsterDeathRuntimeByEntity = {}
        self._T.MonsterHPBarByEntity = {}
        self._T.BackdropBounds = nil
        self._T.BackdropBoundsLastRefreshAt = -9999
        self._T.WarnedMissingBackdropBounds = false
        self._T.StageStartElapsedTime = 0
        self._T.EliteSpawnedSet = {}
        self._T.NormalSpawnBreakpoints = {}
        self._T.LastEliteCheckElapsedSec = 0

        self.IsSpawnActive = false
        self.IsBossPhase = false
    end

    -- BeginPlay loads DataTable snapshots first, then starts safe-zone aware monitor loop.
    @ExecSpace("ServerOnly")
    method void OnBeginPlay()
        self:LoadSpawnDataFromTable()
        self:ResolveMonsterParentEntity()
        self:RefreshBackdropBoundsCacheServer(true)
        self:StartStateMonitorTimer()
        self:RefreshSpawnStateServer()
        self:SchedulePlacedMonsterBindingServer()
    end

    -- Map enter re-resolves parent entity because map transition can invalidate previous references.
    @ExecSpace("ServerOnly")
    method void OnMapEnter(Entity enteredMap)
        self:ResolveMonsterParentEntity()
        self._T.HasMapPhysicsSimulator = nil
        self:RefreshBackdropBoundsCacheServer(true)
        self:RefreshSpawnStateServer()
        self:SchedulePlacedMonsterBindingServer()
    end

    -- EndPlay clears active timers so delayed callbacks never run on recycled entities.
    @ExecSpace("ServerOnly")
    method void OnEndPlay()
        self:StopSpawning()
        self:ClearMonsterDeathRuntimeTimersServer()
        self:ClearMonsterHPBarRuntimeServer()

        if self._T.StateMonitorTimerId ~= nil and self._T.StateMonitorTimerId > 0 then
            _TimerService:ClearTimer(self._T.StateMonitorTimerId)
            self._T.StateMonitorTimerId = 0
        end
        if self._T.PlacedMonsterBindTimerId ~= nil and self._T.PlacedMonsterBindTimerId > 0 then
            _TimerService:ClearTimer(self._T.PlacedMonsterBindTimerId)
            self._T.PlacedMonsterBindTimerId = 0
        end
    end

    -- Destroy repeats timer cleanup as final safety net for unusual lifecycle paths.
    @ExecSpace("ServerOnly")
    method void OnDestroy()
        self:ClearMonsterDeathRuntimeTimersServer()
        self:ClearMonsterHPBarRuntimeServer()

        if self._T.SpawnTimerId ~= nil and self._T.SpawnTimerId > 0 then
            _TimerService:ClearTimer(self._T.SpawnTimerId)
            self._T.SpawnTimerId = 0
        end
        if self._T.StateMonitorTimerId ~= nil and self._T.StateMonitorTimerId > 0 then
            _TimerService:ClearTimer(self._T.StateMonitorTimerId)
            self._T.StateMonitorTimerId = 0
        end
        if self._T.PlacedMonsterBindTimerId ~= nil and self._T.PlacedMonsterBindTimerId > 0 then
            _TimerService:ClearTimer(self._T.PlacedMonsterBindTimerId)
            self._T.PlacedMonsterBindTimerId = 0
        end
    end

    -- One entrypoint loads both config and monster table so availability gate is centralized.
    @ExecSpace("ServerOnly")
    method boolean LoadSpawnDataFromTable()
        local configLoaded = self:LoadSpawnConfigFromTable()
        local monsterLoaded = self:LoadMonsterDataFromTable()

        self._T.DataReady = (configLoaded == true and monsterLoaded == true)
        if self._T.DataReady == false then
            self:StopSpawning()
        end

        if self.EnableDebugLogs == true then
            log("[MonsterSpawnComponent][DEBUG] LoadSpawnDataFromTable dataReady=", self._T.DataReady, ", configLoaded=", configLoaded, ", monsterLoaded=", monsterLoaded)
        end

        return self._T.DataReady
    end

    -- Config table is mandatory because all balance values are data-driven by SPEC.
    @ExecSpace("ServerOnly")
    method boolean LoadSpawnConfigFromTable()
        self._T.Config = nil

        if self.SpawnConfigTableName == nil or self.SpawnConfigTableName == "" then
            self:LogError("[MonsterSpawnComponent] SpawnConfigTableName is empty.")
            return false
        end

        local tableData = nil
        local loadOk, loadResult = pcall(function()
            return _DataService:GetTable(self.SpawnConfigTableName)
        end)
        if loadOk == true then
            tableData = loadResult
        end
        if tableData == nil then
            self:LogError("[MonsterSpawnComponent] Failed to load SpawnConfig table: " .. tostring(self.SpawnConfigTableName))
            return false
        end

        local rows = nil
        local rowsOk, rowsResult = pcall(function()
            return tableData:GetAllRow()
        end)
        if rowsOk == true then
            rows = rowsResult
        end
        if rows == nil or #rows <= 0 then
            self:LogError("[MonsterSpawnComponent] SpawnConfig has no rows.")
            return false
        end
        local row = rows[1]
        if self:ValidateSpawnConfigRowContract(row) ~= true then
            self:LogError("[MonsterSpawnComponent] SpawnConfig required columns are missing.")
            return false
        end

        local innerRadius = self:GetRowNumber(row, "InnerRadius", -1)
        local outerRadius = self:GetRowNumber(row, "OuterRadius", -1)
        local spawnInterval = self:GetRowNumber(row, "SpawnInterval", -1)
        local spawnPerTick = self:GetRowInteger(row, "SpawnPerTick", -1)
        if innerRadius < 0 or outerRadius < 0 or spawnInterval <= 0 or spawnPerTick <= 0 then
            self:LogError("[MonsterSpawnComponent] Invalid SpawnConfig values. Check SpawnConfig.csv.")
            return false
        end
        if outerRadius < innerRadius then
            self:LogError("[MonsterSpawnComponent] OuterRadius must be >= InnerRadius.")
            return false
        end

        local config = {}
        config.InnerRadius = innerRadius
        config.OuterRadius = outerRadius
        config.SpawnInterval = spawnInterval
        config.SpawnPerTick = spawnPerTick

        self._T.Config = config
        if self.EnableDebugLogs == true then
            log("[MonsterSpawnComponent][DEBUG] SpawnConfig loaded. rowCount=", #rows, ", inner=", innerRadius, ", outer=", outerRadius, ", interval=", spawnInterval, ", perTick=", spawnPerTick)
        end
        return true
    end

    -- MonsterData contains normal/elite rows while BossData owns boss rows to keep schemas decoupled.
    @ExecSpace("ServerOnly")
    method boolean LoadMonsterDataFromTable()
        self._T.MonsterRows = {}
        self._T.BossRows = {}
        self._T.ModelTypeByMonType = nil
        self._T.RowFallbackModelById = nil
        self._T.EliteSpawnedSet = {}
        self._T.NormalSpawnBreakpoints = {}
        self._T.LastEliteCheckElapsedSec = 0

        local tableName = self:ResolveMonsterDataTableName()
        if tableName == "" then
            self:LogError("[MonsterSpawnComponent] MonsterDataTableName is empty.")
            return false
        end

        local tableData = nil
        local loadOk, loadResult = pcall(function()
            return _DataService:GetTable(tableName)
        end)
        if loadOk == true then
            tableData = loadResult
        end
        if tableData == nil then
            self:LogError("[MonsterSpawnComponent] Failed to load MonsterData table: " .. tostring(tableName))
            return false
        end

        local rows = nil
        local rowsOk, rowsResult = pcall(function()
            return tableData:GetAllRow()
        end)
        if rowsOk == true then
            rows = rowsResult
        end
        if rows == nil or #rows <= 0 then
            self:LogError("[MonsterSpawnComponent] MonsterData has no rows.")
            return false
        end

        local mergedRows = {}
        for _, row in pairs(rows) do
            if row == nil then
                continue
            end
            if self:IsBossRow(row) == true then
                continue
            end
            table.insert(mergedRows, row)
        end

        self:ValidateMonsterRowsContract(mergedRows, tableName)

        if self._T.UseModeMonsterData ~= true then
            local bossRows = self:LoadBossRowsFromTable()
            if bossRows == nil or #bossRows <= 0 then
                self:LogError("[MonsterSpawnComponent] BossData has no valid boss rows.")
                return false
            end

            self:ValidateMonsterRowsContract(bossRows, self.BossDataTableName)
            self._T.BossRows = bossRows

            for _, bossRow in pairs(bossRows) do
                if bossRow ~= nil then
                    table.insert(mergedRows, bossRow)
                end
            end
        end

        if mergedRows == nil or #mergedRows <= 0 then
            self:LogError("[MonsterSpawnComponent] Spawn rows are empty after loading MonsterData/BossData.")
            return false
        end

        self._T.MonsterRows = mergedRows
        self:BuildNormalSpawnBreakpointsCache(mergedRows)
        self:BuildRowModelFallbackCache(mergedRows)
        self:BuildOptionalMonsterColumnsCache(mergedRows)
        self:BuildCreepScoreCache(mergedRows)
        return true
    end

    -- BossData loader reads only mon_type=boss rows so MonsterData can stay boss-free.
    @ExecSpace("ServerOnly")
    method table LoadBossRowsFromTable()
        local result = {}

        if self.BossDataTableName == nil or self.BossDataTableName == "" then
            self:LogError("[MonsterSpawnComponent] BossDataTableName is empty.")
            return result
        end

        local tableData = nil
        local loadOk, loadResult = pcall(function()
            return _DataService:GetTable(self.BossDataTableName)
        end)
        if loadOk == true then
            tableData = loadResult
        end
        if tableData == nil then
            self:LogError("[MonsterSpawnComponent] Failed to load BossData table: " .. tostring(self.BossDataTableName))
            return result
        end

        local rows = nil
        local rowsOk, rowsResult = pcall(function()
            return tableData:GetAllRow()
        end)
        if rowsOk == true then
            rows = rowsResult
        end
        if rows == nil or #rows <= 0 then
            self:LogError("[MonsterSpawnComponent] BossData has no rows.")
            return result
        end

        for _, row in pairs(rows) do
            if row == nil then
                continue
            end

            local rowId = self:GetRowString(row, "id", "")
            if rowId == "" then
                continue
            end
            if self:IsBossRow(row) ~= true then
                continue
            end

            table.insert(result, row)
        end

        if self.EnableDebugLogs == true then
            log("[MonsterSpawnComponent][DEBUG] BossData rows loaded. count=", #result)
        end
        return result
    end

    -- Creep-score cache avoids repeated table scans when kill-score callbacks are triggered frequently.
    method void BuildCreepScoreCache(table rows)
        self._T.CreepScoreByMonsterId = {}
        if rows == nil then
            return
        end

        for _, row in pairs(rows) do
            if row == nil then
                continue
            end

            local rowId = self:GetRowString(row, "id", "")
            if rowId == "" then
                continue
            end

            local creepScore = self:GetRowInteger(row, "creep_score", 0)
            self._T.CreepScoreByMonsterId[rowId] = math.max(0, creepScore)
        end
    end

    -- Breakpoint cache keeps normal spawn selection O(n) without rebuilding minute buckets every tick.
    method void BuildNormalSpawnBreakpointsCache(table rows)
        self._T.NormalSpawnBreakpoints = {}
        if rows == nil then
            return
        end

        local seen = {}
        for _, row in pairs(rows) do
            if row == nil then
                continue
            end
            if self:IsBossRow(row) == true or self:IsEliteRow(row) == true then
                continue
            end

            local spawnMinute = self:GetSpawnMinuteFromRow(row)
            if spawnMinute == nil then
                continue
            end

            local normalizedMinute = math.floor(tonumber(spawnMinute) or -1)
            if normalizedMinute < 0 then
                continue
            end
            if seen[normalizedMinute] == true then
                continue
            end

            seen[normalizedMinute] = true
            table.insert(self._T.NormalSpawnBreakpoints, normalizedMinute)
        end

        table.sort(self._T.NormalSpawnBreakpoints, function(a, b)
            return a < b
        end)
    end

    method boolean ValidateSpawnConfigRowContract(UserDataRow row)
        if row == nil then
            return false
        end

        local required = {
            "InnerRadius",
            "OuterRadius",
            "SpawnInterval",
            "SpawnPerTick"
        }

        local valid = true
        for _, columnName in pairs(required) do
            local text = self:GetRowString(row, columnName, "")
            if text == "" then
                self:WarnMissingRequiredColumnOnce(self.SpawnConfigTableName, columnName, "SpawnConfig")
                valid = false
            end
        end

        return valid
    end

    method void ValidateMonsterRowsContract(table rows, string tableName)
        if rows == nil then
            return
        end

        for _, row in pairs(rows) do
            if row == nil then
                continue
            end

            local rowId = self:GetRowString(row, "id", "")
            if rowId == "" then
                continue
            end

            local monType = self:GetRowString(row, "mon_type", "")
            if monType == "" then
                self:WarnMissingRequiredColumnOnce(tableName, "mon_type", rowId)
            end

            local isModeRow = self:IsModeMonsterRow(row)
            local modelType = self:GetRowString(row, "model_type", "")
            if isModeRow ~= true and modelType == "" then
                self:WarnMissingRequiredColumnOnce(tableName, "model_type", rowId)
            end

            if isModeRow == true then
                if self:GetRowString(row, "mode_mon_hp", "") == "" then
                    self:WarnMissingRequiredColumnOnce(tableName, "mode_mon_hp", rowId)
                end
            else
                if self:GetRowString(row, "mon_hp", "") == "" then
                    self:WarnMissingRequiredColumnOnce(tableName, "mon_hp", rowId)
                end
            end

            if self:GetRowString(row, "mon_atk", "") == "" then
                self:WarnMissingRequiredColumnOnce(tableName, "mon_atk", rowId)
            end
            if self:GetRowString(row, "mon_spd", "") == "" then
                self:WarnMissingRequiredColumnOnce(tableName, "mon_spd", rowId)
            end
            if self:GetRowString(row, "spawn_time", "") == "" then
                self:WarnMissingRequiredColumnOnce(tableName, "spawn_time", rowId)
            end
            if self:GetRowString(row, "creep_score", "") == "" then
                self:WarnMissingRequiredColumnOnce(tableName, "creep_score", rowId)
            end
        end
    end

    -- Fallback cache keeps CSV authoring flexible when repetitive model_type cells are intentionally left empty.
    method void BuildRowModelFallbackCache(table rows)
        self._T.RowFallbackModelById = {}
        self._T.ModelTypeByMonType = {}

        if rows == nil or #rows <= 0 then
            return
        end

        local lastModelByType = {}
        for index = 1, #rows do
            local row = rows[index]
            if row == nil then
                continue
            end

            local rowId = self:GetRowString(row, "id", "")
            local monType = string.lower(self:GetRowString(row, "mon_type", ""))
            local modelType = self:GetRowString(row, "model_type", "")

            if monType ~= "" and modelType ~= "" and self._T.ModelTypeByMonType[monType] == nil then
                self._T.ModelTypeByMonType[monType] = modelType
            end

            if monType ~= "" and modelType ~= "" then
                lastModelByType[monType] = modelType
                continue
            end

            if rowId ~= "" and monType ~= "" and lastModelByType[monType] ~= nil then
                self._T.RowFallbackModelById[rowId] = lastModelByType[monType]
            end
        end
    end

    -- Optional-column cache avoids repeated row:GetItem calls that would spam engine errors when schema is old.
    method void BuildOptionalMonsterColumnsCache(table rows)
        self._T.OptionalColumnAvailability = {}
        self._T.OptionalColumnMissingWarned = {}

        if rows == nil or #rows <= 0 then
            return
        end

        local probeRow = rows[1]
        if probeRow == nil then
            return
        end

        local optionalColumns = {
            "collider_w",
            "collider_h",
            "collider_offset_x",
            "collider_offset_y"
        }
        for _, columnName in pairs(optionalColumns) do
            self:ProbeOptionalMonsterColumn(probeRow, columnName)
        end
    end

    method boolean ProbeOptionalMonsterColumn(UserDataRow row, string columnName)
        if self._T.OptionalColumnAvailability == nil then
            self._T.OptionalColumnAvailability = {}
        end

        if columnName == nil or columnName == "" then
            return false
        end
        if self._T.OptionalColumnAvailability[columnName] ~= nil then
            return self._T.OptionalColumnAvailability[columnName]
        end
        if row == nil then
            self._T.OptionalColumnAvailability[columnName] = false
            return false
        end

        local readOk, _ = pcall(function()
            return row:GetItem(columnName)
        end)
        self._T.OptionalColumnAvailability[columnName] = readOk

        if readOk == false then
            self:WarnMissingOptionalMonsterColumn(columnName)
        end
        return readOk
    end

    method boolean HasOptionalMonsterColumn(string columnName)
        if columnName == nil or columnName == "" then
            return false
        end

        if self._T.OptionalColumnAvailability == nil then
            self._T.OptionalColumnAvailability = {}
        end

        local cached = self._T.OptionalColumnAvailability[columnName]
        if cached ~= nil then
            return cached
        end

        local rows = self._T.MonsterRows
        if rows == nil or #rows <= 0 then
            self._T.OptionalColumnAvailability[columnName] = false
            return false
        end

        return self:ProbeOptionalMonsterColumn(rows[1], columnName)
    end

    method void WarnMissingOptionalMonsterColumn(string columnName)
        if self._T.OptionalColumnMissingWarned == nil then
            self._T.OptionalColumnMissingWarned = {}
        end
        if self._T.OptionalColumnMissingWarned[columnName] == true then
            return
        end

        self._T.OptionalColumnMissingWarned[columnName] = true
        log_warning("[MonsterSpawnComponent] Optional column missing in MonsterData. fallback applied. column=", columnName)
    end

    -- Backward-compatible resolver allows old SPEC alias without blocking current MonsterData naming.
    method string ResolveMonsterDataTableName()
        if self._T.UseModeMonsterData == true then
            if self.ModeMonsterDataTableName ~= nil and self.ModeMonsterDataTableName ~= "" then
                return self.ModeMonsterDataTableName
            end
            return ""
        end

        if self.MonsterDataTableName ~= nil and self.MonsterDataTableName ~= "" then
            return self.MonsterDataTableName
        end
        if self.SpawnWaveTableName ~= nil and self.SpawnWaveTableName ~= "" then
            return self.SpawnWaveTableName
        end
        return ""
    end

    -- Infinite-mode entry switches spawn source table and restarts gate evaluation in one server API.
    @ExecSpace("ServerOnly")
    method boolean ActivateInfiniteModeServer(boolean enabled)
        local useModeData = (enabled == true)
        self._T.UseModeMonsterData = useModeData

        self.IsBossPhase = false
        self._T.BossSpawnedEntity = nil
        self._T.BossDefeatedByStage = {}
        self._T.EliteSpawnedSet = {}
        self._T.StageStartElapsedTime = 0
        self._T.LastEliteCheckElapsedSec = 0

        local loaded = self:LoadMonsterDataFromTable()
        self._T.DataReady = (self._T.Config ~= nil and loaded == true)

        if loaded == false then
            self:StopSpawning()
            return false
        end

        self:RefreshSpawnStateServer()
        return true
    end

    -- Score lookup API is used by InfiniteMode fallback path when spawn meta is unavailable.
    @ExecSpace("ServerOnly")
    method integer GetCreepScoreByMonsterIdServer(string monsterId)
        if monsterId == nil or monsterId == "" then
            return 0
        end

        if self._T.CreepScoreByMonsterId == nil then
            self._T.CreepScoreByMonsterId = {}
        end

        local cached = self._T.CreepScoreByMonsterId[monsterId]
        if cached ~= nil then
            return math.max(0, math.floor(cached))
        end
        return 0
    end

    method string GetFallbackModelType(UserDataRow row)
        if row == nil then
            return ""
        end

        local rowId = self:GetRowString(row, "id", "")
        if rowId ~= "" and self._T.RowFallbackModelById ~= nil then
            local rowFallback = self._T.RowFallbackModelById[rowId]
            if rowFallback ~= nil and rowFallback ~= "" then
                return rowFallback
            end
        end

        local monType = string.lower(self:GetRowString(row, "mon_type", ""))
        if monType == "" then
            return ""
        end

        if self._T.ModelTypeByMonType ~= nil then
            local defaultModel = self._T.ModelTypeByMonType[monType]
            if defaultModel ~= nil and defaultModel ~= "" then
                return defaultModel
            end
        end

        return ""
    end

    -- Parent resolver enforces SPEC decision: no MonsterContainer means spawn stays disabled.
    @ExecSpace("ServerOnly")
    method void ResolveMonsterParentEntity()
        self.MonsterParentEntity = nil

        local mapEntity = self.Entity.CurrentMap
        if mapEntity == nil or isvalid(mapEntity) == false then
            return
        end

        local container = nil
        local findOk, findResult = pcall(function()
            return mapEntity:GetChildByName(self.MonsterContainerName, true)
        end)
        if findOk == true then
            container = findResult
        end

        if container ~= nil and isvalid(container) == true then
            self.MonsterParentEntity = container
            self._T.WarnedMissingContainer = false
            if self.EnableDebugLogs == true then
                log("[MonsterSpawnComponent][DEBUG] MonsterContainer resolved. name=", self.MonsterContainerName)
            end
            return
        end

        if self._T.WarnedMissingContainer ~= true then
            log_warning("[MonsterSpawnComponent] MonsterContainer is missing. Spawning remains disabled until container is placed.")
            self._T.WarnedMissingContainer = true
        end
    end

    -- Monitor timer reacts to spawn gate state without per-frame OnUpdate overhead.
    @ExecSpace("ServerOnly")
    method void StartStateMonitorTimer()
        if self._T.StateMonitorTimerId ~= nil and self._T.StateMonitorTimerId > 0 then
            return
        end

        local interval = self.StateMonitorInterval
        if interval <= 0 then
            interval = 0.2
        end

        local callback = function()
            self:RefreshSpawnStateServer()
            self:UpdateMonsterHPBarsServer()
            self:ProcessMonsterDeathSequenceServer()
            self:CheckEliteSpawnsServer()
        end
        self._T.StateMonitorTimerId = _TimerService:SetTimerRepeat(callback, interval, 0)
        if self.EnableDebugLogs == true then
            log("[MonsterSpawnComponent][DEBUG] State monitor timer started. id=", self._T.StateMonitorTimerId, ", interval=", interval)
        end
    end

    -- Single state gate keeps start/stop transitions deterministic and easy to extend later.
    @ExecSpace("ServerOnly")
    method void RefreshSpawnStateServer()
        if self:CanSpawnNowServer() == true then
            self:StartSpawning()
            return
        end

        self:StopSpawning()
    end

    -- Spawn readiness checks are centralized so future unknown rules can be appended safely.
    @ExecSpace("ServerOnly")
    method boolean CanSpawnNowServer()
        if self._T.DataReady ~= true then
            self:TraceSpawnGateServer(false, "DataNotReady")
            return false
        end
        if self.IsBossPhase == true then
            self:TraceSpawnGateServer(false, "BossPhaseActive")
            return false
        end
        if self.MonsterParentEntity == nil or isvalid(self.MonsterParentEntity) == false then
            self:TraceSpawnGateServer(false, "MonsterContainerMissing")
            return false
        end
        if self:IsSafeZoneActiveServer() == true then
            self:TraceSpawnGateServer(false, "LobbySafeZoneActive")
            return false
        end
        local timerComponent = self:ResolveComponentSafe(self.Entity, "GameTimerComponent", "IsPaused")
        if timerComponent ~= nil then
            local pauseOk, isPaused = pcall(function()
                return timerComponent.IsPaused
            end)
            if pauseOk == true and isPaused == true then
                self:TraceSpawnGateServer(false, "GameTimerPaused")
                return false
            end
        end

        self:TraceSpawnGateServer(true, "Ready")
        return true
    end

    -- Safe-zone resolver now follows lobby state only; shop open no longer blocks monster spawning.
    @ExecSpace("ServerOnly")
    method boolean IsSafeZoneActiveServer()
        local lobbyFlow = self:ResolveComponentSafe(self.Entity, "LobbyFlowComponent", "IsLobbyActive")
        if lobbyFlow ~= nil then
            local lobbyOk, isLobby = pcall(function()
                return lobbyFlow.IsLobbyActive
            end)
            if lobbyOk == true and isLobby == true then
                return true
            end
        end

        return false
    end

    -- Shop-open state is debug-only context and does not affect spawn gate decisions.
    @ExecSpace("ServerOnly")
    method boolean IsShopOpenServer()
        local shopManager = self:ResolveComponentSafe(self.Entity, "ShopManagerComponent", "IsShopOpen")
        if shopManager ~= nil then
            local shopOk, isShopOpen = pcall(function()
                return shopManager.IsShopOpen
            end)
            if shopOk == true and isShopOpen == true then
                return true
            end
        end

        return false
    end

    -- Start path is isolated so timer recreation and sync flag update always happen together.
    @ExecSpace("ServerOnly")
    method void StartSpawning()
        if self._T.SpawnTimerId ~= nil and self._T.SpawnTimerId > 0 then
            return
        end
        if self._T.Config == nil then
            if self.EnableDebugLogs == true then
                log_warning("[MonsterSpawnComponent][DEBUG] StartSpawning blocked: config missing.")
            end
            return
        end

        local interval = self._T.Config.SpawnInterval
        if interval <= 0 then
            if self.EnableDebugLogs == true then
                log_warning("[MonsterSpawnComponent][DEBUG] StartSpawning blocked: invalid interval=", interval)
            end
            return
        end

        local callback = function()
            self:SpawnTick()
        end
        local timerId = _TimerService:SetTimerRepeat(callback, interval, 0)
        if timerId == nil or timerId <= 0 then
            if self.EnableDebugLogs == true then
                log_warning("[MonsterSpawnComponent][DEBUG] StartSpawning failed: invalid timer id.")
            end
            return
        end

        self._T.SpawnTimerId = timerId
        self.IsSpawnActive = true
        if self.EnableDebugLogs == true then
            log("[MonsterSpawnComponent][DEBUG] Spawn timer started. id=", timerId, ", interval=", interval)
        end
    end

    -- Stop path clears only one timer id so duplicated ClearTimer calls are avoided.
    @ExecSpace("ServerOnly")
    method void StopSpawning()
        if self._T.SpawnTimerId ~= nil and self._T.SpawnTimerId > 0 then
            if self.EnableDebugLogs == true then
                log("[MonsterSpawnComponent][DEBUG] Spawn timer stopped. id=", self._T.SpawnTimerId)
            end
            _TimerService:ClearTimer(self._T.SpawnTimerId)
            self._T.SpawnTimerId = 0
        end
        self.IsSpawnActive = false
    end

    -- Hard clear API is used by run reset and stage transition to guarantee empty combat field.
    @ExecSpace("ServerOnly")
    method void KillAllMonstersServer()
        local toDestroy = {}

        if self._T.SpawnedMonsters ~= nil then
            for _, entity in pairs(self._T.SpawnedMonsters) do
                if entity ~= nil and isvalid(entity) == true then
                    table.insert(toDestroy, entity)
                end
            end
        end

        if self._T.AutoBoundPlacedMonsters ~= nil then
            for entity, isBound in pairs(self._T.AutoBoundPlacedMonsters) do
                if isBound == true and entity ~= nil and isvalid(entity) == true and entity.PlayerComponent == nil then
                    table.insert(toDestroy, entity)
                end
            end
        end

        self._T.SpawnedMonsters = {}
        self._T.SpawnMetaByEntity = {}
        self._T.AutoBoundPlacedMonsters = {}
        self._T.BossSpawnedEntity = nil
        self._T.BossDefeatedByStage = {}
        self.IsBossPhase = false

        for _, entity in pairs(toDestroy) do
            if entity ~= nil and isvalid(entity) == true then
                pcall(function()
                    _EntityService:Destroy(entity)
                end)
            end
        end

        self:ClearMonsterDeathRuntimeTimersServer()
        self:ClearMonsterHPBarRuntimeServer()
    end

    -- Spawn tick executes only lightweight loops and defers unknown features to dedicated extension hooks.
    @ExecSpace("ServerOnly")
    method void SpawnTick()
        if self:CanSpawnNowServer() == false then
            return
        end

        self:RefreshBackdropBoundsCacheServer(false)

        self._T.SpawnTickCounter = self._T.SpawnTickCounter + 1
        self:PruneSpawnedMonsters()

        local config = self._T.Config
        if config == nil then
            return
        end
        local context = self:ResolveCurrentSpawnContext()
        self._T.CurrentSpawnElapsedSec = context.ElapsedSec
        local candidates = self:ResolveSpawnCandidates(context.Stage, context.ElapsedSec)
        if self.EnableDebugLogs == true then
            log("[MonsterSpawnComponent][DEBUG] SpawnTick start. tick=", self._T.SpawnTickCounter, ", stage=", context.Stage, ", elapsed=", context.ElapsedSec, ", normal=", #candidates.NormalRows, ", boss=", #candidates.BossRows, ", alive=", self:GetSpawnedMonsterCount())
        end

        local bossRows = candidates.BossRows
        if bossRows ~= nil and #bossRows > 0 then
            local bossRow = self:SelectLatestRowBySpawnTime(bossRows)
            local bossSpawnPos = self:ResolveBossSpawnPositionServer()
            local bossEntity = self:SpawnMonsterByRow(bossRow, bossSpawnPos, true)
            if bossEntity ~= nil and isvalid(bossEntity) == true then
                self.IsBossPhase = true
                self:StopSpawning()
                if self.EnableDebugLogs == true then
                    local bossId = self:GetRowString(bossRow, "id", "(unknown)")
                    log("[MonsterSpawnComponent][DEBUG] Boss spawned. id=", bossId, ", bossPhase=", self.IsBossPhase)
                end
            elseif self.EnableDebugLogs == true then
                local bossId = self:GetRowString(bossRow, "id", "(unknown)")
                log_warning("[MonsterSpawnComponent][DEBUG] Boss candidate failed to spawn. id=", bossId)
            end
            return
        end

        local normalRows = candidates.NormalRows
        if normalRows == nil or #normalRows <= 0 then
            if self.EnableDebugLogs == true then
                log("[MonsterSpawnComponent][DEBUG] SpawnTick skipped: no normal candidates.")
            end
            return
        end

        local attemptedCount = 0
        local spawnedCount = 0
        local invalidPositionCount = 0

        for i = 1, config.SpawnPerTick do
            self:PruneSpawnedMonsters()

            local selectedRow = self:PickRandomRow(normalRows)
            if selectedRow == nil then
                break
            end
            attemptedCount = attemptedCount + 1

            -- Spawn config no longer retries; penalty system now owns overflow control.
            local spawnPosition = self:CalcDonutPosition()
            if spawnPosition ~= nil and self:IsValidSpawnPosition(spawnPosition) == true then
                local spawned = self:SpawnMonsterByRow(selectedRow, spawnPosition, false)
                if spawned ~= nil and isvalid(spawned) == true then
                    spawnedCount = spawnedCount + 1
                end
            else
                invalidPositionCount = invalidPositionCount + 1
            end
        end

        if self.EnableDebugLogs == true then
            log("[MonsterSpawnComponent][DEBUG] SpawnTick end. attempted=", attemptedCount, ", spawned=", spawnedCount, ", invalidPos=", invalidPositionCount, ", alive=", self:GetSpawnedMonsterCount())
        end
    end

    -- Stage/time context is read from GameTimer or InfiniteMode elapsed timer, both server-authoritative.
    @ExecSpace("ServerOnly")
    method table ResolveCurrentSpawnContext()
        local context = {}
        context.Stage = 1
        context.ElapsedSec = 0

        local infiniteMode = self:ResolveComponentSafe(self.Entity, "InfiniteModeComponent", "IsInfiniteActive")
        if infiniteMode ~= nil then
            local activeOk, isInfinite = pcall(function()
                return infiniteMode.IsInfiniteActive
            end)
            if activeOk == true and isInfinite == true then
                local elapsedOk, elapsedValue = pcall(function()
                    if infiniteMode.GetInfiniteElapsedSecondsServer ~= nil then
                        return infiniteMode:GetInfiniteElapsedSecondsServer()
                    end
                    return 0
                end)
                if elapsedOk == true and elapsedValue ~= nil then
                    context.ElapsedSec = math.max(0, elapsedValue)
                end
                context.Stage = 1
                return context
            end
        end

        local timerComponent = self:ResolveComponentSafe(self.Entity, "GameTimerComponent", "ElapsedTime")
        if timerComponent == nil then
            return context
        end

        local stageOk, stageValue = pcall(function()
            return timerComponent.CurrentStageId
        end)
        if stageOk == true and stageValue ~= nil then
            context.Stage = math.max(1, math.floor(stageValue))
        end

        local elapsedOk, elapsedValue = pcall(function()
            return timerComponent.ElapsedTime
        end)
        if elapsedOk == true and elapsedValue ~= nil then
            local stageStart = 0
            if self._T.StageStartElapsedTime ~= nil then
                stageStart = math.max(0, self._T.StageStartElapsedTime)
            end
            context.ElapsedSec = math.max(0, elapsedValue - stageStart)
        end

        return context
    end

    -- Resolver keeps selection logic in one function so unknown future conditions can be patched quickly.
    @ExecSpace("ServerOnly")
    method table ResolveSpawnCandidates(integer stage, number elapsedSec)
        local result = {}
        result.NormalRows = {}
        result.BossRows = {}
        local enforceStage = (self._T.UseModeMonsterData ~= true)
        local currentBreakpoint = self:ResolveCurrentNormalSpawnBreakpointMin(elapsedSec)

        local rows = self._T.MonsterRows
        if rows == nil then
            return result
        end

        for _, row in pairs(rows) do
            if row == nil then
                continue
            end

            if enforceStage == true then
                local rowStage = self:GetRowInteger(row, "spawn_stage", 1)
                if rowStage ~= stage then
                    continue
                end
            end

            local spawnMinute = self:GetSpawnMinuteFromRow(row)
            if spawnMinute < 0 then
                continue
            end
            if elapsedSec < (spawnMinute * 60) then
                continue
            end

            if self:IsBossRow(row) == true then
                local rowStage = self:GetRowInteger(row, "spawn_stage", 1)
                if self._T.BossDefeatedByStage ~= nil and self._T.BossDefeatedByStage[rowStage] == true then
                    continue
                end
                table.insert(result.BossRows, row)
            elseif self:IsEliteRow(row) == true then
                continue
            else
                if currentBreakpoint < 0 then
                    continue
                end
                local normalizedMinute = math.floor(tonumber(spawnMinute) or -1)
                if normalizedMinute ~= currentBreakpoint then
                    continue
                end
                table.insert(result.NormalRows, row)
            end
        end

        return result
    end

    method integer ResolveCurrentNormalSpawnBreakpointMin(number elapsedSec)
        local breakpoints = self._T.NormalSpawnBreakpoints
        if breakpoints == nil or #breakpoints <= 0 then
            return -1
        end

        local elapsedMinutes = math.floor(math.max(0, tonumber(elapsedSec) or 0) / 60)
        local selected = -1
        for i = 1, #breakpoints do
            local candidate = tonumber(breakpoints[i]) or -1
            if candidate < 0 then
                continue
            end
            if candidate <= elapsedMinutes then
                selected = math.floor(candidate)
            else
                break
            end
        end

        return selected
    end

    method number GetSpawnMinuteFromRow(UserDataRow row)
        if self:IsBossRow(row) == true then
            return 14
        end
        return self:GetRowNumber(row, "spawn_time", -1)
    end

    method boolean IsBossRow(UserDataRow row)
        local monType = string.lower(self:GetRowString(row, "mon_type", ""))
        return monType == "boss"
    end

    method boolean IsEliteRow(UserDataRow row)
        local monType = string.lower(self:GetRowString(row, "mon_type", ""))
        return monType == "elite"
    end

    -- Elite monsters are spawned by monitor tick only once per id to separate them from normal SpawnTick flow.
    @ExecSpace("ServerOnly")
    method void CheckEliteSpawnsServer()
        if self._T.MonsterRows == nil then
            return
        end
        if self:IsSafeZoneActiveServer() == true then
            return
        end
        if self._T.EliteSpawnedSet == nil then
            self._T.EliteSpawnedSet = {}
        end

        local timerComp = self:ResolveComponentSafe(self.Entity, "GameTimerComponent", "ElapsedTime")
        if timerComp == nil then
            return
        end

        local elapsed = 0
        local elapsedOk, elapsedValue = pcall(function()
            return timerComp.ElapsedTime
        end)
        if elapsedOk ~= true or elapsedValue == nil then
            return
        end

        local stageStart = 0
        if self._T.StageStartElapsedTime ~= nil then
            stageStart = math.max(0, self._T.StageStartElapsedTime)
        end
        elapsed = math.max(0, elapsedValue - stageStart)
        self._T.LastEliteCheckElapsedSec = elapsed

        local spawnWindowSec = self:ResolveEliteSpawnWindowSeconds()

        local stage = 1
        local stageOk, stageValue = pcall(function()
            return timerComp.CurrentStageId
        end)
        if stageOk == true and stageValue ~= nil then
            stage = math.max(1, math.floor(stageValue))
        end

        local enforceStage = (self._T.UseModeMonsterData ~= true)
        for _, row in pairs(self._T.MonsterRows) do
            if row == nil then
                continue
            end
            if self:IsEliteRow(row) ~= true then
                continue
            end

            if enforceStage == true then
                local rowStage = self:GetRowInteger(row, "spawn_stage", 1)
                if rowStage ~= stage then
                    continue
                end
            end

            local eliteId = self:GetRowString(row, "id", "")
            if eliteId == "" then
                continue
            end
            if self._T.EliteSpawnedSet[eliteId] == true then
                continue
            end

            local spawnSec = self:GetSpawnMinuteFromRow(row) * 60
            if spawnSec < 0 then
                continue
            end
            if elapsed < spawnSec then
                continue
            end
            if elapsed >= (spawnSec + spawnWindowSec) then
                continue
            end

            self:SpawnEliteOnceServer(row, eliteId)
        end
    end

    method number ResolveEliteSpawnWindowSeconds()
        local window = 1.0
        local config = self._T.Config
        if config ~= nil then
            local configuredInterval = tonumber(config.SpawnInterval)
            if configuredInterval ~= nil and configuredInterval > 0 then
                window = math.max(configuredInterval * 3.0, 1.0)
            end
        end
        return window
    end

    @ExecSpace("ServerOnly")
    method void SpawnEliteOnceServer(UserDataRow row, string eliteId)
        if row == nil then
            return
        end
        if eliteId == nil or eliteId == "" then
            return
        end
        if self._T.EliteSpawnedSet == nil then
            self._T.EliteSpawnedSet = {}
        end
        if self._T.EliteSpawnedSet[eliteId] == true then
            return
        end

        local pos = self:CalcDonutPosition()
        if pos == nil or self:IsValidSpawnPosition(pos) ~= true then
            return
        end

        local spawned = self:SpawnMonsterByRow(row, pos, false)
        if spawned ~= nil and isvalid(spawned) == true then
            self._T.EliteSpawnedSet[eliteId] = true
        end
    end

    method UserDataRow SelectLatestRowBySpawnTime(table rows)
        if rows == nil or #rows <= 0 then
            return nil
        end

        local selectedRow = rows[1]
        local latestMinute = self:GetSpawnMinuteFromRow(selectedRow)

        for _, row in pairs(rows) do
            local rowMinute = self:GetSpawnMinuteFromRow(row)
            if rowMinute > latestMinute then
                latestMinute = rowMinute
                selectedRow = row
            end
        end

        return selectedRow
    end

    method UserDataRow PickRandomRow(table rows)
        if rows == nil or #rows <= 0 then
            return nil
        end

        local randomIndex = math.random(1, #rows)
        return rows[randomIndex]
    end

    -- Donut position keeps spawn out of immediate player view while staying near combat area.
    @ExecSpace("ServerOnly")
    method Vector3 CalcDonutPosition()
        local config = self._T.Config
        if config == nil then
            return nil
        end

        local transform = self.Entity.TransformComponent
        if transform == nil or isvalid(transform) == false then
            return nil
        end

        local playerPosition = transform.WorldPosition
        if playerPosition == nil then
            return nil
        end

        local innerRadius = config.InnerRadius
        local outerRadius = config.OuterRadius
        if outerRadius < innerRadius then
            local temp = innerRadius
            innerRadius = outerRadius
            outerRadius = temp
        end

        local randomAngle = math.random() * 2 * math.pi
        local randomRadius = innerRadius + (math.random() * (outerRadius - innerRadius))

        local x = playerPosition.x + (randomRadius * math.cos(randomAngle))
        local y = playerPosition.y + (randomRadius * math.sin(randomAngle))
        return Vector3(x, y, playerPosition.z)
    end

    -- Backdrop bounds are cached from Map01Bootstrap so spawn/movement can share one authoritative area.
    @ExecSpace("ServerOnly")
    method void RefreshBackdropBoundsCacheServer(boolean forceRefresh)
        if self.RestrictMonstersToBackdrop ~= true then
            self._T.BackdropBounds = nil
            return
        end

        local now = _UtilLogic.ServerElapsedSeconds
        local interval = self.BackdropBoundsRefreshInterval
        if interval <= 0 then
            interval = 0.5
        end

        local lastAt = self._T.BackdropBoundsLastRefreshAt
        if forceRefresh ~= true and lastAt ~= nil and (now - lastAt) < interval then
            return
        end
        self._T.BackdropBoundsLastRefreshAt = now

        local bounds = self:ResolveBackdropBoundsFromBootstrapServer()
        self._T.BackdropBounds = bounds

        if bounds ~= nil then
            self._T.WarnedMissingBackdropBounds = false
            return
        end

        if self._T.WarnedMissingBackdropBounds ~= true then
            log_warning("[MonsterSpawnComponent] Failed to resolve backdrop bounds. path=", tostring(self.BackdropBootstrapPath))
            self._T.WarnedMissingBackdropBounds = true
        end
    end

    @ExecSpace("ServerOnly")
    method table ResolveBackdropBoundsFromBootstrapServer()
        local path = self.BackdropBootstrapPath
        if path == nil or path == "" then
            return nil
        end

        local bootstrapEntity = _EntityService:GetEntityByPath(path)
        if bootstrapEntity == nil or isvalid(bootstrapEntity) == false then
            return nil
        end

        local bootstrap = self:ResolveComponentSafe(bootstrapEntity, "Map01BootstrapComponent", nil)
        if bootstrap == nil then
            return nil
        end

        if bootstrap.RefreshBackdropBoundsFromEntityServer ~= nil then
            pcall(function()
                bootstrap:RefreshBackdropBoundsFromEntityServer(false)
            end)
        end

        local clampEnabled = false
        local clampOk, clampValue = pcall(function()
            return bootstrap.ClampPlayerWithinBackdropBounds
        end)
        if clampOk == true and clampValue == true then
            clampEnabled = true
        end
        if clampEnabled ~= true then
            return nil
        end

        local centerX = 0
        local centerY = 0
        local sizeX = 0
        local sizeY = 0
        local padding = 0

        local centerXOk, centerXValue = pcall(function()
            return bootstrap.BackdropCenterX
        end)
        if centerXOk == true and centerXValue ~= nil then
            centerX = tonumber(centerXValue) or 0
        end

        local centerYOk, centerYValue = pcall(function()
            return bootstrap.BackdropCenterY
        end)
        if centerYOk == true and centerYValue ~= nil then
            centerY = tonumber(centerYValue) or 0
        end

        local sizeXOk, sizeXValue = pcall(function()
            return bootstrap.BackdropSizeX
        end)
        if sizeXOk == true and sizeXValue ~= nil then
            sizeX = tonumber(sizeXValue) or 0
        end

        local sizeYOk, sizeYValue = pcall(function()
            return bootstrap.BackdropSizeY
        end)
        if sizeYOk == true and sizeYValue ~= nil then
            sizeY = tonumber(sizeYValue) or 0
        end

        local paddingOk, paddingValue = pcall(function()
            return bootstrap.BackdropBoundPadding
        end)
        if paddingOk == true and paddingValue ~= nil then
            padding = math.max(0, tonumber(paddingValue) or 0)
        end

        if sizeX <= 0 or sizeY <= 0 then
            return nil
        end

        local halfX = sizeX * 0.5
        local halfY = sizeY * 0.5

        local bounds = {}
        bounds.CenterX = centerX
        bounds.CenterY = centerY
        bounds.MinX = centerX - halfX
        bounds.MaxX = centerX + halfX
        bounds.MinY = centerY - halfY
        bounds.MaxY = centerY + halfY
        bounds.Padding = padding
        return bounds
    end

    @ExecSpace("ServerOnly")
    method boolean IsInsideBackdropBoundsServer(Vector3 targetPosition)
        if self.RestrictMonstersToBackdrop ~= true then
            return true
        end
        if targetPosition == nil then
            return false
        end

        self:RefreshBackdropBoundsCacheServer(false)
        local bounds = self._T.BackdropBounds
        if bounds == nil then
            return false
        end

        local minX = bounds.MinX + bounds.Padding
        local maxX = bounds.MaxX - bounds.Padding
        local minY = bounds.MinY + bounds.Padding
        local maxY = bounds.MaxY - bounds.Padding

        if minX > maxX then
            minX = bounds.CenterX
            maxX = bounds.CenterX
        end
        if minY > maxY then
            minY = bounds.CenterY
            maxY = bounds.CenterY
        end

        if targetPosition.x < minX then
            return false
        end
        if targetPosition.x > maxX then
            return false
        end
        if targetPosition.y < minY then
            return false
        end
        if targetPosition.y > maxY then
            return false
        end
        return true
    end

    -- Boss spawn position is constrained to backdrop center so boss also stays in the same play area.
    @ExecSpace("ServerOnly")
    method Vector3 ResolveBossSpawnPositionServer()
        local z = 0
        local transform = self.Entity.TransformComponent
        if transform ~= nil and isvalid(transform) == true then
            local posOk, posValue = pcall(function()
                return transform.WorldPosition
            end)
            if posOk == true and posValue ~= nil then
                z = posValue.z
            end
        end

        if self.RestrictMonstersToBackdrop ~= true then
            return Vector3(0, 0, z)
        end

        self:RefreshBackdropBoundsCacheServer(false)
        local bounds = self._T.BackdropBounds
        if bounds == nil then
            return Vector3(0, 0, z)
        end

        return Vector3(bounds.CenterX, bounds.CenterY, z)
    end

    -- Every monster uses the same world clamp as player so roaming never leaves GRWorldBackdrop.
    method void ApplyMonsterBackdropClampToMovementServer(Component movement)
        if movement == nil then
            return
        end
        if self.RestrictMonstersToBackdrop ~= true then
            return
        end

        self:RefreshBackdropBoundsCacheServer(false)
        local bounds = self._T.BackdropBounds
        if bounds == nil then
            return
        end

        pcall(function()
            movement.UseWorldBoundsClamp = true
        end)
        pcall(function()
            movement.WorldBoundsMinX = bounds.MinX
        end)
        pcall(function()
            movement.WorldBoundsMaxX = bounds.MaxX
        end)
        pcall(function()
            movement.WorldBoundsMinY = bounds.MinY
        end)
        pcall(function()
            movement.WorldBoundsMaxY = bounds.MaxY
        end)
        pcall(function()
            movement.WorldBoundsPadding = bounds.Padding
        end)
    end

    -- Validity check intentionally stays basic per SPEC v1.1 (no NavMesh dependency yet).
    @ExecSpace("ServerOnly")
    method boolean IsValidSpawnPosition(Vector3 targetPosition)
        if targetPosition == nil then
            return false
        end

        local config = self._T.Config
        if config == nil then
            return false
        end

        local transform = self.Entity.TransformComponent
        if transform == nil or isvalid(transform) == false then
            return false
        end

        local playerPosition = transform.WorldPosition
        if playerPosition == nil then
            return false
        end

        local dx = targetPosition.x - playerPosition.x
        local dy = targetPosition.y - playerPosition.y
        local distanceSqr = (dx * dx) + (dy * dy)
        local innerSqr = config.InnerRadius * config.InnerRadius
        local outerSqr = config.OuterRadius * config.OuterRadius

        if distanceSqr < innerSqr then
            return false
        end
        if distanceSqr > outerSqr then
            return false
        end

        if self:IsInsideBackdropBoundsServer(targetPosition) ~= true then
            return false
        end

        return true
    end

    -- Spawn path attaches metadata immediately so future drop/reward systems can read one source.
    @ExecSpace("ServerOnly")
    method Entity SpawnMonsterByRow(UserDataRow row, Vector3 spawnPosition, boolean isBoss)
        if row == nil then
            return nil
        end
        if spawnPosition == nil then
            return nil
        end
        if self.MonsterParentEntity == nil or isvalid(self.MonsterParentEntity) == false then
            return nil
        end

        local modelId = self:GetRowString(row, "model_type", "")
        if modelId == "" then
            modelId = self:GetFallbackModelType(row)
        end
        if modelId == "" then
            local rowId = self:GetRowString(row, "id", "(unknown)")
            log_warning("[MonsterSpawnComponent] Skip spawn because model_type is empty. rowId=", rowId)
            return nil
        end
        modelId = self:ResolveModelIdForSpawn(modelId)
        if modelId == "" then
            local rowId = self:GetRowString(row, "id", "(unknown)")
            log_warning("[MonsterSpawnComponent] Skip spawn because model id resolution failed. rowId=", rowId)
            return nil
        end

        local spawnName = self:GetRowString(row, "id", "Monster")
        local spawnedEntity = nil
        local spawnOk, spawnResult = pcall(function()
            return _SpawnService:SpawnByModelId(modelId, spawnName, spawnPosition, self.MonsterParentEntity)
        end)
        if spawnOk == true then
            spawnedEntity = spawnResult
        end
        if spawnedEntity == nil or isvalid(spawnedEntity) == false then
            return nil
        end

        -- Spawned enemies must be marked at source so combat systems can split monster/player hit rules.
        local hpSystem = self:ResolveComponentSafe(spawnedEntity, "HPSystemComponent", "CurrentHP")
        if hpSystem ~= nil then
            pcall(function()
                hpSystem.IsMonster = true
            end)
        end

        self:DisablePhysicsColliderIfMapHasNoSimulator(spawnedEntity)
        self:EnsureMonsterTriggerComponent(spawnedEntity)

        if self._T.SpawnedMonsters == nil then
            self._T.SpawnedMonsters = {}
        end
        table.insert(self._T.SpawnedMonsters, spawnedEntity)

        if self._T.SpawnMetaByEntity == nil then
            self._T.SpawnMetaByEntity = {}
        end
        self._T.SpawnMetaByEntity[spawnedEntity] = self:BuildSpawnMetaFromRow(row)

        self:AttachMonsterChaseIfNeeded(spawnedEntity)
        self:ApplyMonsterVisualIfAvailable(spawnedEntity, row)
        self:ApplyMonsterColliderIfAvailable(spawnedEntity, row)
        self:ApplyMonsterStatsIfAvailable(spawnedEntity, row)
        self:EnsureMonsterHPBarServer(spawnedEntity)
        self:UpdateMonsterHPBarByEntityServer(spawnedEntity)

        if isBoss == true then
            self._T.BossSpawnedEntity = spawnedEntity
            local bossAI = self:FindOrAddComponentSafe(spawnedEntity, "BossAIComponent")
            if bossAI ~= nil then
                local currentStage = 1
                local timerComp = self:ResolveComponentSafe(self.Entity, "GameTimerComponent", "CurrentStageId")
                if timerComp ~= nil then
                    local stageOk, stageValue = pcall(function()
                        return timerComp.CurrentStageId
                    end)
                    if stageOk == true and stageValue ~= nil then
                        currentStage = math.max(1, math.floor(stageValue))
                    end
                end

                local bossId = self:GetRowString(row, "id", "")
                local attackInterval = 2.0
                local summonId = "mon_n007"
                if bossId == "mon_b002" then
                    attackInterval = 1.5
                    summonId = "mon_n014"
                end

                local tableAttackInterval = self:GetRowNumber(row, "atk_interval", 0)
                if tableAttackInterval ~= nil and tableAttackInterval > 0 then
                    attackInterval = tableAttackInterval
                end
                local tableSummonId = self:GetRowString(row, "summon_id", "")
                if tableSummonId ~= "" then
                    summonId = tableSummonId
                end

                pcall(function()
                    bossAI.AttackInterval = attackInterval
                    bossAI.SummonMonsterId = summonId
                    bossAI.BossStageId = currentStage
                end)
            end
        end

        return spawnedEntity
    end

    -- Metadata builder stores drop_id for future drop pipeline; detailed drop execution remains deferred.
    method table BuildSpawnMetaFromRow(UserDataRow row)
        local meta = {}
        meta.Id = self:GetRowString(row, "id", "")
        meta.Name = self:GetRowString(row, "name", "")
        meta.MonType = self:GetRowString(row, "mon_type", "")
        meta.ModelType = self:GetRowString(row, "model_type", "")
        meta.MonHP = self:GetRowInteger(row, "mon_hp", 0)
        meta.MonAtk = self:GetRowInteger(row, "mon_atk", 0)
        meta.MonSpd = self:GetRowNumber(row, "mon_spd", 0)
        meta.SpawnStage = self:GetRowInteger(row, "spawn_stage", 1)
        meta.SpawnTimeMin = self:GetSpawnMinuteFromRow(row)
        meta.CreepScore = math.max(0, self:GetRowInteger(row, "creep_score", 0))
        meta.Gold = 0

        meta.DropId = self:GetRowString(row, "drop_id", "")
        meta.DropItem1Id = ""
        meta.DropItem1Rate = 0
        meta.DropItem1Amount = 0
        meta.DropItem2Id = ""
        meta.DropItem2Rate = 0
        meta.DropItem2Amount = 0

        meta.SpriteRuid = self:GetRowString(row, "sprite_ruid", "")
        meta.SoundRuid = self:GetRowString(row, "sound_ruid", "")
        meta.DeathEffectRuid = self:GetRowString(row, "death_effect_ruid", "")
        if self:HasOptionalMonsterColumn("collider_w") == true then
            meta.ColliderW = self:GetRowNumber(row, "collider_w", -1)
        else
            meta.ColliderW = -1
        end
        if self:HasOptionalMonsterColumn("collider_h") == true then
            meta.ColliderH = self:GetRowNumber(row, "collider_h", -1)
        else
            meta.ColliderH = -1
        end
        if self:HasOptionalMonsterColumn("collider_offset_x") == true then
            meta.ColliderOffsetX = self:GetRowNumber(row, "collider_offset_x", 0)
        else
            meta.ColliderOffsetX = 0
        end
        if self:HasOptionalMonsterColumn("collider_offset_y") == true then
            meta.ColliderOffsetY = self:GetRowNumber(row, "collider_offset_y", 0)
        else
            meta.ColliderOffsetY = 0
        end
        meta.IsBoss = self:IsBossRow(row)

        return meta
    end

    -- Boss defeat route branches stage flow and notifies transition/shop systems in one authoritative place.
    @ExecSpace("ServerOnly")
    method void OnBossDefeatedServer(Vector3 deathPos)
        self.IsBossPhase = false
        self._T.BossSpawnedEntity = nil

        local stage = 1
        local timerComp = self:ResolveComponentSafe(self.Entity, "GameTimerComponent", "CurrentStageId")
        if timerComp ~= nil then
            local stageOk, stageValue = pcall(function()
                return timerComp.CurrentStageId
            end)
            if stageOk == true and stageValue ~= nil then
                stage = math.max(1, math.floor(stageValue))
            end
        end
        if self._T.BossDefeatedByStage == nil then
            self._T.BossDefeatedByStage = {}
        end
        self._T.BossDefeatedByStage[stage] = true

        if stage <= 1 then
            local shop = self:ResolveComponentSafe(self.Entity, "ShopManagerComponent", "IsShopOpen")
            if shop ~= nil then
                if shop.OpenBossRewardShopServer ~= nil then
                    pcall(function()
                        shop:OpenBossRewardShopServer()
                    end)
                elseif shop.OpenShopServer ~= nil then
                    pcall(function()
                        shop:OpenShopServer()
                    end)
                end
            end

            local transition = self:ResolveComponentSafe(self.Entity, "RoundTransitionComponent", "PortalInteractRadius")
            if transition ~= nil and transition.ExecuteStageTransitionServer ~= nil then
                pcall(function()
                    transition:ExecuteStageTransitionServer()
                end)
            end
            return
        end

        local infinite = self:ResolveComponentSafe(self.Entity, "InfiniteModeComponent", "CurrentScore")
        if infinite ~= nil then
            if infinite.FinalizeNormalClearServer ~= nil then
                pcall(function()
                    infinite:FinalizeNormalClearServer()
                end)
                return
            end
        end
    end

    -- TODO: Replace this adapter with visual profile resolver when sprite/anim policy is finalized.
    method void ApplyMonsterVisualIfAvailable(Entity targetEntity, UserDataRow row)
        if targetEntity == nil or isvalid(targetEntity) == false then
            return
        end
        if row == nil then
            return
        end

        local spriteRuid = self:GetRowString(row, "sprite_ruid", "")
        if spriteRuid == "" then
            return
        end

        local spriteRenderer = self:ResolveComponentSafe(targetEntity, "SpriteRendererComponent", "SpriteRUID")
        if spriteRenderer == nil then
            return
        end

        local applyOk, _ = pcall(function()
            spriteRenderer.SpriteRUID = spriteRuid
        end)
        if applyOk == false then
            local rowId = self:GetRowString(row, "id", "(unknown)")
            log_warning("[MonsterSpawnComponent] Failed to apply sprite_ruid. rowId=", rowId, ", sprite_ruid=", spriteRuid)
        end
    end

    -- Runtime sprite swaps do not auto-fit colliders, so collider bounds are explicitly data-driven.
    method void ApplyMonsterColliderIfAvailable(Entity targetEntity, UserDataRow row)
        if targetEntity == nil or isvalid(targetEntity) == false then
            return
        end
        if row == nil then
            return
        end

        if self:HasOptionalMonsterColumn("collider_w") == false or self:HasOptionalMonsterColumn("collider_h") == false then
            return
        end

        local colliderW = self:GetRowNumber(row, "collider_w", -1)
        local colliderH = self:GetRowNumber(row, "collider_h", -1)
        if colliderW <= 0 or colliderH <= 0 then
            return
        end

        local colliderSize = Vector2(colliderW, colliderH)
        local offsetXText = ""
        local offsetYText = ""
        if self:HasOptionalMonsterColumn("collider_offset_x") == true then
            offsetXText = self:GetRowString(row, "collider_offset_x", "")
        end
        if self:HasOptionalMonsterColumn("collider_offset_y") == true then
            offsetYText = self:GetRowString(row, "collider_offset_y", "")
        end
        local hasOffset = false
        local colliderOffset = Vector2.zero
        if offsetXText ~= "" and offsetYText ~= "" then
            local offsetX = tonumber(offsetXText)
            local offsetY = tonumber(offsetYText)
            if offsetX ~= nil and offsetY ~= nil then
                hasOffset = true
                colliderOffset = Vector2(offsetX, offsetY)
            end
        end

        local appliedAny = false
        local trigger = self:ResolveComponentSafe(targetEntity, "TriggerComponent", "BoxSize")
        if trigger ~= nil then
            local sizeOk, _ = pcall(function()
                trigger.BoxSize = colliderSize
            end)
            if sizeOk == true then
                appliedAny = true
            end
            if hasOffset == true then
                pcall(function()
                    trigger.ColliderOffset = colliderOffset
                end)
                pcall(function()
                    trigger.BoxOffset = colliderOffset
                end)
            end
        end

        local hit = self:ResolveComponentSafe(targetEntity, "HitComponent", "BoxSize")
        if hit ~= nil then
            local sizeOk, _ = pcall(function()
                hit.BoxSize = colliderSize
            end)
            if sizeOk == true then
                appliedAny = true
            end
            if hasOffset == true then
                pcall(function()
                    hit.ColliderOffset = colliderOffset
                end)
                pcall(function()
                    hit.BoxOffset = colliderOffset
                end)
            end
        end

        if self:HasPhysicsSimulatorInCurrentMap() == true then
            local physicsCollider = self:ResolveComponentSafe(targetEntity, "PhysicsColliderComponent", "BoxSize")
            if physicsCollider ~= nil then
                local sizeOk, _ = pcall(function()
                    physicsCollider.BoxSize = colliderSize
                end)
                if sizeOk == true then
                    appliedAny = true
                end
                if hasOffset == true then
                    pcall(function()
                        physicsCollider.ColliderOffset = colliderOffset
                    end)
                    pcall(function()
                        physicsCollider.BoxOffset = colliderOffset
                    end)
                end
            end
        end

        if appliedAny == false then
            if self:HasPhysicsSimulatorInCurrentMap() == false then
                return
            end
            local rowId = self:GetRowString(row, "id", "(unknown)")
            log_warning("[MonsterSpawnComponent] collider_w/h provided but no collider component found. rowId=", rowId)
        end
    end

    -- PhysicsSimulator is map-level dependency; when missing, disable model physics collider to avoid runtime spam.
    method void DisablePhysicsColliderIfMapHasNoSimulator(Entity targetEntity)
        if targetEntity == nil or isvalid(targetEntity) == false then
            return
        end
        if self:HasPhysicsSimulatorInCurrentMap() == true then
            return
        end

        local physicsCollider = self:ResolveComponentSafe(targetEntity, "PhysicsColliderComponent", "Enable")
        if physicsCollider == nil then
            return
        end

        pcall(function()
            physicsCollider.Enable = false
        end)
    end

    -- Contact combat requires trigger overlap events, so spawn path ensures TriggerComponent is always present.
    method void EnsureMonsterTriggerComponent(Entity targetEntity)
        if targetEntity == nil or isvalid(targetEntity) == false then
            return
        end

        local trigger = self:ResolveComponentSafe(targetEntity, "TriggerComponent", "BoxSize")
        if trigger == nil then
            local addOkA, addResultA = pcall(function()
                return targetEntity:AddComponent("MOD.Core.TriggerComponent")
            end)
            if addOkA == true then
                trigger = addResultA
            end
        end
        if trigger == nil then
            local addOkB, addResultB = pcall(function()
                return targetEntity:AddComponent("TriggerComponent")
            end)
            if addOkB == true then
                trigger = addResultB
            end
        end
        if trigger == nil then
            return
        end

        pcall(function()
            trigger.IsPassive = false
        end)

        local physicsCollider = self:ResolveComponentSafe(targetEntity, "PhysicsColliderComponent", "BoxSize")
        if physicsCollider == nil then
            return
        end

        local sizeOk, boxSize = pcall(function()
            return physicsCollider.BoxSize
        end)
        if sizeOk == true and boxSize ~= nil then
            pcall(function()
                trigger.BoxSize = boxSize
            end)
        end

        local offsetOk, colliderOffset = pcall(function()
            return physicsCollider.ColliderOffset
        end)
        if offsetOk == true and colliderOffset ~= nil then
            pcall(function()
                trigger.ColliderOffset = colliderOffset
            end)
            pcall(function()
                trigger.BoxOffset = colliderOffset
            end)
        end
    end

    method boolean HasPhysicsSimulatorInCurrentMap()
        if self._T.HasMapPhysicsSimulator ~= nil then
            return self._T.HasMapPhysicsSimulator
        end

        local mapEntity = nil
        if self.Entity ~= nil and isvalid(self.Entity) == true then
            mapEntity = self.Entity.CurrentMap
        end
        if mapEntity == nil or isvalid(mapEntity) == false then
            self._T.HasMapPhysicsSimulator = false
            return false
        end

        local simulator = nil
        local readOkA, readResultA = pcall(function()
            return mapEntity:GetComponent("MOD.Core.PhysicsSimulatorComponent")
        end)
        if readOkA == true then
            simulator = readResultA
        end
        if simulator == nil then
            local readOkB, readResultB = pcall(function()
                return mapEntity:GetComponent("PhysicsSimulatorComponent")
            end)
            if readOkB == true then
                simulator = readResultB
            end
        end

        local hasSimulator = (simulator ~= nil and isvalid(simulator) == true)
        self._T.HasMapPhysicsSimulator = hasSimulator

        if hasSimulator == false and self._T.WarnedMissingPhysicsSimulator ~= true then
            log_warning("[MonsterSpawnComponent] PhysicsSimulatorComponent missing on current map. physics collider will be disabled on spawned monsters.")
            self._T.WarnedMissingPhysicsSimulator = true
        end
        return hasSimulator
    end

    -- TODO: Replace this adapter with dedicated monster stat component integration when spec arrives.
    method void ApplyMonsterStatsIfAvailable(Entity targetEntity, UserDataRow row)
        if targetEntity == nil or isvalid(targetEntity) == false then
            return
        end
        if row == nil then
            return
        end

        local scaled = self:ResolveMonsterStatValues(row, self._T.CurrentSpawnElapsedSec)
        local monHp = scaled.MonHP
        local monAtk = scaled.MonAtk
        local monSpd = scaled.MonSpd

        if monHp >= 0 then
            local hpSystem = self:ResolveComponentSafe(targetEntity, "HPSystemComponent", "CurrentHP")
            if hpSystem ~= nil then
                pcall(function()
                    hpSystem.MaxHP = monHp
                end)
                pcall(function()
                    hpSystem.CurrentHP = monHp
                end)
            end
        end

        if monAtk >= 0 then
            local monsterAttack = self:ResolveComponentSafe(targetEntity, "MonsterAttackComponent", "AttackPower")
            if monsterAttack ~= nil then
                pcall(function()
                    monsterAttack.AttackPower = monAtk
                end)
            end
        end

        local chase = self:ResolveComponentSafe(targetEntity, "MonsterChaseComponent", "ThinkInterval")
        if chase ~= nil then
            if monAtk >= 0 then
                pcall(function()
                    chase.ContactDamage = math.max(monAtk, 0)
                end)
            end
        end

        local movement = self:ResolveComponentSafe(targetEntity, "MovementComponent", "MoveSpeed")
        if movement ~= nil then
            pcall(function()
                movement.UsePlayerInput = false
            end)
            self:ApplyMonsterBackdropClampToMovementServer(movement)

            if monSpd >= 0 then
                pcall(function()
                    movement.MoveSpeed = monSpd
                end)
            end
        end
    end

    -- Mode rows support per-minute stat growth; normal rows use fixed mon_hp/mon_atk/mon_spd values.
    method table ResolveMonsterStatValues(UserDataRow row, number elapsedSec)
        local stats = {}
        stats.MonHP = self:GetRowInteger(row, "mon_hp", -1)
        stats.MonAtk = self:GetRowInteger(row, "mon_atk", -1)
        stats.MonSpd = self:GetRowNumber(row, "mon_spd", -1)

        if self:IsModeMonsterRow(row) ~= true then
            return stats
        end

        local minute = math.max(0, elapsedSec) / 60

        local baseHp = self:GetRowNumber(row, "mode_mon_hp", -1)
        if baseHp >= 0 then
            local hpUp = self:GetRowNumber(row, "mode_mon_hp_up", 0)
            stats.MonHP = math.max(0, math.floor(baseHp + (hpUp * minute)))
        end

        local baseAtk = self:GetRowNumber(row, "mon_atk", -1)
        if baseAtk >= 0 then
            local atkUp = self:GetRowNumber(row, "mode_mon_atk_up", 0)
            stats.MonAtk = math.max(0, math.floor(baseAtk + (atkUp * minute)))
        end

        local baseSpd = self:GetRowNumber(row, "mon_spd", -1)
        if baseSpd >= 0 then
            local spdUp = self:GetRowNumber(row, "mon_spd_up", -1)
            if spdUp < 0 then
                spdUp = self:GetRowNumber(row, "mode_mon_spd_up", 0)
            end
            stats.MonSpd = math.max(0, baseSpd + (spdUp * minute))
        end

        return stats
    end

    method boolean IsModeMonsterRow(UserDataRow row)
        local monType = string.lower(self:GetRowString(row, "mon_type", ""))
        return string.sub(monType, 1, 5) == "mode_"
    end

    -- Every spawned monster gets chase AI once so nearest-player pursuit works without model-side manual setup.
    method void AttachMonsterChaseIfNeeded(Entity targetEntity)
        if targetEntity == nil or isvalid(targetEntity) == false then
            return
        end

        local existing = self:ResolveComponentSafe(targetEntity, "MonsterChaseComponent", "ThinkInterval")
        if existing ~= nil then
            return
        end

        local addOkA, addResultA = pcall(function()
            return targetEntity:AddComponent("script.MonsterChaseComponent")
        end)
        if addOkA == true and addResultA ~= nil then
            return
        end

        pcall(function()
            targetEntity:AddComponent("MonsterChaseComponent")
        end)
    end

    -- Delayed pass binds map-placed monsters after table load and entity bootstrap are complete.
    @ExecSpace("ServerOnly")
    method void SchedulePlacedMonsterBindingServer()
        if self.AutoBindPlacedMonsterEntities ~= true then
            return
        end

        if self._T.PlacedMonsterBindTimerId ~= nil and self._T.PlacedMonsterBindTimerId > 0 then
            _TimerService:ClearTimer(self._T.PlacedMonsterBindTimerId)
            self._T.PlacedMonsterBindTimerId = 0
        end

        local delay = self.PlacedMonsterBindDelay
        if delay < 0 then
            delay = 0
        end

        local bindFn = function()
            self._T.PlacedMonsterBindTimerId = 0
            self:AutoBindPlacedMonstersServer()
        end
        self._T.PlacedMonsterBindTimerId = _TimerService:SetTimerOnce(bindFn, delay)
    end

    -- Static monsters are scanned once and receive the same table-driven stat/collider pipeline as spawned monsters.
    @ExecSpace("ServerOnly")
    method integer AutoBindPlacedMonstersServer()
        if self.AutoBindPlacedMonsterEntities ~= true then
            return 0
        end

        if self._T.DataReady ~= true then
            self:LoadSpawnDataFromTable()
        end
        if self._T.MonsterRows == nil or #self._T.MonsterRows <= 0 then
            return 0
        end

        local mapEntity = self.Entity.CurrentMap
        if mapEntity == nil or isvalid(mapEntity) == false then
            return 0
        end

        local bindCount = self:BindPlacedMonstersRecursiveServer(mapEntity)
        if self.EnableDebugLogs == true and bindCount > 0 then
            log("[MonsterSpawnComponent][DEBUG] placed monster auto-bind count=", bindCount)
        end
        return bindCount
    end

    @ExecSpace("ServerOnly")
    method integer BindPlacedMonstersRecursiveServer(Entity node)
        if node == nil or isvalid(node) == false then
            return 0
        end

        local bindCount = self:TryBindPlacedMonsterEntityServer(node)
        local children = node.Children
        if children == nil then
            return bindCount
        end

        for _, child in pairs(children) do
            if child ~= nil and isvalid(child) == true then
                bindCount += self:BindPlacedMonstersRecursiveServer(child)
            end
        end

        return bindCount
    end

    -- Candidate selection excludes player/spawned entries and targets explicit or signature-based monster entities only.
    @ExecSpace("ServerOnly")
    method integer TryBindPlacedMonsterEntityServer(Entity targetEntity)
        if targetEntity == nil or isvalid(targetEntity) == false then
            return 0
        end
        if targetEntity == self.Entity then
            return 0
        end

        if self._T.AutoBoundPlacedMonsters == nil then
            self._T.AutoBoundPlacedMonsters = {}
        end
        if self._T.AutoBoundPlacedMonsters[targetEntity] == true then
            return 0
        end

        if self._T.SpawnMetaByEntity ~= nil and self._T.SpawnMetaByEntity[targetEntity] ~= nil then
            self._T.AutoBoundPlacedMonsters[targetEntity] = true
            return 0
        end
        if targetEntity.PlayerComponent ~= nil then
            return 0
        end

        local hpSystem = self:ResolveComponentSafe(targetEntity, "HPSystemComponent", "CurrentHP")
        if hpSystem == nil then
            return 0
        end

        local isMonster = false
        local readMonsterOk, readMonsterValue = pcall(function()
            return hpSystem.IsMonster
        end)
        if readMonsterOk == true and readMonsterValue == true then
            isMonster = true
        end

        local chase = self:ResolveComponentSafe(targetEntity, "MonsterChaseComponent", "ThinkInterval")
        if isMonster ~= true and chase == nil then
            return 0
        end

        local row = self:ResolvePlacedMonsterRowServer(targetEntity, hpSystem)
        if row == nil then
            return 0
        end

        self:AttachMonsterChaseIfNeeded(targetEntity)
        self:EnsureMonsterTriggerComponent(targetEntity)
        self:DisablePhysicsColliderIfMapHasNoSimulator(targetEntity)
        self:ApplyMonsterVisualIfAvailable(targetEntity, row)
        self:ApplyMonsterColliderIfAvailable(targetEntity, row)
        self:ApplyMonsterStatsIfAvailable(targetEntity, row)

        pcall(function()
            hpSystem.IsMonster = true
        end)
        pcall(function()
            hpSystem.IsDead = false
        end)
        pcall(function()
            hpSystem.IsInvincible = false
        end)

        self:EnsureMonsterHPBarServer(targetEntity)
        self:UpdateMonsterHPBarByEntityServer(targetEntity)

        self._T.AutoBoundPlacedMonsters[targetEntity] = true
        return 1
    end

    -- Row resolution priority: explicit HPSystem.MonsterDataId -> entity name as row id -> default non-mode normal row.
    @ExecSpace("ServerOnly")
    method UserDataRow ResolvePlacedMonsterRowServer(Entity targetEntity, Component hpSystem)
        if self._T.MonsterRows == nil or #self._T.MonsterRows <= 0 then
            return nil
        end

        local explicitId = self:GetPlacedMonsterDataIdFromHPServer(hpSystem)
        if explicitId ~= "" then
            local explicitRow = self:GetMonsterRowByIdServer(explicitId)
            if explicitRow ~= nil then
                return explicitRow
            end
        end

        local entityName = ""
        if targetEntity ~= nil and isvalid(targetEntity) == true then
            local readOk, readValue = pcall(function()
                return targetEntity.Name
            end)
            if readOk == true and readValue ~= nil then
                entityName = tostring(readValue)
            end
        end
        local nameAsId = self:NormalizeMonsterRowIdToken(entityName)
        if nameAsId ~= "" then
            local nameRow = self:GetMonsterRowByIdServer(nameAsId)
            if nameRow ~= nil then
                return nameRow
            end
        end

        return self:GetDefaultPlacedMonsterRowServer()
    end

    @ExecSpace("ServerOnly")
    method string GetPlacedMonsterDataIdFromHPServer(Component hpSystem)
        if hpSystem == nil then
            return ""
        end

        local value = ""
        local readOk, readValue = pcall(function()
            return hpSystem.MonsterDataId
        end)
        if readOk == true and readValue ~= nil then
            value = tostring(readValue)
        end

        return self:NormalizeMonsterRowIdToken(value)
    end

    @ExecSpace("ServerOnly")
    method UserDataRow GetMonsterRowByIdServer(string rowId)
        local normalizedId = self:NormalizeMonsterRowIdToken(rowId)
        if normalizedId == "" then
            return nil
        end
        if self._T.MonsterRows == nil then
            return nil
        end

        for _, row in pairs(self._T.MonsterRows) do
            if row == nil then
                continue
            end
            local currentId = self:NormalizeMonsterRowIdToken(self:GetRowString(row, "id", ""))
            if currentId == normalizedId then
                return row
            end
        end

        return nil
    end

    -- Default fallback picks earliest non-mode normal row so static monsters stay deterministic without explicit id.
    @ExecSpace("ServerOnly")
    method UserDataRow GetDefaultPlacedMonsterRowServer()
        if self._T.DefaultPlacedMonsterRow ~= nil then
            return self._T.DefaultPlacedMonsterRow
        end
        if self._T.MonsterRows == nil or #self._T.MonsterRows <= 0 then
            return nil
        end

        local firstAny = nil
        local firstNormal = nil
        local firstNormalAtZero = nil
        for _, row in pairs(self._T.MonsterRows) do
            if row == nil then
                continue
            end

            local rowId = self:GetRowString(row, "id", "")
            if rowId == "" then
                continue
            end

            if firstAny == nil then
                firstAny = row
            end

            local monType = string.lower(self:GetRowString(row, "mon_type", ""))
            if string.sub(monType, 1, 5) == "mode_" then
                continue
            end
            if monType ~= "normal" then
                continue
            end

            if firstNormal == nil then
                firstNormal = row
            end

            local spawnMin = self:GetSpawnMinuteFromRow(row)
            if spawnMin <= 0 and firstNormalAtZero == nil then
                firstNormalAtZero = row
            end
        end

        local selected = firstNormalAtZero
        if selected == nil then
            selected = firstNormal
        end
        if selected == nil then
            selected = firstAny
        end

        self._T.DefaultPlacedMonsterRow = selected
        return selected
    end

    method string NormalizeMonsterRowIdToken(string value)
        if value == nil then
            return ""
        end

        local text = tostring(value)
        text = string.gsub(text, "^%s+", "")
        text = string.gsub(text, "%s+$", "")
        text = string.lower(text)
        if text == "" then
            return ""
        end
        if text == "-" or text == "null" or text == "nil" then
            return ""
        end

        return text
    end

    -- NameTag-based HP bars are updated from server so all clients observe the same monster HP feedback.
    @ExecSpace("ServerOnly")
    method void UpdateMonsterHPBarsServer()
        if self.EnableMonsterHPBar ~= true then
            return
        end

        self:PruneMonsterHPBarRuntimeServer()
        local visited = {}

        if self._T.SpawnedMonsters ~= nil then
            for _, spawnedEntity in pairs(self._T.SpawnedMonsters) do
                if spawnedEntity ~= nil and isvalid(spawnedEntity) == true and visited[spawnedEntity] ~= true then
                    visited[spawnedEntity] = true
                    self:UpdateMonsterHPBarByEntityServer(spawnedEntity)
                end
            end
        end

        if self._T.AutoBoundPlacedMonsters ~= nil then
            for boundEntity, isBound in pairs(self._T.AutoBoundPlacedMonsters) do
                if isBound == true and boundEntity ~= nil and isvalid(boundEntity) == true and visited[boundEntity] ~= true then
                    visited[boundEntity] = true
                    self:UpdateMonsterHPBarByEntityServer(boundEntity)
                end
            end
        end
    end

    @ExecSpace("ServerOnly")
    method void UpdateMonsterHPBarByEntityServer(Entity monsterEntity)
        if self.EnableMonsterHPBar ~= true then
            return
        end
        if monsterEntity == nil or isvalid(monsterEntity) == false then
            return
        end

        local hpSystem = self:ResolveComponentSafe(monsterEntity, "HPSystemComponent", "CurrentHP")
        if hpSystem == nil then
            self:HideMonsterHPBarServer(monsterEntity)
            return
        end

        local isMonster = false
        local monsterOk, monsterValue = pcall(function()
            return hpSystem.IsMonster
        end)
        if monsterOk == true and monsterValue == true then
            isMonster = true
        end
        if isMonster ~= true then
            self:HideMonsterHPBarServer(monsterEntity)
            return
        end

        local isDead = false
        local deadOk, deadValue = pcall(function()
            return hpSystem.IsDead
        end)
        if deadOk == true and deadValue == true then
            isDead = true
        end
        if isDead == true then
            self:HideMonsterHPBarServer(monsterEntity)
            return
        end

        local maxHp = 1
        local maxOk, maxValue = pcall(function()
            return hpSystem.MaxHP
        end)
        if maxOk == true and maxValue ~= nil then
            local parsedMax = tonumber(maxValue)
            if parsedMax ~= nil and parsedMax > 0 then
                maxHp = math.floor(parsedMax)
            end
        end

        local currentHp = 0
        local currentOk, currentValue = pcall(function()
            return hpSystem.CurrentHP
        end)
        if currentOk == true and currentValue ~= nil then
            local parsedCurrent = tonumber(currentValue)
            if parsedCurrent ~= nil then
                currentHp = math.max(0, math.min(math.floor(parsedCurrent), maxHp))
            end
        end

        local hpBar = self:EnsureMonsterHPBarServer(monsterEntity)
        if hpBar == nil then
            return
        end

        local layout = self:ResolveMonsterHPBarLayoutServer(monsterEntity)
        local label = self:BuildMonsterHPBarLabelServer(currentHp, maxHp, layout.Segments, self.MonsterHPBarShowNumeric)
        pcall(function()
            hpBar.Name = label
            hpBar.Enable = true
            hpBar.OffsetY = self.MonsterHPBarOffsetY
            hpBar.FontSize = layout.FontSize
            hpBar.Bold = true
            hpBar.FontColor = Color(0.2, 0.9, 0.25, 1)
        end)
    end

    -- HP bar component is created lazily to support both spawned monsters and map-placed monsters.
    @ExecSpace("ServerOnly")
    method Component EnsureMonsterHPBarServer(Entity monsterEntity)
        if self.EnableMonsterHPBar ~= true then
            return nil
        end
        if monsterEntity == nil or isvalid(monsterEntity) == false then
            return nil
        end

        local hpBar = self:ResolveComponentSafe(monsterEntity, "NameTagComponent", "Name")
        if hpBar == nil then
            local addOkA, addResultA = pcall(function()
                return monsterEntity:AddComponent("MOD.Core.NameTagComponent")
            end)
            if addOkA == true then
                hpBar = addResultA
            end
        end
        if hpBar == nil then
            local addOkB, addResultB = pcall(function()
                return monsterEntity:AddComponent("NameTagComponent")
            end)
            if addOkB == true then
                hpBar = addResultB
            end
        end
        if hpBar == nil then
            return nil
        end

        if self._T.MonsterHPBarByEntity == nil then
            self._T.MonsterHPBarByEntity = {}
        end
        self._T.MonsterHPBarByEntity[monsterEntity] = hpBar
        return hpBar
    end

    -- HP bar width/height follows model scale (x) and y/x ratio so oversized tags shrink with sprite size.
    method table ResolveMonsterHPBarLayoutServer(Entity monsterEntity)
        local layout = {}
        layout.Segments = math.max(self.MonsterHPBarSegments, 2)
        layout.FontSize = math.max(self.MonsterHPBarFontSize, 1)

        local modelScaleX = 1
        local modelScaleY = 1
        if monsterEntity ~= nil and isvalid(monsterEntity) == true then
            local transform = monsterEntity.TransformComponent
            if transform ~= nil and isvalid(transform) == true then
                local scaleOk, scaleValue = pcall(function()
                    return transform.Scale
                end)
                if scaleOk == true and scaleValue ~= nil then
                    local sx = tonumber(scaleValue.x)
                    local sy = tonumber(scaleValue.y)
                    if sx ~= nil and math.abs(sx) > 0 then
                        modelScaleX = math.abs(sx)
                    end
                    if sy ~= nil and math.abs(sy) > 0 then
                        modelScaleY = math.abs(sy)
                    end
                end
            end
        end

        local scaledX = modelScaleX * math.max(self.MonsterHPBarModelScaleXMultiplier, 0.01)
        local ratioY = 1
        if modelScaleX > 0 then
            ratioY = modelScaleY / modelScaleX
        end
        local scaledY = scaledX * ratioY * math.max(self.MonsterHPBarModelScaleYMultiplier, 0.01)

        local maxSegments = math.max(self.MonsterHPBarSegments, 2)
        local minSegments = math.max(self.MonsterHPBarMinSegments, 1)
        if minSegments > maxSegments then
            minSegments = maxSegments
        end
        local calculatedSegments = math.floor(maxSegments * scaledX)
        if calculatedSegments < minSegments then
            calculatedSegments = minSegments
        end
        if calculatedSegments > maxSegments then
            calculatedSegments = maxSegments
        end
        layout.Segments = calculatedSegments

        local minFont = math.max(self.MonsterHPBarMinFontSize, 1)
        local calculatedFontSize = math.floor(self.MonsterHPBarFontSize * scaledY)
        if calculatedFontSize < minFont then
            calculatedFontSize = minFont
        end
        if calculatedFontSize > self.MonsterHPBarFontSize then
            calculatedFontSize = self.MonsterHPBarFontSize
        end
        layout.FontSize = calculatedFontSize

        return layout
    end

    -- Keep numeric-only mode compact as `current/max` to avoid clipping on small monster UI.
    method string BuildMonsterHPBarLabelServer(integer currentHp, integer maxHp, integer segmentOverride, boolean includeNumeric)
        local safeMax = math.max(1, maxHp)
        local safeCurrent = math.max(0, math.min(currentHp, safeMax))
        if includeNumeric == true then
            return tostring(safeCurrent) .. "/" .. tostring(safeMax)
        end

        local segments = math.floor(segmentOverride)
        if segments <= 0 then
            segments = math.floor(self.MonsterHPBarSegments)
        end
        if segments < 1 then
            segments = 1
        end
        if segments > 20 then
            segments = 20
        end

        local ratio = safeCurrent / safeMax
        local filled = math.floor(ratio * segments + 0.0001)
        if safeCurrent > 0 and filled <= 0 then
            filled = 1
        end
        if filled > segments then
            filled = segments
        end

        local filledText = ""
        for index = 1, filled do
            filledText ..= "#"
        end

        local emptyText = ""
        for index = (filled + 1), segments do
            emptyText ..= "-"
        end

        return "[" .. filledText .. emptyText .. "]"
    end

    @ExecSpace("ServerOnly")
    method void HideMonsterHPBarServer(Entity monsterEntity)
        if self._T.MonsterHPBarByEntity == nil then
            self._T.MonsterHPBarByEntity = {}
        end
        if monsterEntity == nil then
            return
        end

        local hpBar = self._T.MonsterHPBarByEntity[monsterEntity]
        if hpBar == nil then
            hpBar = self:ResolveComponentSafe(monsterEntity, "NameTagComponent", "Name")
        end
        if hpBar ~= nil then
            pcall(function()
                hpBar.Name = ""
                hpBar.Enable = false
            end)
        end
    end

    @ExecSpace("ServerOnly")
    method void PruneMonsterHPBarRuntimeServer()
        if self._T.MonsterHPBarByEntity == nil then
            self._T.MonsterHPBarByEntity = {}
            return
        end

        local pruned = {}
        for targetEntity, hpBar in pairs(self._T.MonsterHPBarByEntity) do
            if targetEntity ~= nil and isvalid(targetEntity) == true and hpBar ~= nil and isvalid(hpBar) == true then
                pruned[targetEntity] = hpBar
            end
        end
        self._T.MonsterHPBarByEntity = pruned
    end

    @ExecSpace("ServerOnly")
    method void ClearMonsterHPBarRuntimeServer()
        if self._T.MonsterHPBarByEntity == nil then
            self._T.MonsterHPBarByEntity = {}
            return
        end

        for _, hpBar in pairs(self._T.MonsterHPBarByEntity) do
            if hpBar ~= nil and isvalid(hpBar) == true then
                pcall(function()
                    hpBar.Name = ""
                    hpBar.Enable = false
                end)
            end
        end
        self._T.MonsterHPBarByEntity = {}
    end

    -- Public read API exposes spawn metadata without coupling callers to internal cache structure.
    method table GetSpawnMetaByEntity(Entity targetEntity)
        if targetEntity == nil or isvalid(targetEntity) == false then
            return nil
        end
        if self._T.SpawnMetaByEntity == nil then
            return nil
        end

        local sourceMeta = self._T.SpawnMetaByEntity[targetEntity]
        if sourceMeta == nil then
            return nil
        end

        return self:CloneTable(sourceMeta)
    end

    -- Dead monsters start one-shot death-effect playback and timed fade-out before destroy.
    @ExecSpace("ServerOnly")
    method void ProcessMonsterDeathSequenceServer()
        self:PruneMonsterDeathRuntimeServer()

        if self._T.SpawnedMonsters ~= nil then
            for _, spawnedEntity in pairs(self._T.SpawnedMonsters) do
                self:TryStartMonsterDeathSequenceServer(spawnedEntity)
            end
        end

        if self._T.AutoBoundPlacedMonsters ~= nil then
            for boundEntity, isBound in pairs(self._T.AutoBoundPlacedMonsters) do
                if isBound == true then
                    self:TryStartMonsterDeathSequenceServer(boundEntity)
                end
            end
        end
    end

    @ExecSpace("ServerOnly")
    method void TryStartMonsterDeathSequenceServer(Entity monsterEntity)
        if monsterEntity == nil or isvalid(monsterEntity) == false then
            return
        end

        if self._T.MonsterDeathRuntimeByEntity ~= nil and self._T.MonsterDeathRuntimeByEntity[monsterEntity] ~= nil then
            return
        end

        if self:IsDeadMonsterEntityServer(monsterEntity) ~= true then
            return
        end

        self:BeginMonsterDeathSequenceServer(monsterEntity)
    end

    -- Server checks both IsDead flag and HP value to tolerate mixed legacy death writers.
    method boolean IsDeadMonsterEntityServer(Entity monsterEntity)
        if monsterEntity == nil or isvalid(monsterEntity) == false then
            return false
        end
        if monsterEntity.PlayerComponent ~= nil then
            return false
        end

        local hpSystem = self:ResolveComponentSafe(monsterEntity, "HPSystemComponent", "CurrentHP")
        if hpSystem == nil then
            return false
        end

        local isMonster = false
        local isMonsterOk, isMonsterValue = pcall(function()
            return hpSystem.IsMonster
        end)
        if isMonsterOk == true and isMonsterValue == true then
            isMonster = true
        end
        if isMonster ~= true then
            return false
        end

        local deadOk, deadValue = pcall(function()
            return hpSystem.IsDead
        end)
        if deadOk == true and deadValue == true then
            return true
        end

        local hpOk, hpValue = pcall(function()
            return hpSystem.CurrentHP
        end)
        if hpOk == true and hpValue ~= nil then
            local parsedHp = tonumber(hpValue)
            if parsedHp ~= nil and parsedHp <= 0 then
                return true
            end
        end

        return false
    end

    -- Death setup freezes combat interaction first, then applies death effect sprite and starts fade timer.
    @ExecSpace("ServerOnly")
    method void BeginMonsterDeathSequenceServer(Entity monsterEntity)
        if monsterEntity == nil or isvalid(monsterEntity) == false then
            return
        end

        if self._T.MonsterDeathRuntimeByEntity == nil then
            self._T.MonsterDeathRuntimeByEntity = {}
        end
        if self._T.MonsterDeathRuntimeByEntity[monsterEntity] ~= nil then
            return
        end

        local spawnMeta = nil
        if self._T.SpawnMetaByEntity ~= nil then
            spawnMeta = self._T.SpawnMetaByEntity[monsterEntity]
        end
        if spawnMeta ~= nil and spawnMeta.IsBoss == true then
            local deathPos = monsterEntity.TransformComponent.WorldPosition
            self:OnBossDefeatedServer(deathPos)
        end

        self:PrepareDeadMonsterForFadeServer(monsterEntity)

        -- Drop pipeline starts at death-sequence entry so visual fade timing does not delay reward spawn.
        local dropManager = self:ResolveComponentSafe(self.Entity, "ItemDropManagerComponent", "DropDataTableName")
        if dropManager ~= nil and dropManager.ExecuteDropServer ~= nil then
            local dropId = ""
            if self._T.SpawnMetaByEntity ~= nil then
                local spawnMeta = self._T.SpawnMetaByEntity[monsterEntity]
                if spawnMeta ~= nil and spawnMeta.DropId ~= nil then
                    dropId = tostring(spawnMeta.DropId)
                end
            end

            if dropId ~= "" then
                local deathPos = monsterEntity.TransformComponent.WorldPosition
                if deathPos ~= nil then
                    pcall(function()
                        dropManager:ExecuteDropServer(Vector2(deathPos.x, deathPos.y), dropId)
                    end)
                end
            end
        end

        self:HideMonsterHPBarServer(monsterEntity)

        local runtime = {}
        runtime.ElapsedSeconds = 0
        runtime.LeadTime = math.max(self.MonsterDeathEffectLeadTime, 0)
        runtime.FadeDuration = math.max(self.MonsterDeathFadeDuration, 0.01)
        runtime.TickInterval = self.MonsterDeathFadeTick
        if runtime.TickInterval <= 0 then
            runtime.TickInterval = 0.05
        end
        runtime.TimerId = 0
        runtime.BaseR = 1
        runtime.BaseG = 1
        runtime.BaseB = 1
        runtime.BaseA = 1

        local spriteRenderer = self:ResolveComponentSafe(monsterEntity, "SpriteRendererComponent", "SpriteRUID")
        if spriteRenderer ~= nil then
            local colorOk, colorValue = pcall(function()
                return spriteRenderer.Color
            end)
            if colorOk == true and colorValue ~= nil then
                local readR = tonumber(colorValue.r)
                local readG = tonumber(colorValue.g)
                local readB = tonumber(colorValue.b)
                local readA = tonumber(colorValue.a)
                if readR ~= nil then
                    runtime.BaseR = readR
                end
                if readG ~= nil then
                    runtime.BaseG = readG
                end
                if readB ~= nil then
                    runtime.BaseB = readB
                end
                if readA ~= nil and readA > 0 then
                    runtime.BaseA = readA
                end
            end

            local deathEffectRuid = self:ResolveMonsterDeathEffectRuidServer(monsterEntity)
            if deathEffectRuid ~= nil and deathEffectRuid ~= "" then
                pcall(function()
                    spriteRenderer.SpriteRUID = deathEffectRuid
                    spriteRenderer.PlayRate = 1
                    spriteRenderer.StartFrameIndex = 0
                    spriteRenderer.EndFrameIndex = 2147483647
                end)
            end
        end

        self._T.MonsterDeathRuntimeByEntity[monsterEntity] = runtime

        local tickFn = function()
            self:TickMonsterDeathFadeServer(monsterEntity)
        end
        local timerId = _TimerService:SetTimerRepeat(tickFn, runtime.TickInterval, 0)
        runtime.TimerId = timerId
        self._T.MonsterDeathRuntimeByEntity[monsterEntity] = runtime
    end

    -- Contact damage and chase movement are disabled immediately so dead monsters cannot keep dealing damage.
    @ExecSpace("ServerOnly")
    method void PrepareDeadMonsterForFadeServer(Entity monsterEntity)
        if monsterEntity == nil or isvalid(monsterEntity) == false then
            return
        end

        local trigger = self:ResolveComponentSafe(monsterEntity, "TriggerComponent", "IsPassive")
        if trigger ~= nil then
            pcall(function()
                trigger.IsPassive = true
            end)
        end

        local rigidbody = self:ResolveComponentSafe(monsterEntity, "RigidbodyComponent", "MoveVelocity")
        if rigidbody ~= nil then
            pcall(function()
                rigidbody.MoveVelocity = Vector2.zero
            end)
        end

        local movement = self:ResolveComponentSafe(monsterEntity, "MovementComponent", "CanMove")
        if movement ~= nil then
            pcall(function()
                movement.CanMove = false
            end)
            pcall(function()
                movement.UsePlayerInput = false
            end)
            if movement.SetMoveDirectionServer ~= nil then
                pcall(function()
                    movement:SetMoveDirectionServer(Vector2.zero)
                end)
            end
            pcall(function()
                movement._T.ServerInputDirection = Vector2.zero
            end)
        end

        local chase = self:ResolveComponentSafe(monsterEntity, "MonsterChaseComponent", "ThinkInterval")
        if chase ~= nil then
            if chase.ClearThinkTimerServer ~= nil then
                pcall(function()
                    chase:ClearThinkTimerServer()
                end)
            end
            pcall(function()
                chase.Enable = false
            end)
        end
    end

    -- Death effect lead time is followed by alpha fade, then the entity is destroyed exactly once.
    @ExecSpace("ServerOnly")
    method void TickMonsterDeathFadeServer(Entity monsterEntity)
        if self._T.MonsterDeathRuntimeByEntity == nil then
            return
        end

        local runtime = self._T.MonsterDeathRuntimeByEntity[monsterEntity]
        if runtime == nil then
            return
        end

        if monsterEntity == nil or isvalid(monsterEntity) == false then
            self:ClearMonsterDeathRuntimeServer(monsterEntity)
            return
        end

        local tickInterval = runtime.TickInterval
        if tickInterval == nil or tickInterval <= 0 then
            tickInterval = 0.05
        end

        runtime.ElapsedSeconds += tickInterval
        local leadTime = runtime.LeadTime
        if leadTime == nil then
            leadTime = 0
        end

        if runtime.ElapsedSeconds < leadTime then
            self._T.MonsterDeathRuntimeByEntity[monsterEntity] = runtime
            return
        end

        local fadeDuration = runtime.FadeDuration
        if fadeDuration == nil or fadeDuration <= 0 then
            fadeDuration = 0.01
        end

        local elapsedFade = runtime.ElapsedSeconds - leadTime
        local ratio = elapsedFade / fadeDuration
        if ratio < 0 then
            ratio = 0
        end
        if ratio > 1 then
            ratio = 1
        end

        local remainAlpha = (1 - ratio) * runtime.BaseA
        if remainAlpha < 0 then
            remainAlpha = 0
        end
        self:ApplyMonsterFadeAlphaServer(monsterEntity, runtime.BaseR, runtime.BaseG, runtime.BaseB, remainAlpha)

        if ratio >= 1 then
            self:ClearMonsterDeathRuntimeServer(monsterEntity)
            if monsterEntity ~= nil and isvalid(monsterEntity) == true then
                _EntityService:Destroy(monsterEntity)
            end
            return
        end

        self._T.MonsterDeathRuntimeByEntity[monsterEntity] = runtime
    end

    @ExecSpace("ServerOnly")
    method void ApplyMonsterFadeAlphaServer(Entity monsterEntity, number baseR, number baseG, number baseB, number alpha)
        if monsterEntity == nil or isvalid(monsterEntity) == false then
            return
        end

        local spriteRenderer = self:ResolveComponentSafe(monsterEntity, "SpriteRendererComponent", "SpriteRUID")
        if spriteRenderer == nil then
            return
        end

        pcall(function()
            spriteRenderer.Color = Color(baseR, baseG, baseB, alpha)
        end)
    end

    -- Uses cached spawn metadata first, then row fallback for placed/bound monsters.
    @ExecSpace("ServerOnly")
    method string ResolveMonsterDeathEffectRuidServer(Entity monsterEntity)
        if monsterEntity == nil or isvalid(monsterEntity) == false then
            return ""
        end

        if self._T.SpawnMetaByEntity ~= nil then
            local spawnMeta = self._T.SpawnMetaByEntity[monsterEntity]
            if spawnMeta ~= nil and spawnMeta.DeathEffectRuid ~= nil then
                local text = tostring(spawnMeta.DeathEffectRuid)
                if text ~= "" then
                    return text
                end
            end
        end

        local hpSystem = self:ResolveComponentSafe(monsterEntity, "HPSystemComponent", "CurrentHP")
        if hpSystem == nil then
            return ""
        end

        local rowId = self:GetPlacedMonsterDataIdFromHPServer(hpSystem)
        if rowId == nil or rowId == "" then
            return ""
        end

        local row = self:GetMonsterRowByIdServer(rowId)
        if row == nil then
            return ""
        end

        return self:GetRowString(row, "death_effect_ruid", "")
    end

    @ExecSpace("ServerOnly")
    method void ClearMonsterDeathRuntimeServer(Entity monsterEntity)
        if self._T.MonsterDeathRuntimeByEntity == nil then
            return
        end
        if monsterEntity == nil then
            return
        end

        local runtime = self._T.MonsterDeathRuntimeByEntity[monsterEntity]
        if runtime == nil then
            return
        end

        local timerId = runtime.TimerId
        if timerId ~= nil and timerId > 0 then
            _TimerService:ClearTimer(timerId)
        end

        self._T.MonsterDeathRuntimeByEntity[monsterEntity] = nil
    end

    -- Runtime prune clears stale timer records when entities are externally removed first.
    @ExecSpace("ServerOnly")
    method void PruneMonsterDeathRuntimeServer()
        if self._T.MonsterDeathRuntimeByEntity == nil then
            self._T.MonsterDeathRuntimeByEntity = {}
            return
        end

        local pruned = {}
        for trackedEntity, runtime in pairs(self._T.MonsterDeathRuntimeByEntity) do
            if trackedEntity ~= nil and isvalid(trackedEntity) == true then
                pruned[trackedEntity] = runtime
                continue
            end

            if runtime ~= nil and runtime.TimerId ~= nil and runtime.TimerId > 0 then
                _TimerService:ClearTimer(runtime.TimerId)
            end
        end

        self._T.MonsterDeathRuntimeByEntity = pruned
    end

    -- Endplay/destroy both call this to stop all per-monster death fade timers.
    @ExecSpace("ServerOnly")
    method void ClearMonsterDeathRuntimeTimersServer()
        if self._T.MonsterDeathRuntimeByEntity == nil then
            self._T.MonsterDeathRuntimeByEntity = {}
            return
        end

        for _, runtime in pairs(self._T.MonsterDeathRuntimeByEntity) do
            if runtime ~= nil and runtime.TimerId ~= nil and runtime.TimerId > 0 then
                _TimerService:ClearTimer(runtime.TimerId)
            end
        end

        self._T.MonsterDeathRuntimeByEntity = {}
    end

    -- Pruning keeps field cap checks accurate even when external systems destroy spawned entities.
    @ExecSpace("ServerOnly")
    method void PruneSpawnedMonsters()
        if self._T.SpawnedMonsters == nil then
            self._T.SpawnedMonsters = {}
        end

        local oldMeta = self._T.SpawnMetaByEntity
        local newList = {}
        local newMeta = {}

        for _, entity in pairs(self._T.SpawnedMonsters) do
            if entity ~= nil and isvalid(entity) == true then
                table.insert(newList, entity)
                if oldMeta ~= nil and oldMeta[entity] ~= nil then
                    newMeta[entity] = oldMeta[entity]
                end
            else
                if oldMeta ~= nil and oldMeta[entity] ~= nil then
                    self:HandleSpawnedMonsterRemovedServer(oldMeta[entity])
                end
            end
        end

        self._T.SpawnedMonsters = newList
        self._T.SpawnMetaByEntity = newMeta
    end

    -- Removed-entity hook reports kill/clear events to InfiniteModeComponent without hard coupling.
    @ExecSpace("ServerOnly")
    method void HandleSpawnedMonsterRemovedServer(table spawnMeta)
        if spawnMeta == nil then
            return
        end

        local infiniteMode = self:ResolveComponentSafe(self.Entity, "InfiniteModeComponent", "CurrentScore")
        if infiniteMode == nil then
            return
        end

        local monsterId = ""
        local creepScore = 0
        if spawnMeta.Id ~= nil then
            monsterId = tostring(spawnMeta.Id)
        end
        if spawnMeta.CreepScore ~= nil then
            creepScore = math.max(0, math.floor(spawnMeta.CreepScore))
        end

        if monsterId ~= "" and infiniteMode.OnMonsterKilledServer ~= nil then
            pcall(function()
                infiniteMode:OnMonsterKilledServer(monsterId, creepScore)
            end)
        end

        -- Boss clear flow is handled in OnBossDefeatedServer() to avoid duplicate popup/event paths.
    end

    method integer GetSpawnedMonsterCount()
        if self._T.SpawnedMonsters == nil then
            return 0
        end
        return #self._T.SpawnedMonsters
    end

    method void WarnMissingRequiredColumnOnce(string tableName, string columnName, string key)
        if self._T.RequiredColumnWarned == nil then
            self._T.RequiredColumnWarned = {}
        end

        local warnKey = tostring(tableName) .. "|" .. tostring(columnName) .. "|" .. tostring(key)
        if self._T.RequiredColumnWarned[warnKey] == true then
            return
        end
        self._T.RequiredColumnWarned[warnKey] = true

        log_warning(
            "[MonsterSpawnComponent] missing required column value. table=",
            tostring(tableName),
            ", column=",
            tostring(columnName),
            ", key=",
            tostring(key)
        )
    end

    method string GetRowString(UserDataRow row, string columnName, string fallbackValue)
        local fallback = fallbackValue
        if fallback == nil then
            fallback = ""
        end

        if row == nil then
            return fallback
        end
        if columnName == nil or columnName == "" then
            return fallback
        end

        local text = nil
        local readOk, readResult = pcall(function()
            return row:GetItem(columnName)
        end)
        if readOk == true then
            text = readResult
        end
        if text == nil then
            return fallback
        end

        local normalized = tostring(text)
        normalized = string.gsub(normalized, "^%s+", "")
        normalized = string.gsub(normalized, "%s+$", "")
        if normalized == "" then
            return fallback
        end

        local lowered = string.lower(normalized)
        if normalized == "-" or lowered == "null" or lowered == "nil" then
            return fallback
        end

        return normalized
    end

    method integer GetRowInteger(UserDataRow row, string columnName, integer fallbackValue)
        local text = self:GetRowString(row, columnName, "")
        if text == "" then
            return math.floor(fallbackValue)
        end

        local parsed = tonumber(text)
        if parsed == nil then
            return math.floor(fallbackValue)
        end

        return math.floor(parsed)
    end

    method number GetRowNumber(UserDataRow row, string columnName, number fallbackValue)
        local text = self:GetRowString(row, columnName, "")
        if text == "" then
            return fallbackValue
        end

        local parsed = tonumber(text)
        if parsed == nil then
            return fallbackValue
        end

        return parsed
    end

    method boolean GetRowBoolean(UserDataRow row, string columnName, boolean fallbackValue)
        local text = string.lower(self:GetRowString(row, columnName, ""))
        if text == "" then
            return fallbackValue
        end
        if text == "true" or text == "1" or text == "yes" then
            return true
        end
        if text == "false" or text == "0" or text == "no" then
            return false
        end
        return fallbackValue
    end

    -- SpawnByModelId requires model entry id; resolver tolerates name/entry-key mixed authoring.
    method string ResolveModelIdForSpawn(string rawModelType)
        local normalized = self:NormalizeModelIdText(rawModelType)
        if normalized == "" then
            return ""
        end

        if self:IsExplicitModelId(normalized) == true then
            return normalized
        end

        local resolvedId = ""
        local resolveOk, resolveResult = pcall(function()
            return _EntryService:GetModelIdByName(normalized)
        end)
        if resolveOk == true and resolveResult ~= nil then
            resolvedId = self:NormalizeModelIdText(tostring(resolveResult))
        end
        if resolvedId ~= "" then
            return resolvedId
        end

        return normalized
    end

    method string NormalizeModelIdText(string value)
        if value == nil then
            return ""
        end

        local text = tostring(value)
        if text == "" then
            return ""
        end

        local prefix = "model://"
        if string.sub(text, 1, #prefix) == prefix then
            return string.sub(text, #prefix + 1)
        end

        return text
    end

    -- Explicit-id detector prevents unnecessary lookup calls for GUID/preset-style ids.
    method boolean IsExplicitModelId(string value)
        if value == nil or value == "" then
            return false
        end

        if string.find(value, "-") ~= nil then
            return true
        end
        if string.find(value, "$") ~= nil then
            return true
        end
        if string.find(value, "://") ~= nil then
            return true
        end

        return false
    end

    method table CloneTable(table source)
        local clone = {}
        if source == nil then
            return clone
        end

        for key, value in pairs(source) do
            clone[key] = value
        end
        return clone
    end

    -- Gate trace logs spawn-on/off reason transitions with throttle to keep logs readable during monitor polling.
    @ExecSpace("ServerOnly")
    method void TraceSpawnGateServer(boolean canSpawn, string reason)
        if self.EnableDebugLogs ~= true then
            return
        end

        local changed = false
        if self._T.LastSpawnGateAllowed ~= canSpawn then
            changed = true
        end
        if self._T.LastSpawnGateReason ~= reason then
            changed = true
        end

        local nowSeconds = self:GetServerNowSeconds()
        local throttle = self.DebugLogThrottleSeconds
        if throttle < 0 then
            throttle = 0
        end
        local lastAt = self._T.LastSpawnGateLogAt
        if lastAt == nil then
            lastAt = -9999
        end

        if changed == false and (nowSeconds - lastAt) < throttle then
            return
        end

        self._T.LastSpawnGateAllowed = canSpawn
        self._T.LastSpawnGateReason = reason
        self._T.LastSpawnGateLogAt = nowSeconds

        log(
            "[MonsterSpawnComponent][DEBUG] gate canSpawn=", canSpawn,
            ", reason=", reason,
            ", dataReady=", self._T.DataReady,
            ", bossPhase=", self.IsBossPhase,
            ", hasParent=", (self.MonsterParentEntity ~= nil),
            ", lobbySafeZone=", self:IsSafeZoneActiveServer(),
            ", shopOpen=", self:IsShopOpenServer(),
            ", spawnActive=", self.IsSpawnActive
        )
    end

    -- Server elapsed time helper is isolated so debug throttle stays deterministic even if util lookup fails.
    method number GetServerNowSeconds()
        local nowSeconds = 0
        local readOk, readValue = pcall(function()
            return _UtilLogic.ServerElapsedSeconds
        end)
        if readOk == true and readValue ~= nil then
            nowSeconds = readValue
        end
        return nowSeconds
    end

    method void LogError(string message)
        local loggedOk, _ = pcall(function()
            log_error(message)
        end)
        if loggedOk == false then
            log_warning(message)
        end
    end

    -- Utility bootstrap first; fallback lookup is retained for resilience in partially configured maps.
    method void EnsureGRUtil()
        if self._T.GRUtil ~= nil and self._T.GRUtil.ResolveComponent ~= nil then
            return
        end

        local utilComponent = nil
        if self.Entity ~= nil and isvalid(self.Entity) == true then
            utilComponent = self.Entity:GetComponent("script.GRUtilModule")
            if utilComponent == nil then
                utilComponent = self.Entity:GetComponent("GRUtilModule")
            end
            if utilComponent == nil then
                local addOk1, addResult1 = pcall(function()
                    return self.Entity:AddComponent("script.GRUtilModule")
                end)
                if addOk1 == true then
                    utilComponent = addResult1
                end
            end
            if utilComponent == nil then
                local addOk2, addResult2 = pcall(function()
                    return self.Entity:AddComponent("GRUtilModule")
                end)
                if addOk2 == true then
                    utilComponent = addResult2
                end
            end
        end

        if utilComponent ~= nil and isvalid(utilComponent) == true then
            local bootstrapOk, utilApi = pcall(function()
                return utilComponent:BootstrapUtil()
            end)
            if bootstrapOk == true and utilApi ~= nil then
                self._T.GRUtil = utilApi
            end
            if self._T.GRUtil ~= nil and self._T.GRUtil.ResolveComponent ~= nil then
                return
            end
        end

        self._T.UseGRUtilFallback = true
    end

    method any ResolveComponentSafe(Entity targetEntity, string scriptName, string markerField)
        if targetEntity == nil or isvalid(targetEntity) == false then
            return nil
        end

        if self._T.GRUtil ~= nil and self._T.GRUtil.ResolveComponent ~= nil then
            return self._T.GRUtil.ResolveComponent(targetEntity, scriptName, markerField)
        end

        local prefixedName = scriptName
        local plainName = scriptName
        if string.sub(scriptName, 1, 7) == "script." then
            plainName = string.sub(scriptName, 8)
        else
            prefixedName = "script." .. scriptName
        end

        local component = targetEntity:GetComponent(prefixedName)
        if component == nil then
            component = targetEntity:GetComponent(plainName)
        end
        if component == nil then
            return nil
        end

        if markerField ~= nil and markerField ~= "" then
            local ok, _ = pcall(function()
                return component[markerField]
            end)
            if ok == false then
                return nil
            end
        end

        return component
    end

    method Component FindOrAddComponentSafe(Entity targetEntity, string typeName)
        if targetEntity == nil or isvalid(targetEntity) == false then
            return nil
        end

        if self._T.GRUtil ~= nil and self._T.GRUtil.FindOrAddComponent ~= nil then
            return self._T.GRUtil.FindOrAddComponent(targetEntity, typeName)
        end

        local existing = self:ResolveComponentSafe(targetEntity, typeName, nil)
        if existing ~= nil then
            return existing
        end

        local prefixedName = typeName
        local plainName = typeName
        if string.sub(typeName, 1, 7) == "script." then
            plainName = string.sub(typeName, 8)
        else
            prefixedName = "script." .. typeName
        end

        local added = nil
        local addOk1, addResult1 = pcall(function()
            return targetEntity:AddComponent(prefixedName)
        end)
        if addOk1 == true then
            added = addResult1
        end

        if added == nil then
            local addOk2, addResult2 = pcall(function()
                return targetEntity:AddComponent(plainName)
            end)
            if addOk2 == true then
                added = addResult2
            end
        end

        return added
    end
end
