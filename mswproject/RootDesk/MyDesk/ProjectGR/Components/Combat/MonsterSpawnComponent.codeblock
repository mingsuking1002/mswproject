  "Usage": 0,
  "UsePublish": 1,
  "UseService": 0,
  "CoreVersion": "26.1.0.0",
  "StudioVersion": "",
  "DynamicLoading": 0,
  "ContentProto": {
    "Use": "Json",
    "Json": {
      "CoreVersion": {
        "Major": 0,
        "Minor": 2
      },
      "ScriptVersion": {
        "Major": 1,
        "Minor": 1
      },
      "Description": "",
      "Id": "5db31753-fa7c-4095-a6d0-a19fd35e5b6a",
      "Language": 1,
      "Name": "MonsterSpawnComponent",
      "Type": 1,
      "Source": 1,
      "Target": "@Component\nscript MonsterSpawnComponent extends Component\n\n    property string SpawnConfigTableName = \"SpawnConfig\"\n    property string MonsterDataTableName = \"MonsterData\"\n    property string ModeMonsterDataTableName = \"ModeMonsterData\"\n    property string SpawnWaveTableName = \"\"\n\n    @Sync\n    property boolean IsSpawnActive = false\n    @Sync\n    property boolean IsBossPhase = false\n    property Entity MonsterParentEntity = nil\n\n    property string MonsterContainerName = \"MonsterContainer\"\n    property number StateMonitorInterval = 0.2\n    property boolean EnableDebugLogs = false\n    property number DebugLogThrottleSeconds = 1.0\n    property boolean AutoBindPlacedMonsterEntities = true\n    property number PlacedMonsterBindDelay = 0.2\n    property number MonsterDeathEffectLeadTime = 0\n    property number MonsterDeathFadeDuration = 0.25\n    property number MonsterDeathFadeTick = 0.05\n    property boolean EnableMonsterHPBar = true\n    property integer MonsterHPBarSegments = 10\n    property number MonsterHPBarOffsetY = -0.65\n    property number MonsterHPBarFontSize = 7\n    property number MonsterHPBarModelScaleXMultiplier = 0.25\n    property number MonsterHPBarModelScaleYMultiplier = 0.25\n    property integer MonsterHPBarMinSegments = 2\n    property integer MonsterHPBarMinFontSize = 2\n    property boolean MonsterHPBarShowNumeric = true\n\n    -- Server initializes all runtime caches once so spawn flow remains deterministic after hot-reload.\n    @ExecSpace(\"ServerOnly\")\n    method void OnInitialize()\n        self:EnsureGRUtil()\n\n        self._T.SpawnTimerId = 0\n        self._T.StateMonitorTimerId = 0\n        self._T.SpawnedMonsters = {}\n        self._T.SpawnMetaByEntity = {}\n        self._T.Config = nil\n        self._T.MonsterRows = {}\n        self._T.ModelTypeByMonType = nil\n        self._T.RowFallbackModelById = nil\n        self._T.OptionalColumnAvailability = {}\n        self._T.OptionalColumnMissingWarned = {}\n        self._T.RequiredColumnWarned = {}\n        self._T.CreepScoreByMonsterId = {}\n        self._T.BossSpawnedEntity = nil\n        self._T.WarnedMissingContainer = false\n        self._T.HasMapPhysicsSimulator = nil\n        self._T.WarnedMissingPhysicsSimulator = false\n        self._T.UseModeMonsterData = false\n        self._T.CurrentSpawnElapsedSec = 0\n        self._T.DataReady = false\n        self._T.LastSpawnGateAllowed = nil\n        self._T.LastSpawnGateReason = \"\"\n        self._T.LastSpawnGateLogAt = -9999\n        self._T.SpawnTickCounter = 0\n        self._T.PlacedMonsterBindTimerId = 0\n        self._T.AutoBoundPlacedMonsters = {}\n        self._T.DefaultPlacedMonsterRow = nil\n        self._T.MonsterDeathRuntimeByEntity = {}\n        self._T.MonsterHPBarByEntity = {}\n\n        self.IsSpawnActive = false\n        self.IsBossPhase = false\n    end\n\n    -- BeginPlay loads DataTable snapshots first, then starts safe-zone aware monitor loop.\n    @ExecSpace(\"ServerOnly\")\n    method void OnBeginPlay()\n        self:LoadSpawnDataFromTable()\n        self:ResolveMonsterParentEntity()\n        self:StartStateMonitorTimer()\n        self:RefreshSpawnStateServer()\n        self:SchedulePlacedMonsterBindingServer()\n    end\n\n    -- Map enter re-resolves parent entity because map transition can invalidate previous references.\n    @ExecSpace(\"ServerOnly\")\n    method void OnMapEnter(Entity enteredMap)\n        self:ResolveMonsterParentEntity()\n        self._T.HasMapPhysicsSimulator = nil\n        self:RefreshSpawnStateServer()\n        self:SchedulePlacedMonsterBindingServer()\n    end\n\n    -- EndPlay clears active timers so delayed callbacks never run on recycled entities.\n    @ExecSpace(\"ServerOnly\")\n    method void OnEndPlay()\n        self:StopSpawning()\n        self:ClearMonsterDeathRuntimeTimersServer()\n        self:ClearMonsterHPBarRuntimeServer()\n\n        if self._T.StateMonitorTimerId ~= nil and self._T.StateMonitorTimerId > 0 then\n            _TimerService:ClearTimer(self._T.StateMonitorTimerId)\n            self._T.StateMonitorTimerId = 0\n        end\n        if self._T.PlacedMonsterBindTimerId ~= nil and self._T.PlacedMonsterBindTimerId > 0 then\n            _TimerService:ClearTimer(self._T.PlacedMonsterBindTimerId)\n            self._T.PlacedMonsterBindTimerId = 0\n        end\n    end\n\n    -- Destroy repeats timer cleanup as final safety net for unusual lifecycle paths.\n    @ExecSpace(\"ServerOnly\")\n    method void OnDestroy()\n        self:ClearMonsterDeathRuntimeTimersServer()\n        self:ClearMonsterHPBarRuntimeServer()\n\n        if self._T.SpawnTimerId ~= nil and self._T.SpawnTimerId > 0 then\n            _TimerService:ClearTimer(self._T.SpawnTimerId)\n            self._T.SpawnTimerId = 0\n        end\n        if self._T.StateMonitorTimerId ~= nil and self._T.StateMonitorTimerId > 0 then\n            _TimerService:ClearTimer(self._T.StateMonitorTimerId)\n            self._T.StateMonitorTimerId = 0\n        end\n        if self._T.PlacedMonsterBindTimerId ~= nil and self._T.PlacedMonsterBindTimerId > 0 then\n            _TimerService:ClearTimer(self._T.PlacedMonsterBindTimerId)\n            self._T.PlacedMonsterBindTimerId = 0\n        end\n    end\n\n    -- One entrypoint loads both config and monster table so availability gate is centralized.\n    @ExecSpace(\"ServerOnly\")\n    method boolean LoadSpawnDataFromTable()\n        local configLoaded = self:LoadSpawnConfigFromTable()\n        local monsterLoaded = self:LoadMonsterDataFromTable()\n\n        self._T.DataReady = (configLoaded == true and monsterLoaded == true)\n        if self._T.DataReady == false then\n            self:StopSpawning()\n        end\n\n        if self.EnableDebugLogs == true then\n            log(\"[MonsterSpawnComponent][DEBUG] LoadSpawnDataFromTable dataReady=\", self._T.DataReady, \", configLoaded=\", configLoaded, \", monsterLoaded=\", monsterLoaded)\n        end\n\n        return self._T.DataReady\n    end\n\n    -- Config table is mandatory because all balance values are data-driven by SPEC.\n    @ExecSpace(\"ServerOnly\")\n    method boolean LoadSpawnConfigFromTable()\n        self._T.Config = nil\n\n        if self.SpawnConfigTableName == nil or self.SpawnConfigTableName == \"\" then\n            self:LogError(\"[MonsterSpawnComponent] SpawnConfigTableName is empty.\")\n            return false\n        end\n\n        local tableData = nil\n        local loadOk, loadResult = pcall(function()\n            return _DataService:GetTable(self.SpawnConfigTableName)\n        end)\n        if loadOk == true then\n            tableData = loadResult\n        end\n        if tableData == nil then\n            self:LogError(\"[MonsterSpawnComponent] Failed to load SpawnConfig table: \" .. tostring(self.SpawnConfigTableName))\n            return false\n        end\n\n        local rows = nil\n        local rowsOk, rowsResult = pcall(function()\n            return tableData:GetAllRow()\n        end)\n        if rowsOk == true then\n            rows = rowsResult\n        end\n        if rows == nil or #rows <= 0 then\n            self:LogError(\"[MonsterSpawnComponent] SpawnConfig has no rows.\")\n            return false\n        end\n        local row = rows[1]\n        if self:ValidateSpawnConfigRowContract(row) ~= true then\n            self:LogError(\"[MonsterSpawnComponent] SpawnConfig required columns are missing.\")\n            return false\n        end\n\n        local innerRadius = self:GetRowNumber(row, \"InnerRadius\", -1)\n        local outerRadius = self:GetRowNumber(row, \"OuterRadius\", -1)\n        local spawnInterval = self:GetRowNumber(row, \"SpawnInterval\", -1)\n        local spawnPerTick = self:GetRowInteger(row, \"SpawnPerTick\", -1)\n        if innerRadius < 0 or outerRadius < 0 or spawnInterval <= 0 or spawnPerTick <= 0 then\n            self:LogError(\"[MonsterSpawnComponent] Invalid SpawnConfig values. Check SpawnConfig.csv.\")\n            return false\n        end\n        if outerRadius < innerRadius then\n            self:LogError(\"[MonsterSpawnComponent] OuterRadius must be >= InnerRadius.\")\n            return false\n        end\n\n        local config = {}\n        config.InnerRadius = innerRadius\n        config.OuterRadius = outerRadius\n        config.SpawnInterval = spawnInterval\n        config.SpawnPerTick = spawnPerTick\n\n        self._T.Config = config\n        if self.EnableDebugLogs == true then\n            log(\"[MonsterSpawnComponent][DEBUG] SpawnConfig loaded. rowCount=\", #rows, \", inner=\", innerRadius, \", outer=\", outerRadius, \", interval=\", spawnInterval, \", perTick=\", spawnPerTick)\n        end\n        return true\n    end\n\n    -- MonsterData table is single source of truth for wave and drop metadata in current iteration.\n    @ExecSpace(\"ServerOnly\")\n    method boolean LoadMonsterDataFromTable()\n        self._T.MonsterRows = {}\n        self._T.ModelTypeByMonType = nil\n        self._T.RowFallbackModelById = nil\n\n        local tableName = self:ResolveMonsterDataTableName()\n        if tableName == \"\" then\n            self:LogError(\"[MonsterSpawnComponent] MonsterDataTableName is empty.\")\n            return false\n        end\n\n        local tableData = nil\n        local loadOk, loadResult = pcall(function()\n            return _DataService:GetTable(tableName)\n        end)\n        if loadOk == true then\n            tableData = loadResult\n        end\n        if tableData == nil then\n            self:LogError(\"[MonsterSpawnComponent] Failed to load MonsterData table: \" .. tostring(tableName))\n            return false\n        end\n\n        local rows = nil\n        local rowsOk, rowsResult = pcall(function()\n            return tableData:GetAllRow()\n        end)\n        if rowsOk == true then\n            rows = rowsResult\n        end\n        if rows == nil or #rows <= 0 then\n            self:LogError(\"[MonsterSpawnComponent] MonsterData has no rows.\")\n            return false\n        end\n\n        self:ValidateMonsterRowsContract(rows, tableName)\n        self._T.MonsterRows = rows\n        self:BuildRowModelFallbackCache(rows)\n        self:BuildOptionalMonsterColumnsCache(rows)\n        self:BuildCreepScoreCache(rows)\n        return true\n    end\n\n    -- Creep-score cache avoids repeated table scans when kill-score callbacks are triggered frequently.\n    method void BuildCreepScoreCache(table rows)\n        self._T.CreepScoreByMonsterId = {}\n        if rows == nil then\n            return\n        end\n\n        for _, row in pairs(rows) do\n            if row == nil then\n                continue\n            end\n\n            local rowId = self:GetRowString(row, \"id\", \"\")\n            if rowId == \"\" then\n                continue\n            end\n\n            local creepScore = self:GetRowInteger(row, \"creep_score\", 0)\n            self._T.CreepScoreByMonsterId[rowId] = math.max(0, creepScore)\n        end\n    end\n\n    method boolean ValidateSpawnConfigRowContract(UserDataRow row)\n        if row == nil then\n            return false\n        end\n\n        local required = {\n            \"InnerRadius\",\n            \"OuterRadius\",\n            \"SpawnInterval\",\n            \"SpawnPerTick\"\n        }\n\n        local valid = true\n        for _, columnName in pairs(required) do\n            local text = self:GetRowString(row, columnName, \"\")\n            if text == \"\" then\n                self:WarnMissingRequiredColumnOnce(self.SpawnConfigTableName, columnName, \"SpawnConfig\")\n                valid = false\n            end\n        end\n\n        return valid\n    end\n\n    method void ValidateMonsterRowsContract(table rows, string tableName)\n        if rows == nil then\n            return\n        end\n\n        for _, row in pairs(rows) do\n            if row == nil then\n                continue\n            end\n\n            local rowId = self:GetRowString(row, \"id\", \"\")\n            if rowId == \"\" then\n                continue\n            end\n\n            local monType = self:GetRowString(row, \"mon_type\", \"\")\n            if monType == \"\" then\n                self:WarnMissingRequiredColumnOnce(tableName, \"mon_type\", rowId)\n            end\n\n            local isModeRow = self:IsModeMonsterRow(row)\n            local modelType = self:GetRowString(row, \"model_type\", \"\")\n            if isModeRow ~= true and modelType == \"\" then\n                self:WarnMissingRequiredColumnOnce(tableName, \"model_type\", rowId)\n            end\n\n            if isModeRow == true then\n                if self:GetRowString(row, \"mode_mon_hp\", \"\") == \"\" then\n                    self:WarnMissingRequiredColumnOnce(tableName, \"mode_mon_hp\", rowId)\n                end\n            else\n                if self:GetRowString(row, \"mon_hp\", \"\") == \"\" then\n                    self:WarnMissingRequiredColumnOnce(tableName, \"mon_hp\", rowId)\n                end\n            end\n\n            if self:GetRowString(row, \"mon_atk\", \"\") == \"\" then\n                self:WarnMissingRequiredColumnOnce(tableName, \"mon_atk\", rowId)\n            end\n            if self:GetRowString(row, \"mon_spd\", \"\") == \"\" then\n                self:WarnMissingRequiredColumnOnce(tableName, \"mon_spd\", rowId)\n            end\n            if self:GetRowString(row, \"spawn_time\", \"\") == \"\" then\n                self:WarnMissingRequiredColumnOnce(tableName, \"spawn_time\", rowId)\n            end\n            if self:GetRowString(row, \"creep_score\", \"\") == \"\" then\n                self:WarnMissingRequiredColumnOnce(tableName, \"creep_score\", rowId)\n            end\n        end\n    end\n\n    -- Fallback cache keeps CSV authoring flexible when repetitive model_type cells are intentionally left empty.\n    method void BuildRowModelFallbackCache(table rows)\n        self._T.RowFallbackModelById = {}\n        self._T.ModelTypeByMonType = {}\n\n        if rows == nil or #rows <= 0 then\n            return\n        end\n\n        local lastModelByType = {}\n        for index = 1, #rows do\n            local row = rows[index]\n            if row == nil then\n                continue\n            end\n\n            local rowId = self:GetRowString(row, \"id\", \"\")\n            local monType = string.lower(self:GetRowString(row, \"mon_type\", \"\"))\n            local modelType = self:GetRowString(row, \"model_type\", \"\")\n\n            if monType ~= \"\" and modelType ~= \"\" and self._T.ModelTypeByMonType[monType] == nil then\n                self._T.ModelTypeByMonType[monType] = modelType\n            end\n\n            if monType ~= \"\" and modelType ~= \"\" then\n                lastModelByType[monType] = modelType\n                continue\n            end\n\n            if rowId ~= \"\" and monType ~= \"\" and lastModelByType[monType] ~= nil then\n                self._T.RowFallbackModelById[rowId] = lastModelByType[monType]\n            end\n        end\n    end\n\n    -- Optional-column cache avoids repeated row:GetItem calls that would spam engine errors when schema is old.\n    method void BuildOptionalMonsterColumnsCache(table rows)\n        self._T.OptionalColumnAvailability = {}\n        self._T.OptionalColumnMissingWarned = {}\n\n        if rows == nil or #rows <= 0 then\n            return\n        end\n\n        local probeRow = rows[1]\n        if probeRow == nil then\n            return\n        end\n\n        local optionalColumns = {\n            \"collider_w\",\n            \"collider_h\",\n            \"collider_offset_x\",\n            \"collider_offset_y\"\n        }\n        for _, columnName in pairs(optionalColumns) do\n            self:ProbeOptionalMonsterColumn(probeRow, columnName)\n        end\n    end\n\n    method boolean ProbeOptionalMonsterColumn(UserDataRow row, string columnName)\n        if self._T.OptionalColumnAvailability == nil then\n            self._T.OptionalColumnAvailability = {}\n        end\n\n        if columnName == nil or columnName == \"\" then\n            return false\n        end\n        if self._T.OptionalColumnAvailability[columnName] ~= nil then\n            return self._T.OptionalColumnAvailability[columnName]\n        end\n        if row == nil then\n            self._T.OptionalColumnAvailability[columnName] = false\n            return false\n        end\n\n        local readOk, _ = pcall(function()\n            return row:GetItem(columnName)\n        end)\n        self._T.OptionalColumnAvailability[columnName] = readOk\n\n        if readOk == false then\n            self:WarnMissingOptionalMonsterColumn(columnName)\n        end\n        return readOk\n    end\n\n    method boolean HasOptionalMonsterColumn(string columnName)\n        if columnName == nil or columnName == \"\" then\n            return false\n        end\n\n        if self._T.OptionalColumnAvailability == nil then\n            self._T.OptionalColumnAvailability = {}\n        end\n\n        local cached = self._T.OptionalColumnAvailability[columnName]\n        if cached ~= nil then\n            return cached\n        end\n\n        local rows = self._T.MonsterRows\n        if rows == nil or #rows <= 0 then\n            self._T.OptionalColumnAvailability[columnName] = false\n            return false\n        end\n\n        return self:ProbeOptionalMonsterColumn(rows[1], columnName)\n    end\n\n    method void WarnMissingOptionalMonsterColumn(string columnName)\n        if self._T.OptionalColumnMissingWarned == nil then\n            self._T.OptionalColumnMissingWarned = {}\n        end\n        if self._T.OptionalColumnMissingWarned[columnName] == true then\n            return\n        end\n\n        self._T.OptionalColumnMissingWarned[columnName] = true\n        log_warning(\"[MonsterSpawnComponent] Optional column missing in MonsterData. fallback applied. column=\", columnName)\n    end\n\n    -- Backward-compatible resolver allows old SPEC alias without blocking current MonsterData naming.\n    method string ResolveMonsterDataTableName()\n        if self._T.UseModeMonsterData == true then\n            if self.ModeMonsterDataTableName ~= nil and self.ModeMonsterDataTableName ~= \"\" then\n                return self.ModeMonsterDataTableName\n            end\n            return \"\"\n        end\n\n        if self.MonsterDataTableName ~= nil and self.MonsterDataTableName ~= \"\" then\n            return self.MonsterDataTableName\n        end\n        if self.SpawnWaveTableName ~= nil and self.SpawnWaveTableName ~= \"\" then\n            return self.SpawnWaveTableName\n        end\n        return \"\"\n    end\n\n    -- Infinite-mode entry switches spawn source table and restarts gate evaluation in one server API.\n    @ExecSpace(\"ServerOnly\")\n    method boolean ActivateInfiniteModeServer(boolean enabled)\n        local useModeData = (enabled == true)\n        self._T.UseModeMonsterData = useModeData\n\n        self.IsBossPhase = false\n        self._T.BossSpawnedEntity = nil\n\n        local loaded = self:LoadMonsterDataFromTable()\n        self._T.DataReady = (self._T.Config ~= nil and loaded == true)\n\n        if loaded == false then\n            self:StopSpawning()\n            return false\n        end\n\n        self:RefreshSpawnStateServer()\n        return true\n    end\n\n    -- Score lookup API is used by InfiniteMode fallback path when spawn meta is unavailable.\n    @ExecSpace(\"ServerOnly\")\n    method integer GetCreepScoreByMonsterIdServer(string monsterId)\n        if monsterId == nil or monsterId == \"\" then\n            return 0\n        end\n\n        if self._T.CreepScoreByMonsterId == nil then\n            self._T.CreepScoreByMonsterId = {}\n        end\n\n        local cached = self._T.CreepScoreByMonsterId[monsterId]\n        if cached ~= nil then\n            return math.max(0, math.floor(cached))\n        end\n        return 0\n    end\n\n    method string GetFallbackModelType(UserDataRow row)\n        if row == nil then\n            return \"\"\n        end\n\n        local rowId = self:GetRowString(row, \"id\", \"\")\n        if rowId ~= \"\" and self._T.RowFallbackModelById ~= nil then\n            local rowFallback = self._T.RowFallbackModelById[rowId]\n            if rowFallback ~= nil and rowFallback ~= \"\" then\n                return rowFallback\n            end\n        end\n\n        local monType = string.lower(self:GetRowString(row, \"mon_type\", \"\"))\n        if monType == \"\" then\n            return \"\"\n        end\n\n        if self._T.ModelTypeByMonType ~= nil then\n            local defaultModel = self._T.ModelTypeByMonType[monType]\n            if defaultModel ~= nil and defaultModel ~= \"\" then\n                return defaultModel\n            end\n        end\n\n        return \"\"\n    end\n\n    -- Parent resolver enforces SPEC decision: no MonsterContainer means spawn stays disabled.\n    @ExecSpace(\"ServerOnly\")\n    method void ResolveMonsterParentEntity()\n        self.MonsterParentEntity = nil\n\n        local mapEntity = self.Entity.CurrentMap\n        if mapEntity == nil or isvalid(mapEntity) == false then\n            return\n        end\n\n        local container = nil\n        local findOk, findResult = pcall(function()\n            return mapEntity:GetChildByName(self.MonsterContainerName, true)\n        end)\n        if findOk == true then\n            container = findResult\n        end\n\n        if container ~= nil and isvalid(container) == true then\n            self.MonsterParentEntity = container\n            self._T.WarnedMissingContainer = false\n            if self.EnableDebugLogs == true then\n                log(\"[MonsterSpawnComponent][DEBUG] MonsterContainer resolved. name=\", self.MonsterContainerName)\n            end\n            return\n        end\n\n        if self._T.WarnedMissingContainer ~= true then\n            log_warning(\"[MonsterSpawnComponent] MonsterContainer is missing. Spawning remains disabled until container is placed.\")\n            self._T.WarnedMissingContainer = true\n        end\n    end\n\n    -- Monitor timer reacts to spawn gate state without per-frame OnUpdate overhead.\n    @ExecSpace(\"ServerOnly\")\n    method void StartStateMonitorTimer()\n        if self._T.StateMonitorTimerId ~= nil and self._T.StateMonitorTimerId > 0 then\n            return\n        end\n\n        local interval = self.StateMonitorInterval\n        if interval <= 0 then\n            interval = 0.2\n        end\n\n        local callback = function()\n            self:RefreshSpawnStateServer()\n            self:UpdateMonsterHPBarsServer()\n            self:ProcessMonsterDeathSequenceServer()\n        end\n        self._T.StateMonitorTimerId = _TimerService:SetTimerRepeat(callback, interval, 0)\n        if self.EnableDebugLogs == true then\n            log(\"[MonsterSpawnComponent][DEBUG] State monitor timer started. id=\", self._T.StateMonitorTimerId, \", interval=\", interval)\n        end\n    end\n\n    -- Single state gate keeps start/stop transitions deterministic and easy to extend later.\n    @ExecSpace(\"ServerOnly\")\n    method void RefreshSpawnStateServer()\n        if self:CanSpawnNowServer() == true then\n            self:StartSpawning()\n            return\n        end\n\n        self:StopSpawning()\n    end\n\n    -- Spawn readiness checks are centralized so future unknown rules can be appended safely.\n    @ExecSpace(\"ServerOnly\")\n    method boolean CanSpawnNowServer()\n        if self._T.DataReady ~= true then\n            self:TraceSpawnGateServer(false, \"DataNotReady\")\n            return false\n        end\n        if self.IsBossPhase == true then\n            self:TraceSpawnGateServer(false, \"BossPhaseActive\")\n            return false\n        end\n        if self.MonsterParentEntity == nil or isvalid(self.MonsterParentEntity) == false then\n            self:TraceSpawnGateServer(false, \"MonsterContainerMissing\")\n            return false\n        end\n        if self:IsSafeZoneActiveServer() == true then\n            self:TraceSpawnGateServer(false, \"LobbySafeZoneActive\")\n            return false\n        end\n        local timerComponent = self:ResolveComponentSafe(self.Entity, \"GameTimerComponent\", \"IsPaused\")\n        if timerComponent ~= nil then\n            local pauseOk, isPaused = pcall(function()\n                return timerComponent.IsPaused\n            end)\n            if pauseOk == true and isPaused == true then\n                self:TraceSpawnGateServer(false, \"GameTimerPaused\")\n                return false\n            end\n        end\n\n        self:TraceSpawnGateServer(true, \"Ready\")\n        return true\n    end\n\n    -- Safe-zone resolver now follows lobby state only; shop open no longer blocks monster spawning.\n    @ExecSpace(\"ServerOnly\")\n    method boolean IsSafeZoneActiveServer()\n        local lobbyFlow = self:ResolveComponentSafe(self.Entity, \"LobbyFlowComponent\", \"IsLobbyActive\")\n        if lobbyFlow ~= nil then\n            local lobbyOk, isLobby = pcall(function()\n                return lobbyFlow.IsLobbyActive\n            end)\n            if lobbyOk == true and isLobby == true then\n                return true\n            end\n        end\n\n        return false\n    end\n\n    -- Shop-open state is debug-only context and does not affect spawn gate decisions.\n    @ExecSpace(\"ServerOnly\")\n    method boolean IsShopOpenServer()\n        local shopManager = self:ResolveComponentSafe(self.Entity, \"ShopManagerComponent\", \"IsShopOpen\")\n        if shopManager ~= nil then\n            local shopOk, isShopOpen = pcall(function()\n                return shopManager.IsShopOpen\n            end)\n            if shopOk == true and isShopOpen == true then\n                return true\n            end\n        end\n\n        return false\n    end\n\n    -- Start path is isolated so timer recreation and sync flag update always happen together.\n    @ExecSpace(\"ServerOnly\")\n    method void StartSpawning()\n        if self._T.SpawnTimerId ~= nil and self._T.SpawnTimerId > 0 then\n            return\n        end\n        if self._T.Config == nil then\n            if self.EnableDebugLogs == true then\n                log_warning(\"[MonsterSpawnComponent][DEBUG] StartSpawning blocked: config missing.\")\n            end\n            return\n        end\n\n        local interval = self._T.Config.SpawnInterval\n        if interval <= 0 then\n            if self.EnableDebugLogs == true then\n                log_warning(\"[MonsterSpawnComponent][DEBUG] StartSpawning blocked: invalid interval=\", interval)\n            end\n            return\n        end\n\n        local callback = function()\n            self:SpawnTick()\n        end\n        local timerId = _TimerService:SetTimerRepeat(callback, interval, 0)\n        if timerId == nil or timerId <= 0 then\n            if self.EnableDebugLogs == true then\n                log_warning(\"[MonsterSpawnComponent][DEBUG] StartSpawning failed: invalid timer id.\")\n            end\n            return\n        end\n\n        self._T.SpawnTimerId = timerId\n        self.IsSpawnActive = true\n        if self.EnableDebugLogs == true then\n            log(\"[MonsterSpawnComponent][DEBUG] Spawn timer started. id=\", timerId, \", interval=\", interval)\n        end\n    end\n\n    -- Stop path clears only one timer id so duplicated ClearTimer calls are avoided.\n    @ExecSpace(\"ServerOnly\")\n    method void StopSpawning()\n        if self._T.SpawnTimerId ~= nil and self._T.SpawnTimerId > 0 then\n            if self.EnableDebugLogs == true then\n                log(\"[MonsterSpawnComponent][DEBUG] Spawn timer stopped. id=\", self._T.SpawnTimerId)\n            end\n            _TimerService:ClearTimer(self._T.SpawnTimerId)\n            self._T.SpawnTimerId = 0\n        end\n        self.IsSpawnActive = false\n    end\n\n    -- Spawn tick executes only lightweight loops and defers unknown features to dedicated extension hooks.\n    @ExecSpace(\"ServerOnly\")\n    method void SpawnTick()\n        if self:CanSpawnNowServer() == false then\n            return\n        end\n\n        self._T.SpawnTickCounter = self._T.SpawnTickCounter + 1\n        self:PruneSpawnedMonsters()\n\n        local config = self._T.Config\n        if config == nil then\n            return\n        end\n        local context = self:ResolveCurrentSpawnContext()\n        self._T.CurrentSpawnElapsedSec = context.ElapsedSec\n        local candidates = self:ResolveSpawnCandidates(context.Stage, context.ElapsedSec)\n        if self.EnableDebugLogs == true then\n            log(\"[MonsterSpawnComponent][DEBUG] SpawnTick start. tick=\", self._T.SpawnTickCounter, \", stage=\", context.Stage, \", elapsed=\", context.ElapsedSec, \", normal=\", #candidates.NormalRows, \", boss=\", #candidates.BossRows, \", alive=\", self:GetSpawnedMonsterCount())\n        end\n\n        local bossRows = candidates.BossRows\n        if bossRows ~= nil and #bossRows > 0 then\n            local bossRow = self:SelectLatestRowBySpawnTime(bossRows)\n            local bossEntity = self:SpawnMonsterByRow(bossRow, Vector3(0, 0, 0), true)\n            if bossEntity ~= nil and isvalid(bossEntity) == true then\n                self.IsBossPhase = true\n                self:StopSpawning()\n                if self.EnableDebugLogs == true then\n                    local bossId = self:GetRowString(bossRow, \"id\", \"(unknown)\")\n                    log(\"[MonsterSpawnComponent][DEBUG] Boss spawned. id=\", bossId, \", bossPhase=\", self.IsBossPhase)\n                end\n            elseif self.EnableDebugLogs == true then\n                local bossId = self:GetRowString(bossRow, \"id\", \"(unknown)\")\n                log_warning(\"[MonsterSpawnComponent][DEBUG] Boss candidate failed to spawn. id=\", bossId)\n            end\n            return\n        end\n\n        local normalRows = candidates.NormalRows\n        if normalRows == nil or #normalRows <= 0 then\n            if self.EnableDebugLogs == true then\n                log(\"[MonsterSpawnComponent][DEBUG] SpawnTick skipped: no normal candidates.\")\n            end\n            return\n        end\n\n        local attemptedCount = 0\n        local spawnedCount = 0\n        local invalidPositionCount = 0\n\n        for i = 1, config.SpawnPerTick do\n            self:PruneSpawnedMonsters()\n\n            local selectedRow = self:PickRandomRow(normalRows)\n            if selectedRow == nil then\n                break\n            end\n            attemptedCount = attemptedCount + 1\n\n            -- Spawn config no longer retries; penalty system now owns overflow control.\n            local spawnPosition = self:CalcDonutPosition()\n            if spawnPosition ~= nil and self:IsValidSpawnPosition(spawnPosition) == true then\n                local spawned = self:SpawnMonsterByRow(selectedRow, spawnPosition, false)\n                if spawned ~= nil and isvalid(spawned) == true then\n                    spawnedCount = spawnedCount + 1\n                end\n            else\n                invalidPositionCount = invalidPositionCount + 1\n            end\n        end\n\n        if self.EnableDebugLogs == true then\n            log(\"[MonsterSpawnComponent][DEBUG] SpawnTick end. attempted=\", attemptedCount, \", spawned=\", spawnedCount, \", invalidPos=\", invalidPositionCount, \", alive=\", self:GetSpawnedMonsterCount())\n        end\n    end\n\n    -- Stage/time context is read from GameTimer or InfiniteMode elapsed timer, both server-authoritative.\n    @ExecSpace(\"ServerOnly\")\n    method table ResolveCurrentSpawnContext()\n        local context = {}\n        context.Stage = 1\n        context.ElapsedSec = 0\n\n        local infiniteMode = self:ResolveComponentSafe(self.Entity, \"InfiniteModeComponent\", \"IsInfiniteActive\")\n        if infiniteMode ~= nil then\n            local activeOk, isInfinite = pcall(function()\n                return infiniteMode.IsInfiniteActive\n            end)\n            if activeOk == true and isInfinite == true then\n                local elapsedOk, elapsedValue = pcall(function()\n                    if infiniteMode.GetInfiniteElapsedSecondsServer ~= nil then\n                        return infiniteMode:GetInfiniteElapsedSecondsServer()\n                    end\n                    return 0\n                end)\n                if elapsedOk == true and elapsedValue ~= nil then\n                    context.ElapsedSec = math.max(0, elapsedValue)\n                end\n                context.Stage = 1\n                return context\n            end\n        end\n\n        local timerComponent = self:ResolveComponentSafe(self.Entity, \"GameTimerComponent\", \"ElapsedTime\")\n        if timerComponent == nil then\n            return context\n        end\n\n        local stageOk, stageValue = pcall(function()\n            return timerComponent.CurrentStageId\n        end)\n        if stageOk == true and stageValue ~= nil then\n            context.Stage = math.max(1, math.floor(stageValue))\n        end\n\n        local elapsedOk, elapsedValue = pcall(function()\n            return timerComponent.ElapsedTime\n        end)\n        if elapsedOk == true and elapsedValue ~= nil then\n            context.ElapsedSec = math.max(0, elapsedValue)\n        end\n\n        return context\n    end\n\n    -- Resolver keeps selection logic in one function so unknown future conditions can be patched quickly.\n    @ExecSpace(\"ServerOnly\")\n    method table ResolveSpawnCandidates(integer stage, number elapsedSec)\n        local result = {}\n        result.NormalRows = {}\n        result.BossRows = {}\n        local enforceStage = (self._T.UseModeMonsterData ~= true)\n\n        local rows = self._T.MonsterRows\n        if rows == nil then\n            return result\n        end\n\n        for _, row in pairs(rows) do\n            if row == nil then\n                continue\n            end\n\n            if enforceStage == true then\n                local rowStage = self:GetRowInteger(row, \"spawn_stage\", 1)\n                if rowStage ~= stage then\n                    continue\n                end\n            end\n\n            local spawnMinute = self:GetSpawnMinuteFromRow(row)\n            if spawnMinute < 0 then\n                continue\n            end\n            if elapsedSec < (spawnMinute * 60) then\n                continue\n            end\n\n            if self:IsBossRow(row) == true then\n                table.insert(result.BossRows, row)\n            else\n                table.insert(result.NormalRows, row)\n            end\n        end\n\n        return result\n    end\n\n    method number GetSpawnMinuteFromRow(UserDataRow row)\n        return self:GetRowNumber(row, \"spawn_time\", -1)\n    end\n\n    method boolean IsBossRow(UserDataRow row)\n        local monType = string.lower(self:GetRowString(row, \"mon_type\", \"\"))\n        return monType == \"boss\"\n    end\n\n    method UserDataRow SelectLatestRowBySpawnTime(table rows)\n        if rows == nil or #rows <= 0 then\n            return nil\n        end\n\n        local selectedRow = rows[1]\n        local latestMinute = self:GetSpawnMinuteFromRow(selectedRow)\n\n        for _, row in pairs(rows) do\n            local rowMinute = self:GetSpawnMinuteFromRow(row)\n            if rowMinute > latestMinute then\n                latestMinute = rowMinute\n                selectedRow = row\n            end\n        end\n\n        return selectedRow\n    end\n\n    method UserDataRow PickRandomRow(table rows)\n        if rows == nil or #rows <= 0 then\n            return nil\n        end\n\n        local randomIndex = math.random(1, #rows)\n        return rows[randomIndex]\n    end\n\n    -- Donut position keeps spawn out of immediate player view while staying near combat area.\n    @ExecSpace(\"ServerOnly\")\n    method Vector3 CalcDonutPosition()\n        local config = self._T.Config\n        if config == nil then\n            return nil\n        end\n\n        local transform = self.Entity.TransformComponent\n        if transform == nil or isvalid(transform) == false then\n            return nil\n        end\n\n        local playerPosition = transform.WorldPosition\n        if playerPosition == nil then\n            return nil\n        end\n\n        local innerRadius = config.InnerRadius\n        local outerRadius = config.OuterRadius\n        if outerRadius < innerRadius then\n            local temp = innerRadius\n            innerRadius = outerRadius\n            outerRadius = temp\n        end\n\n        local randomAngle = math.random() * 2 * math.pi\n        local randomRadius = innerRadius + (math.random() * (outerRadius - innerRadius))\n\n        local x = playerPosition.x + (randomRadius * math.cos(randomAngle))\n        local y = playerPosition.y + (randomRadius * math.sin(randomAngle))\n        return Vector3(x, y, playerPosition.z)\n    end\n\n    -- Validity check intentionally stays basic per SPEC v1.1 (no NavMesh dependency yet).\n    @ExecSpace(\"ServerOnly\")\n    method boolean IsValidSpawnPosition(Vector3 targetPosition)\n        if targetPosition == nil then\n            return false\n        end\n\n        local config = self._T.Config\n        if config == nil then\n            return false\n        end\n\n        local transform = self.Entity.TransformComponent\n        if transform == nil or isvalid(transform) == false then\n            return false\n        end\n\n        local playerPosition = transform.WorldPosition\n        if playerPosition == nil then\n            return false\n        end\n\n        local dx = targetPosition.x - playerPosition.x\n        local dy = targetPosition.y - playerPosition.y\n        local distanceSqr = (dx * dx) + (dy * dy)\n        local innerSqr = config.InnerRadius * config.InnerRadius\n        local outerSqr = config.OuterRadius * config.OuterRadius\n\n        if distanceSqr < innerSqr then\n            return false\n        end\n        if distanceSqr > outerSqr then\n            return false\n        end\n\n        return true\n    end\n\n    -- Spawn path attaches metadata immediately so future drop/reward systems can read one source.\n    @ExecSpace(\"ServerOnly\")\n    method Entity SpawnMonsterByRow(UserDataRow row, Vector3 spawnPosition, boolean isBoss)\n        if row == nil then\n            return nil\n        end\n        if spawnPosition == nil then\n            return nil\n        end\n        if self.MonsterParentEntity == nil or isvalid(self.MonsterParentEntity) == false then\n            return nil\n        end\n\n        local modelId = self:GetRowString(row, \"model_type\", \"\")\n        if modelId == \"\" then\n            modelId = self:GetFallbackModelType(row)\n        end\n        if modelId == \"\" then\n            local rowId = self:GetRowString(row, \"id\", \"(unknown)\")\n            log_warning(\"[MonsterSpawnComponent] Skip spawn because model_type is empty. rowId=\", rowId)\n            return nil\n        end\n        modelId = self:ResolveModelIdForSpawn(modelId)\n        if modelId == \"\" then\n            local rowId = self:GetRowString(row, \"id\", \"(unknown)\")\n            log_warning(\"[MonsterSpawnComponent] Skip spawn because model id resolution failed. rowId=\", rowId)\n            return nil\n        end\n\n        local spawnName = self:GetRowString(row, \"id\", \"Monster\")\n        local spawnedEntity = nil\n        local spawnOk, spawnResult = pcall(function()\n            return _SpawnService:SpawnByModelId(modelId, spawnName, spawnPosition, self.MonsterParentEntity)\n        end)\n        if spawnOk == true then\n            spawnedEntity = spawnResult\n        end\n        if spawnedEntity == nil or isvalid(spawnedEntity) == false then\n            return nil\n        end\n\n        -- Spawned enemies must be marked at source so combat systems can split monster/player hit rules.\n        local hpSystem = self:ResolveComponentSafe(spawnedEntity, \"HPSystemComponent\", \"CurrentHP\")\n        if hpSystem ~= nil then\n            pcall(function()\n                hpSystem.IsMonster = true\n            end)\n        end\n\n        self:DisablePhysicsColliderIfMapHasNoSimulator(spawnedEntity)\n        self:EnsureMonsterTriggerComponent(spawnedEntity)\n\n        if self._T.SpawnedMonsters == nil then\n            self._T.SpawnedMonsters = {}\n        end\n        table.insert(self._T.SpawnedMonsters, spawnedEntity)\n\n        if self._T.SpawnMetaByEntity == nil then\n            self._T.SpawnMetaByEntity = {}\n        end\n        self._T.SpawnMetaByEntity[spawnedEntity] = self:BuildSpawnMetaFromRow(row)\n\n        self:AttachMonsterChaseIfNeeded(spawnedEntity)\n        self:ApplyMonsterVisualIfAvailable(spawnedEntity, row)\n        self:ApplyMonsterColliderIfAvailable(spawnedEntity, row)\n        self:ApplyMonsterStatsIfAvailable(spawnedEntity, row)\n        self:EnsureMonsterHPBarServer(spawnedEntity)\n        self:UpdateMonsterHPBarByEntityServer(spawnedEntity)\n\n        if isBoss == true then\n            self._T.BossSpawnedEntity = spawnedEntity\n        end\n\n        return spawnedEntity\n    end\n\n    -- Metadata builder stores drop_id for future drop pipeline; detailed drop execution remains deferred.\n    method table BuildSpawnMetaFromRow(UserDataRow row)\n        local meta = {}\n        meta.Id = self:GetRowString(row, \"id\", \"\")\n        meta.Name = self:GetRowString(row, \"name\", \"\")\n        meta.MonType = self:GetRowString(row, \"mon_type\", \"\")\n        meta.ModelType = self:GetRowString(row, \"model_type\", \"\")\n        meta.MonHP = self:GetRowInteger(row, \"mon_hp\", 0)\n        meta.MonAtk = self:GetRowInteger(row, \"mon_atk\", 0)\n        meta.MonSpd = self:GetRowNumber(row, \"mon_spd\", 0)\n        meta.SpawnStage = self:GetRowInteger(row, \"spawn_stage\", 1)\n        meta.SpawnTimeMin = self:GetSpawnMinuteFromRow(row)\n        meta.CreepScore = math.max(0, self:GetRowInteger(row, \"creep_score\", 0))\n        meta.Gold = 0\n\n        meta.DropId = self:GetRowString(row, \"drop_id\", \"\")\n        meta.DropItem1Id = \"\"\n        meta.DropItem1Rate = 0\n        meta.DropItem1Amount = 0\n        meta.DropItem2Id = \"\"\n        meta.DropItem2Rate = 0\n        meta.DropItem2Amount = 0\n\n        meta.SpriteRuid = self:GetRowString(row, \"sprite_ruid\", \"\")\n        meta.SoundRuid = self:GetRowString(row, \"sound_ruid\", \"\")\n        meta.DeathEffectRuid = self:GetRowString(row, \"death_effect_ruid\", \"\")\n        if self:HasOptionalMonsterColumn(\"collider_w\") == true then\n            meta.ColliderW = self:GetRowNumber(row, \"collider_w\", -1)\n        else\n            meta.ColliderW = -1\n        end\n        if self:HasOptionalMonsterColumn(\"collider_h\") == true then\n            meta.ColliderH = self:GetRowNumber(row, \"collider_h\", -1)\n        else\n            meta.ColliderH = -1\n        end\n        if self:HasOptionalMonsterColumn(\"collider_offset_x\") == true then\n            meta.ColliderOffsetX = self:GetRowNumber(row, \"collider_offset_x\", 0)\n        else\n            meta.ColliderOffsetX = 0\n        end\n        if self:HasOptionalMonsterColumn(\"collider_offset_y\") == true then\n            meta.ColliderOffsetY = self:GetRowNumber(row, \"collider_offset_y\", 0)\n        else\n            meta.ColliderOffsetY = 0\n        end\n        meta.IsBoss = self:IsBossRow(row)\n\n        return meta\n    end\n\n    -- TODO: Replace this adapter with visual profile resolver when sprite/anim policy is finalized.\n    method void ApplyMonsterVisualIfAvailable(Entity targetEntity, UserDataRow row)\n        if targetEntity == nil or isvalid(targetEntity) == false then\n            return\n        end\n        if row == nil then\n            return\n        end\n\n        local spriteRuid = self:GetRowString(row, \"sprite_ruid\", \"\")\n        if spriteRuid == \"\" then\n            return\n        end\n\n        local spriteRenderer = self:ResolveComponentSafe(targetEntity, \"SpriteRendererComponent\", \"SpriteRUID\")\n        if spriteRenderer == nil then\n            return\n        end\n\n        local applyOk, _ = pcall(function()\n            spriteRenderer.SpriteRUID = spriteRuid\n        end)\n        if applyOk == false then\n            local rowId = self:GetRowString(row, \"id\", \"(unknown)\")\n            log_warning(\"[MonsterSpawnComponent] Failed to apply sprite_ruid. rowId=\", rowId, \", sprite_ruid=\", spriteRuid)\n        end\n    end\n\n    -- Runtime sprite swaps do not auto-fit colliders, so collider bounds are explicitly data-driven.\n    method void ApplyMonsterColliderIfAvailable(Entity targetEntity, UserDataRow row)\n        if targetEntity == nil or isvalid(targetEntity) == false then\n            return\n        end\n        if row == nil then\n            return\n        end\n\n        if self:HasOptionalMonsterColumn(\"collider_w\") == false or self:HasOptionalMonsterColumn(\"collider_h\") == false then\n            return\n        end\n\n        local colliderW = self:GetRowNumber(row, \"collider_w\", -1)\n        local colliderH = self:GetRowNumber(row, \"collider_h\", -1)\n        if colliderW <= 0 or colliderH <= 0 then\n            return\n        end\n\n        local colliderSize = Vector2(colliderW, colliderH)\n        local offsetXText = \"\"\n        local offsetYText = \"\"\n        if self:HasOptionalMonsterColumn(\"collider_offset_x\") == true then\n            offsetXText = self:GetRowString(row, \"collider_offset_x\", \"\")\n        end\n        if self:HasOptionalMonsterColumn(\"collider_offset_y\") == true then\n            offsetYText = self:GetRowString(row, \"collider_offset_y\", \"\")\n        end\n        local hasOffset = false\n        local colliderOffset = Vector2.zero\n        if offsetXText ~= \"\" and offsetYText ~= \"\" then\n            local offsetX = tonumber(offsetXText)\n            local offsetY = tonumber(offsetYText)\n            if offsetX ~= nil and offsetY ~= nil then\n                hasOffset = true\n                colliderOffset = Vector2(offsetX, offsetY)\n            end\n        end\n\n        local appliedAny = false\n        local trigger = self:ResolveComponentSafe(targetEntity, \"TriggerComponent\", \"BoxSize\")\n        if trigger ~= nil then\n            local sizeOk, _ = pcall(function()\n                trigger.BoxSize = colliderSize\n            end)\n            if sizeOk == true then\n                appliedAny = true\n            end\n            if hasOffset == true then\n                pcall(function()\n                    trigger.ColliderOffset = colliderOffset\n                end)\n                pcall(function()\n                    trigger.BoxOffset = colliderOffset\n                end)\n            end\n        end\n\n        local hit = self:ResolveComponentSafe(targetEntity, \"HitComponent\", \"BoxSize\")\n        if hit ~= nil then\n            local sizeOk, _ = pcall(function()\n                hit.BoxSize = colliderSize\n            end)\n            if sizeOk == true then\n                appliedAny = true\n            end\n            if hasOffset == true then\n                pcall(function()\n                    hit.ColliderOffset = colliderOffset\n                end)\n                pcall(function()\n                    hit.BoxOffset = colliderOffset\n                end)\n            end\n        end\n\n        if self:HasPhysicsSimulatorInCurrentMap() == true then\n            local physicsCollider = self:ResolveComponentSafe(targetEntity, \"PhysicsColliderComponent\", \"BoxSize\")\n            if physicsCollider ~= nil then\n                local sizeOk, _ = pcall(function()\n                    physicsCollider.BoxSize = colliderSize\n                end)\n                if sizeOk == true then\n                    appliedAny = true\n                end\n                if hasOffset == true then\n                    pcall(function()\n                        physicsCollider.ColliderOffset = colliderOffset\n                    end)\n                    pcall(function()\n                        physicsCollider.BoxOffset = colliderOffset\n                    end)\n                end\n            end\n        end\n\n        if appliedAny == false then\n            if self:HasPhysicsSimulatorInCurrentMap() == false then\n                return\n            end\n            local rowId = self:GetRowString(row, \"id\", \"(unknown)\")\n            log_warning(\"[MonsterSpawnComponent] collider_w/h provided but no collider component found. rowId=\", rowId)\n        end\n    end\n\n    -- PhysicsSimulator is map-level dependency; when missing, disable model physics collider to avoid runtime spam.\n    method void DisablePhysicsColliderIfMapHasNoSimulator(Entity targetEntity)\n        if targetEntity == nil or isvalid(targetEntity) == false then\n            return\n        end\n        if self:HasPhysicsSimulatorInCurrentMap() == true then\n            return\n        end\n\n        local physicsCollider = self:ResolveComponentSafe(targetEntity, \"PhysicsColliderComponent\", \"Enable\")\n        if physicsCollider == nil then\n            return\n        end\n\n        pcall(function()\n            physicsCollider.Enable = false\n        end)\n    end\n\n    -- Contact combat requires trigger overlap events, so spawn path ensures TriggerComponent is always present.\n    method void EnsureMonsterTriggerComponent(Entity targetEntity)\n        if targetEntity == nil or isvalid(targetEntity) == false then\n            return\n        end\n\n        local trigger = self:ResolveComponentSafe(targetEntity, \"TriggerComponent\", \"BoxSize\")\n        if trigger == nil then\n            local addOkA, addResultA = pcall(function()\n                return targetEntity:AddComponent(\"MOD.Core.TriggerComponent\")\n            end)\n            if addOkA == true then\n                trigger = addResultA\n            end\n        end\n        if trigger == nil then\n            local addOkB, addResultB = pcall(function()\n                return targetEntity:AddComponent(\"TriggerComponent\")\n            end)\n            if addOkB == true then\n                trigger = addResultB\n            end\n        end\n        if trigger == nil then\n            return\n        end\n\n        pcall(function()\n            trigger.IsPassive = false\n        end)\n\n        local physicsCollider = self:ResolveComponentSafe(targetEntity, \"PhysicsColliderComponent\", \"BoxSize\")\n        if physicsCollider == nil then\n            return\n        end\n\n        local sizeOk, boxSize = pcall(function()\n            return physicsCollider.BoxSize\n        end)\n        if sizeOk == true and boxSize ~= nil then\n            pcall(function()\n                trigger.BoxSize = boxSize\n            end)\n        end\n\n        local offsetOk, colliderOffset = pcall(function()\n            return physicsCollider.ColliderOffset\n        end)\n        if offsetOk == true and colliderOffset ~= nil then\n            pcall(function()\n                trigger.ColliderOffset = colliderOffset\n            end)\n            pcall(function()\n                trigger.BoxOffset = colliderOffset\n            end)\n        end\n    end\n\n    method boolean HasPhysicsSimulatorInCurrentMap()\n        if self._T.HasMapPhysicsSimulator ~= nil then\n            return self._T.HasMapPhysicsSimulator\n        end\n\n        local mapEntity = nil\n        if self.Entity ~= nil and isvalid(self.Entity) == true then\n            mapEntity = self.Entity.CurrentMap\n        end\n        if mapEntity == nil or isvalid(mapEntity) == false then\n            self._T.HasMapPhysicsSimulator = false\n            return false\n        end\n\n        local simulator = nil\n        local readOkA, readResultA = pcall(function()\n            return mapEntity:GetComponent(\"MOD.Core.PhysicsSimulatorComponent\")\n        end)\n        if readOkA == true then\n            simulator = readResultA\n        end\n        if simulator == nil then\n            local readOkB, readResultB = pcall(function()\n                return mapEntity:GetComponent(\"PhysicsSimulatorComponent\")\n            end)\n            if readOkB == true then\n                simulator = readResultB\n            end\n        end\n\n        local hasSimulator = (simulator ~= nil and isvalid(simulator) == true)\n        self._T.HasMapPhysicsSimulator = hasSimulator\n\n        if hasSimulator == false and self._T.WarnedMissingPhysicsSimulator ~= true then\n            log_warning(\"[MonsterSpawnComponent] PhysicsSimulatorComponent missing on current map. physics collider will be disabled on spawned monsters.\")\n            self._T.WarnedMissingPhysicsSimulator = true\n        end\n        return hasSimulator\n    end\n\n    -- TODO: Replace this adapter with dedicated monster stat component integration when spec arrives.\n    method void ApplyMonsterStatsIfAvailable(Entity targetEntity, UserDataRow row)\n        if targetEntity == nil or isvalid(targetEntity) == false then\n            return\n        end\n        if row == nil then\n            return\n        end\n\n        local scaled = self:ResolveMonsterStatValues(row, self._T.CurrentSpawnElapsedSec)\n        local monHp = scaled.MonHP\n        local monAtk = scaled.MonAtk\n        local monSpd = scaled.MonSpd\n\n        if monHp >= 0 then\n            local hpSystem = self:ResolveComponentSafe(targetEntity, \"HPSystemComponent\", \"CurrentHP\")\n            if hpSystem ~= nil then\n                pcall(function()\n                    hpSystem.MaxHP = monHp\n                end)\n                pcall(function()\n                    hpSystem.CurrentHP = monHp\n                end)\n            end\n        end\n\n        if monAtk >= 0 then\n            local monsterAttack = self:ResolveComponentSafe(targetEntity, \"MonsterAttackComponent\", \"AttackPower\")\n            if monsterAttack ~= nil then\n                pcall(function()\n                    monsterAttack.AttackPower = monAtk\n                end)\n            end\n        end\n\n        local chase = self:ResolveComponentSafe(targetEntity, \"MonsterChaseComponent\", \"ThinkInterval\")\n        if chase ~= nil then\n            if monAtk >= 0 then\n                pcall(function()\n                    chase.ContactDamage = math.max(monAtk, 0)\n                end)\n            end\n        end\n\n        local movement = self:ResolveComponentSafe(targetEntity, \"MovementComponent\", \"MoveSpeed\")\n        if movement ~= nil then\n            pcall(function()\n                movement.UsePlayerInput = false\n            end)\n\n            if monSpd >= 0 then\n                pcall(function()\n                    movement.MoveSpeed = monSpd\n                end)\n            end\n        end\n    end\n\n    -- Mode rows support per-minute stat growth; normal rows use fixed mon_hp/mon_atk/mon_spd values.\n    method table ResolveMonsterStatValues(UserDataRow row, number elapsedSec)\n        local stats = {}\n        stats.MonHP = self:GetRowInteger(row, \"mon_hp\", -1)\n        stats.MonAtk = self:GetRowInteger(row, \"mon_atk\", -1)\n        stats.MonSpd = self:GetRowNumber(row, \"mon_spd\", -1)\n\n        if self:IsModeMonsterRow(row) ~= true then\n            return stats\n        end\n\n        local minute = math.max(0, elapsedSec) / 60\n\n        local baseHp = self:GetRowNumber(row, \"mode_mon_hp\", -1)\n        if baseHp >= 0 then\n            local hpUp = self:GetRowNumber(row, \"mode_mon_hp_up\", 0)\n            stats.MonHP = math.max(0, math.floor(baseHp + (hpUp * minute)))\n        end\n\n        local baseAtk = self:GetRowNumber(row, \"mon_atk\", -1)\n        if baseAtk >= 0 then\n            local atkUp = self:GetRowNumber(row, \"mode_mon_atk_up\", 0)\n            stats.MonAtk = math.max(0, math.floor(baseAtk + (atkUp * minute)))\n        end\n\n        local baseSpd = self:GetRowNumber(row, \"mon_spd\", -1)\n        if baseSpd >= 0 then\n            local spdUp = self:GetRowNumber(row, \"mon_spd_up\", -1)\n            if spdUp < 0 then\n                spdUp = self:GetRowNumber(row, \"mode_mon_spd_up\", 0)\n            end\n            stats.MonSpd = math.max(0, baseSpd + (spdUp * minute))\n        end\n\n        return stats\n    end\n\n    method boolean IsModeMonsterRow(UserDataRow row)\n        local monType = string.lower(self:GetRowString(row, \"mon_type\", \"\"))\n        return string.sub(monType, 1, 5) == \"mode_\"\n    end\n\n    -- Every spawned monster gets chase AI once so nearest-player pursuit works without model-side manual setup.\n    method void AttachMonsterChaseIfNeeded(Entity targetEntity)\n        if targetEntity == nil or isvalid(targetEntity) == false then\n            return\n        end\n\n        local existing = self:ResolveComponentSafe(targetEntity, \"MonsterChaseComponent\", \"ThinkInterval\")\n        if existing ~= nil then\n            return\n        end\n\n        local addOkA, addResultA = pcall(function()\n            return targetEntity:AddComponent(\"script.MonsterChaseComponent\")\n        end)\n        if addOkA == true and addResultA ~= nil then\n            return\n        end\n\n        pcall(function()\n            targetEntity:AddComponent(\"MonsterChaseComponent\")\n        end)\n    end\n\n    -- Delayed pass binds map-placed monsters after table load and entity bootstrap are complete.\n    @ExecSpace(\"ServerOnly\")\n    method void SchedulePlacedMonsterBindingServer()\n        if self.AutoBindPlacedMonsterEntities ~= true then\n            return\n        end\n\n        if self._T.PlacedMonsterBindTimerId ~= nil and self._T.PlacedMonsterBindTimerId > 0 then\n            _TimerService:ClearTimer(self._T.PlacedMonsterBindTimerId)\n            self._T.PlacedMonsterBindTimerId = 0\n        end\n\n        local delay = self.PlacedMonsterBindDelay\n        if delay < 0 then\n            delay = 0\n        end\n\n        local bindFn = function()\n            self._T.PlacedMonsterBindTimerId = 0\n            self:AutoBindPlacedMonstersServer()\n        end\n        self._T.PlacedMonsterBindTimerId = _TimerService:SetTimerOnce(bindFn, delay)\n    end\n\n    -- Static monsters are scanned once and receive the same table-driven stat/collider pipeline as spawned monsters.\n    @ExecSpace(\"ServerOnly\")\n    method integer AutoBindPlacedMonstersServer()\n        if self.AutoBindPlacedMonsterEntities ~= true then\n            return 0\n        end\n\n        if self._T.DataReady ~= true then\n            self:LoadSpawnDataFromTable()\n        end\n        if self._T.MonsterRows == nil or #self._T.MonsterRows <= 0 then\n            return 0\n        end\n\n        local mapEntity = self.Entity.CurrentMap\n        if mapEntity == nil or isvalid(mapEntity) == false then\n            return 0\n        end\n\n        local bindCount = self:BindPlacedMonstersRecursiveServer(mapEntity)\n        if self.EnableDebugLogs == true and bindCount > 0 then\n            log(\"[MonsterSpawnComponent][DEBUG] placed monster auto-bind count=\", bindCount)\n        end\n        return bindCount\n    end\n\n    @ExecSpace(\"ServerOnly\")\n    method integer BindPlacedMonstersRecursiveServer(Entity node)\n        if node == nil or isvalid(node) == false then\n            return 0\n        end\n\n        local bindCount = self:TryBindPlacedMonsterEntityServer(node)\n        local children = node.Children\n        if children == nil then\n            return bindCount\n        end\n\n        for _, child in pairs(children) do\n            if child ~= nil and isvalid(child) == true then\n                bindCount += self:BindPlacedMonstersRecursiveServer(child)\n            end\n        end\n\n        return bindCount\n    end\n\n    -- Candidate selection excludes player/spawned entries and targets explicit or signature-based monster entities only.\n    @ExecSpace(\"ServerOnly\")\n    method integer TryBindPlacedMonsterEntityServer(Entity targetEntity)\n        if targetEntity == nil or isvalid(targetEntity) == false then\n            return 0\n        end\n        if targetEntity == self.Entity then\n            return 0\n        end\n\n        if self._T.AutoBoundPlacedMonsters == nil then\n            self._T.AutoBoundPlacedMonsters = {}\n        end\n        if self._T.AutoBoundPlacedMonsters[targetEntity] == true then\n            return 0\n        end\n\n        if self._T.SpawnMetaByEntity ~= nil and self._T.SpawnMetaByEntity[targetEntity] ~= nil then\n            self._T.AutoBoundPlacedMonsters[targetEntity] = true\n            return 0\n        end\n        if targetEntity.PlayerComponent ~= nil then\n            return 0\n        end\n\n        local hpSystem = self:ResolveComponentSafe(targetEntity, \"HPSystemComponent\", \"CurrentHP\")\n        if hpSystem == nil then\n            return 0\n        end\n\n        local isMonster = false\n        local readMonsterOk, readMonsterValue = pcall(function()\n            return hpSystem.IsMonster\n        end)\n        if readMonsterOk == true and readMonsterValue == true then\n            isMonster = true\n        end\n\n        local chase = self:ResolveComponentSafe(targetEntity, \"MonsterChaseComponent\", \"ThinkInterval\")\n        if isMonster ~= true and chase == nil then\n            return 0\n        end\n\n        local row = self:ResolvePlacedMonsterRowServer(targetEntity, hpSystem)\n        if row == nil then\n            return 0\n        end\n\n        self:AttachMonsterChaseIfNeeded(targetEntity)\n        self:EnsureMonsterTriggerComponent(targetEntity)\n        self:DisablePhysicsColliderIfMapHasNoSimulator(targetEntity)\n        self:ApplyMonsterVisualIfAvailable(targetEntity, row)\n        self:ApplyMonsterColliderIfAvailable(targetEntity, row)\n        self:ApplyMonsterStatsIfAvailable(targetEntity, row)\n\n        pcall(function()\n            hpSystem.IsMonster = true\n        end)\n        pcall(function()\n            hpSystem.IsDead = false\n        end)\n        pcall(function()\n            hpSystem.IsInvincible = false\n        end)\n\n        self:EnsureMonsterHPBarServer(targetEntity)\n        self:UpdateMonsterHPBarByEntityServer(targetEntity)\n\n        self._T.AutoBoundPlacedMonsters[targetEntity] = true\n        return 1\n    end\n\n    -- Row resolution priority: explicit HPSystem.MonsterDataId -> entity name as row id -> default non-mode normal row.\n    @ExecSpace(\"ServerOnly\")\n    method UserDataRow ResolvePlacedMonsterRowServer(Entity targetEntity, Component hpSystem)\n        if self._T.MonsterRows == nil or #self._T.MonsterRows <= 0 then\n            return nil\n        end\n\n        local explicitId = self:GetPlacedMonsterDataIdFromHPServer(hpSystem)\n        if explicitId ~= \"\" then\n            local explicitRow = self:GetMonsterRowByIdServer(explicitId)\n            if explicitRow ~= nil then\n                return explicitRow\n            end\n        end\n\n        local entityName = \"\"\n        if targetEntity ~= nil and isvalid(targetEntity) == true then\n            local readOk, readValue = pcall(function()\n                return targetEntity.Name\n            end)\n            if readOk == true and readValue ~= nil then\n                entityName = tostring(readValue)\n            end\n        end\n        local nameAsId = self:NormalizeMonsterRowIdToken(entityName)\n        if nameAsId ~= \"\" then\n            local nameRow = self:GetMonsterRowByIdServer(nameAsId)\n            if nameRow ~= nil then\n                return nameRow\n            end\n        end\n\n        return self:GetDefaultPlacedMonsterRowServer()\n    end\n\n    @ExecSpace(\"ServerOnly\")\n    method string GetPlacedMonsterDataIdFromHPServer(Component hpSystem)\n        if hpSystem == nil then\n            return \"\"\n        end\n\n        local value = \"\"\n        local readOk, readValue = pcall(function()\n            return hpSystem.MonsterDataId\n        end)\n        if readOk == true and readValue ~= nil then\n            value = tostring(readValue)\n        end\n\n        return self:NormalizeMonsterRowIdToken(value)\n    end\n\n    @ExecSpace(\"ServerOnly\")\n    method UserDataRow GetMonsterRowByIdServer(string rowId)\n        local normalizedId = self:NormalizeMonsterRowIdToken(rowId)\n        if normalizedId == \"\" then\n            return nil\n        end\n        if self._T.MonsterRows == nil then\n            return nil\n        end\n\n        for _, row in pairs(self._T.MonsterRows) do\n            if row == nil then\n                continue\n            end\n            local currentId = self:NormalizeMonsterRowIdToken(self:GetRowString(row, \"id\", \"\"))\n            if currentId == normalizedId then\n                return row\n            end\n        end\n\n        return nil\n    end\n\n    -- Default fallback picks earliest non-mode normal row so static monsters stay deterministic without explicit id.\n    @ExecSpace(\"ServerOnly\")\n    method UserDataRow GetDefaultPlacedMonsterRowServer()\n        if self._T.DefaultPlacedMonsterRow ~= nil then\n            return self._T.DefaultPlacedMonsterRow\n        end\n        if self._T.MonsterRows == nil or #self._T.MonsterRows <= 0 then\n            return nil\n        end\n\n        local firstAny = nil\n        local firstNormal = nil\n        local firstNormalAtZero = nil\n        for _, row in pairs(self._T.MonsterRows) do\n            if row == nil then\n                continue\n            end\n\n            local rowId = self:GetRowString(row, \"id\", \"\")\n            if rowId == \"\" then\n                continue\n            end\n\n            if firstAny == nil then\n                firstAny = row\n            end\n\n            local monType = string.lower(self:GetRowString(row, \"mon_type\", \"\"))\n            if string.sub(monType, 1, 5) == \"mode_\" then\n                continue\n            end\n            if monType ~= \"normal\" then\n                continue\n            end\n\n            if firstNormal == nil then\n                firstNormal = row\n            end\n\n            local spawnMin = self:GetSpawnMinuteFromRow(row)\n            if spawnMin <= 0 and firstNormalAtZero == nil then\n                firstNormalAtZero = row\n            end\n        end\n\n        local selected = firstNormalAtZero\n        if selected == nil then\n            selected = firstNormal\n        end\n        if selected == nil then\n            selected = firstAny\n        end\n\n        self._T.DefaultPlacedMonsterRow = selected\n        return selected\n    end\n\n    method string NormalizeMonsterRowIdToken(string value)\n        if value == nil then\n            return \"\"\n        end\n\n        local text = tostring(value)\n        text = string.gsub(text, \"^%s+\", \"\")\n        text = string.gsub(text, \"%s+$\", \"\")\n        text = string.lower(text)\n        if text == \"\" then\n            return \"\"\n        end\n        if text == \"-\" or text == \"null\" or text == \"nil\" then\n            return \"\"\n        end\n\n        return text\n    end\n\n    -- NameTag-based HP bars are updated from server so all clients observe the same monster HP feedback.\n    @ExecSpace(\"ServerOnly\")\n    method void UpdateMonsterHPBarsServer()\n        if self.EnableMonsterHPBar ~= true then\n            return\n        end\n\n        self:PruneMonsterHPBarRuntimeServer()\n        local visited = {}\n\n        if self._T.SpawnedMonsters ~= nil then\n            for _, spawnedEntity in pairs(self._T.SpawnedMonsters) do\n                if spawnedEntity ~= nil and isvalid(spawnedEntity) == true and visited[spawnedEntity] ~= true then\n                    visited[spawnedEntity] = true\n                    self:UpdateMonsterHPBarByEntityServer(spawnedEntity)\n                end\n            end\n        end\n\n        if self._T.AutoBoundPlacedMonsters ~= nil then\n            for boundEntity, isBound in pairs(self._T.AutoBoundPlacedMonsters) do\n                if isBound == true and boundEntity ~= nil and isvalid(boundEntity) == true and visited[boundEntity] ~= true then\n                    visited[boundEntity] = true\n                    self:UpdateMonsterHPBarByEntityServer(boundEntity)\n                end\n            end\n        end\n    end\n\n    @ExecSpace(\"ServerOnly\")\n    method void UpdateMonsterHPBarByEntityServer(Entity monsterEntity)\n        if self.EnableMonsterHPBar ~= true then\n            return\n        end\n        if monsterEntity == nil or isvalid(monsterEntity) == false then\n            return\n        end\n\n        local hpSystem = self:ResolveComponentSafe(monsterEntity, \"HPSystemComponent\", \"CurrentHP\")\n        if hpSystem == nil then\n            self:HideMonsterHPBarServer(monsterEntity)\n            return\n        end\n\n        local isMonster = false\n        local monsterOk, monsterValue = pcall(function()\n            return hpSystem.IsMonster\n        end)\n        if monsterOk == true and monsterValue == true then\n            isMonster = true\n        end\n        if isMonster ~= true then\n            self:HideMonsterHPBarServer(monsterEntity)\n            return\n        end\n\n        local isDead = false\n        local deadOk, deadValue = pcall(function()\n            return hpSystem.IsDead\n        end)\n        if deadOk == true and deadValue == true then\n            isDead = true\n        end\n        if isDead == true then\n            self:HideMonsterHPBarServer(monsterEntity)\n            return\n        end\n\n        local maxHp = 1\n        local maxOk, maxValue = pcall(function()\n            return hpSystem.MaxHP\n        end)\n        if maxOk == true and maxValue ~= nil then\n            local parsedMax = tonumber(maxValue)\n            if parsedMax ~= nil and parsedMax > 0 then\n                maxHp = math.floor(parsedMax)\n            end\n        end\n\n        local currentHp = 0\n        local currentOk, currentValue = pcall(function()\n            return hpSystem.CurrentHP\n        end)\n        if currentOk == true and currentValue ~= nil then\n            local parsedCurrent = tonumber(currentValue)\n            if parsedCurrent ~= nil then\n                currentHp = math.max(0, math.min(math.floor(parsedCurrent), maxHp))\n            end\n        end\n\n        local hpBar = self:EnsureMonsterHPBarServer(monsterEntity)\n        if hpBar == nil then\n            return\n        end\n\n        local layout = self:ResolveMonsterHPBarLayoutServer(monsterEntity)\n        local label = self:BuildMonsterHPBarLabelServer(currentHp, maxHp, layout.Segments, self.MonsterHPBarShowNumeric)\n        pcall(function()\n            hpBar.Name = label\n            hpBar.Enable = true\n            hpBar.OffsetY = self.MonsterHPBarOffsetY\n            hpBar.FontSize = layout.FontSize\n            hpBar.Bold = true\n            hpBar.FontColor = Color(0.2, 0.9, 0.25, 1)\n        end)\n    end\n\n    -- HP bar component is created lazily to support both spawned monsters and map-placed monsters.\n    @ExecSpace(\"ServerOnly\")\n    method Component EnsureMonsterHPBarServer(Entity monsterEntity)\n        if self.EnableMonsterHPBar ~= true then\n            return nil\n        end\n        if monsterEntity == nil or isvalid(monsterEntity) == false then\n            return nil\n        end\n\n        local hpBar = self:ResolveComponentSafe(monsterEntity, \"NameTagComponent\", \"Name\")\n        if hpBar == nil then\n            local addOkA, addResultA = pcall(function()\n                return monsterEntity:AddComponent(\"MOD.Core.NameTagComponent\")\n            end)\n            if addOkA == true then\n                hpBar = addResultA\n            end\n        end\n        if hpBar == nil then\n            local addOkB, addResultB = pcall(function()\n                return monsterEntity:AddComponent(\"NameTagComponent\")\n            end)\n            if addOkB == true then\n                hpBar = addResultB\n            end\n        end\n        if hpBar == nil then\n            return nil\n        end\n\n        if self._T.MonsterHPBarByEntity == nil then\n            self._T.MonsterHPBarByEntity = {}\n        end\n        self._T.MonsterHPBarByEntity[monsterEntity] = hpBar\n        return hpBar\n    end\n\n    -- HP bar width/height follows model scale (x) and y/x ratio so oversized tags shrink with sprite size.\n    method table ResolveMonsterHPBarLayoutServer(Entity monsterEntity)\n        local layout = {}\n        layout.Segments = math.max(self.MonsterHPBarSegments, 2)\n        layout.FontSize = math.max(self.MonsterHPBarFontSize, 1)\n\n        local modelScaleX = 1\n        local modelScaleY = 1\n        if monsterEntity ~= nil and isvalid(monsterEntity) == true then\n            local transform = monsterEntity.TransformComponent\n            if transform ~= nil and isvalid(transform) == true then\n                local scaleOk, scaleValue = pcall(function()\n                    return transform.Scale\n                end)\n                if scaleOk == true and scaleValue ~= nil then\n                    local sx = tonumber(scaleValue.x)\n                    local sy = tonumber(scaleValue.y)\n                    if sx ~= nil and math.abs(sx) > 0 then\n                        modelScaleX = math.abs(sx)\n                    end\n                    if sy ~= nil and math.abs(sy) > 0 then\n                        modelScaleY = math.abs(sy)\n                    end\n                end\n            end\n        end\n\n        local scaledX = modelScaleX * math.max(self.MonsterHPBarModelScaleXMultiplier, 0.01)\n        local ratioY = 1\n        if modelScaleX > 0 then\n            ratioY = modelScaleY / modelScaleX\n        end\n        local scaledY = scaledX * ratioY * math.max(self.MonsterHPBarModelScaleYMultiplier, 0.01)\n\n        local maxSegments = math.max(self.MonsterHPBarSegments, 2)\n        local minSegments = math.max(self.MonsterHPBarMinSegments, 1)\n        if minSegments > maxSegments then\n            minSegments = maxSegments\n        end\n        local calculatedSegments = math.floor(maxSegments * scaledX)\n        if calculatedSegments < minSegments then\n            calculatedSegments = minSegments\n        end\n        if calculatedSegments > maxSegments then\n            calculatedSegments = maxSegments\n        end\n        layout.Segments = calculatedSegments\n\n        local minFont = math.max(self.MonsterHPBarMinFontSize, 1)\n        local calculatedFontSize = math.floor(self.MonsterHPBarFontSize * scaledY)\n        if calculatedFontSize < minFont then\n            calculatedFontSize = minFont\n        end\n        if calculatedFontSize > self.MonsterHPBarFontSize then\n            calculatedFontSize = self.MonsterHPBarFontSize\n        end\n        layout.FontSize = calculatedFontSize\n\n        return layout\n    end\n\n    -- Keep numeric-only mode compact as `current/max` to avoid clipping on small monster UI.\n    method string BuildMonsterHPBarLabelServer(integer currentHp, integer maxHp, integer segmentOverride, boolean includeNumeric)\n        local safeMax = math.max(1, maxHp)\n        local safeCurrent = math.max(0, math.min(currentHp, safeMax))\n        if includeNumeric == true then\n            return tostring(safeCurrent) .. \"/\" .. tostring(safeMax)\n        end\n\n        local segments = math.floor(segmentOverride)\n        if segments <= 0 then\n            segments = math.floor(self.MonsterHPBarSegments)\n        end\n        if segments < 1 then\n            segments = 1\n        end\n        if segments > 20 then\n            segments = 20\n        end\n\n        local ratio = safeCurrent / safeMax\n        local filled = math.floor(ratio * segments + 0.0001)\n        if safeCurrent > 0 and filled <= 0 then\n            filled = 1\n        end\n        if filled > segments then\n            filled = segments\n        end\n\n        local filledText = \"\"\n        for index = 1, filled do\n            filledText ..= \"#\"\n        end\n\n        local emptyText = \"\"\n        for index = (filled + 1), segments do\n            emptyText ..= \"-\"\n        end\n\n        return \"[\" .. filledText .. emptyText .. \"]\"\n    end\n\n    @ExecSpace(\"ServerOnly\")\n    method void HideMonsterHPBarServer(Entity monsterEntity)\n        if self._T.MonsterHPBarByEntity == nil then\n            self._T.MonsterHPBarByEntity = {}\n        end\n        if monsterEntity == nil then\n            return\n        end\n\n        local hpBar = self._T.MonsterHPBarByEntity[monsterEntity]\n        if hpBar == nil then\n            hpBar = self:ResolveComponentSafe(monsterEntity, \"NameTagComponent\", \"Name\")\n        end\n        if hpBar ~= nil then\n            pcall(function()\n                hpBar.Name = \"\"\n                hpBar.Enable = false\n            end)\n        end\n    end\n\n    @ExecSpace(\"ServerOnly\")\n    method void PruneMonsterHPBarRuntimeServer()\n        if self._T.MonsterHPBarByEntity == nil then\n            self._T.MonsterHPBarByEntity = {}\n            return\n        end\n\n        local pruned = {}\n        for targetEntity, hpBar in pairs(self._T.MonsterHPBarByEntity) do\n            if targetEntity ~= nil and isvalid(targetEntity) == true and hpBar ~= nil and isvalid(hpBar) == true then\n                pruned[targetEntity] = hpBar\n            end\n        end\n        self._T.MonsterHPBarByEntity = pruned\n    end\n\n    @ExecSpace(\"ServerOnly\")\n    method void ClearMonsterHPBarRuntimeServer()\n        if self._T.MonsterHPBarByEntity == nil then\n            self._T.MonsterHPBarByEntity = {}\n            return\n        end\n\n        for _, hpBar in pairs(self._T.MonsterHPBarByEntity) do\n            if hpBar ~= nil and isvalid(hpBar) == true then\n                pcall(function()\n                    hpBar.Name = \"\"\n                    hpBar.Enable = false\n                end)\n            end\n        end\n        self._T.MonsterHPBarByEntity = {}\n    end\n\n    -- Public read API exposes spawn metadata without coupling callers to internal cache structure.\n    method table GetSpawnMetaByEntity(Entity targetEntity)\n        if targetEntity == nil or isvalid(targetEntity) == false then\n            return nil\n        end\n        if self._T.SpawnMetaByEntity == nil then\n            return nil\n        end\n\n        local sourceMeta = self._T.SpawnMetaByEntity[targetEntity]\n        if sourceMeta == nil then\n            return nil\n        end\n\n        return self:CloneTable(sourceMeta)\n    end\n\n    -- Dead monsters start one-shot death-effect playback and timed fade-out before destroy.\n    @ExecSpace(\"ServerOnly\")\n    method void ProcessMonsterDeathSequenceServer()\n        self:PruneMonsterDeathRuntimeServer()\n\n        if self._T.SpawnedMonsters ~= nil then\n            for _, spawnedEntity in pairs(self._T.SpawnedMonsters) do\n                self:TryStartMonsterDeathSequenceServer(spawnedEntity)\n            end\n        end\n\n        if self._T.AutoBoundPlacedMonsters ~= nil then\n            for boundEntity, isBound in pairs(self._T.AutoBoundPlacedMonsters) do\n                if isBound == true then\n                    self:TryStartMonsterDeathSequenceServer(boundEntity)\n                end\n            end\n        end\n    end\n\n    @ExecSpace(\"ServerOnly\")\n    method void TryStartMonsterDeathSequenceServer(Entity monsterEntity)\n        if monsterEntity == nil or isvalid(monsterEntity) == false then\n            return\n        end\n\n        if self._T.MonsterDeathRuntimeByEntity ~= nil and self._T.MonsterDeathRuntimeByEntity[monsterEntity] ~= nil then\n            return\n        end\n\n        if self:IsDeadMonsterEntityServer(monsterEntity) ~= true then\n            return\n        end\n\n        self:BeginMonsterDeathSequenceServer(monsterEntity)\n    end\n\n    -- Server checks both IsDead flag and HP value to tolerate mixed legacy death writers.\n    method boolean IsDeadMonsterEntityServer(Entity monsterEntity)\n        if monsterEntity == nil or isvalid(monsterEntity) == false then\n            return false\n        end\n        if monsterEntity.PlayerComponent ~= nil then\n            return false\n        end\n\n        local hpSystem = self:ResolveComponentSafe(monsterEntity, \"HPSystemComponent\", \"CurrentHP\")\n        if hpSystem == nil then\n            return false\n        end\n\n        local isMonster = false\n        local isMonsterOk, isMonsterValue = pcall(function()\n            return hpSystem.IsMonster\n        end)\n        if isMonsterOk == true and isMonsterValue == true then\n            isMonster = true\n        end\n        if isMonster ~= true then\n            return false\n        end\n\n        local deadOk, deadValue = pcall(function()\n            return hpSystem.IsDead\n        end)\n        if deadOk == true and deadValue == true then\n            return true\n        end\n\n        local hpOk, hpValue = pcall(function()\n            return hpSystem.CurrentHP\n        end)\n        if hpOk == true and hpValue ~= nil then\n            local parsedHp = tonumber(hpValue)\n            if parsedHp ~= nil and parsedHp <= 0 then\n                return true\n            end\n        end\n\n        return false\n    end\n\n    -- Death setup freezes combat interaction first, then applies death effect sprite and starts fade timer.\n    @ExecSpace(\"ServerOnly\")\n    method void BeginMonsterDeathSequenceServer(Entity monsterEntity)\n        if monsterEntity == nil or isvalid(monsterEntity) == false then\n            return\n        end\n\n        if self._T.MonsterDeathRuntimeByEntity == nil then\n            self._T.MonsterDeathRuntimeByEntity = {}\n        end\n        if self._T.MonsterDeathRuntimeByEntity[monsterEntity] ~= nil then\n            return\n        end\n\n        self:PrepareDeadMonsterForFadeServer(monsterEntity)\n        self:HideMonsterHPBarServer(monsterEntity)\n\n        local runtime = {}\n        runtime.ElapsedSeconds = 0\n        runtime.LeadTime = math.max(self.MonsterDeathEffectLeadTime, 0)\n        runtime.FadeDuration = math.max(self.MonsterDeathFadeDuration, 0.01)\n        runtime.TickInterval = self.MonsterDeathFadeTick\n        if runtime.TickInterval <= 0 then\n            runtime.TickInterval = 0.05\n        end\n        runtime.TimerId = 0\n        runtime.BaseR = 1\n        runtime.BaseG = 1\n        runtime.BaseB = 1\n        runtime.BaseA = 1\n\n        local spriteRenderer = self:ResolveComponentSafe(monsterEntity, \"SpriteRendererComponent\", \"SpriteRUID\")\n        if spriteRenderer ~= nil then\n            local colorOk, colorValue = pcall(function()\n                return spriteRenderer.Color\n            end)\n            if colorOk == true and colorValue ~= nil then\n                local readR = tonumber(colorValue.r)\n                local readG = tonumber(colorValue.g)\n                local readB = tonumber(colorValue.b)\n                local readA = tonumber(colorValue.a)\n                if readR ~= nil then\n                    runtime.BaseR = readR\n                end\n                if readG ~= nil then\n                    runtime.BaseG = readG\n                end\n                if readB ~= nil then\n                    runtime.BaseB = readB\n                end\n                if readA ~= nil and readA > 0 then\n                    runtime.BaseA = readA\n                end\n            end\n\n            local deathEffectRuid = self:ResolveMonsterDeathEffectRuidServer(monsterEntity)\n            if deathEffectRuid ~= nil and deathEffectRuid ~= \"\" then\n                pcall(function()\n                    spriteRenderer.SpriteRUID = deathEffectRuid\n                    spriteRenderer.PlayRate = 1\n                    spriteRenderer.StartFrameIndex = 0\n                    spriteRenderer.EndFrameIndex = 2147483647\n                end)\n            end\n        end\n\n        self._T.MonsterDeathRuntimeByEntity[monsterEntity] = runtime\n\n        local tickFn = function()\n            self:TickMonsterDeathFadeServer(monsterEntity)\n        end\n        local timerId = _TimerService:SetTimerRepeat(tickFn, runtime.TickInterval, 0)\n        runtime.TimerId = timerId\n        self._T.MonsterDeathRuntimeByEntity[monsterEntity] = runtime\n    end\n\n    -- Contact damage and chase movement are disabled immediately so dead monsters cannot keep dealing damage.\n    @ExecSpace(\"ServerOnly\")\n    method void PrepareDeadMonsterForFadeServer(Entity monsterEntity)\n        if monsterEntity == nil or isvalid(monsterEntity) == false then\n            return\n        end\n\n        local trigger = self:ResolveComponentSafe(monsterEntity, \"TriggerComponent\", \"IsPassive\")\n        if trigger ~= nil then\n            pcall(function()\n                trigger.IsPassive = true\n            end)\n        end\n\n        local rigidbody = self:ResolveComponentSafe(monsterEntity, \"RigidbodyComponent\", \"MoveVelocity\")\n        if rigidbody ~= nil then\n            pcall(function()\n                rigidbody.MoveVelocity = Vector2.zero\n            end)\n        end\n\n        local movement = self:ResolveComponentSafe(monsterEntity, \"MovementComponent\", \"CanMove\")\n        if movement ~= nil then\n            pcall(function()\n                movement.CanMove = false\n            end)\n            pcall(function()\n                movement.UsePlayerInput = false\n            end)\n            if movement.SetMoveDirectionServer ~= nil then\n                pcall(function()\n                    movement:SetMoveDirectionServer(Vector2.zero)\n                end)\n            end\n            pcall(function()\n                movement._T.ServerInputDirection = Vector2.zero\n            end)\n        end\n\n        local chase = self:ResolveComponentSafe(monsterEntity, \"MonsterChaseComponent\", \"ThinkInterval\")\n        if chase ~= nil then\n            if chase.ClearThinkTimerServer ~= nil then\n                pcall(function()\n                    chase:ClearThinkTimerServer()\n                end)\n            end\n            pcall(function()\n                chase.Enable = false\n            end)\n        end\n    end\n\n    -- Death effect lead time is followed by alpha fade, then the entity is destroyed exactly once.\n    @ExecSpace(\"ServerOnly\")\n    method void TickMonsterDeathFadeServer(Entity monsterEntity)\n        if self._T.MonsterDeathRuntimeByEntity == nil then\n            return\n        end\n\n        local runtime = self._T.MonsterDeathRuntimeByEntity[monsterEntity]\n        if runtime == nil then\n            return\n        end\n\n        if monsterEntity == nil or isvalid(monsterEntity) == false then\n            self:ClearMonsterDeathRuntimeServer(monsterEntity)\n            return\n        end\n\n        local tickInterval = runtime.TickInterval\n        if tickInterval == nil or tickInterval <= 0 then\n            tickInterval = 0.05\n        end\n\n        runtime.ElapsedSeconds += tickInterval\n        local leadTime = runtime.LeadTime\n        if leadTime == nil then\n            leadTime = 0\n        end\n\n        if runtime.ElapsedSeconds < leadTime then\n            self._T.MonsterDeathRuntimeByEntity[monsterEntity] = runtime\n            return\n        end\n\n        local fadeDuration = runtime.FadeDuration\n        if fadeDuration == nil or fadeDuration <= 0 then\n            fadeDuration = 0.01\n        end\n\n        local elapsedFade = runtime.ElapsedSeconds - leadTime\n        local ratio = elapsedFade / fadeDuration\n        if ratio < 0 then\n            ratio = 0\n        end\n        if ratio > 1 then\n            ratio = 1\n        end\n\n        local remainAlpha = (1 - ratio) * runtime.BaseA\n        if remainAlpha < 0 then\n            remainAlpha = 0\n        end\n        self:ApplyMonsterFadeAlphaServer(monsterEntity, runtime.BaseR, runtime.BaseG, runtime.BaseB, remainAlpha)\n\n        if ratio >= 1 then\n            self:ClearMonsterDeathRuntimeServer(monsterEntity)\n            if monsterEntity ~= nil and isvalid(monsterEntity) == true then\n                _EntityService:Destroy(monsterEntity)\n            end\n            return\n        end\n\n        self._T.MonsterDeathRuntimeByEntity[monsterEntity] = runtime\n    end\n\n    @ExecSpace(\"ServerOnly\")\n    method void ApplyMonsterFadeAlphaServer(Entity monsterEntity, number baseR, number baseG, number baseB, number alpha)\n        if monsterEntity == nil or isvalid(monsterEntity) == false then\n            return\n        end\n\n        local spriteRenderer = self:ResolveComponentSafe(monsterEntity, \"SpriteRendererComponent\", \"SpriteRUID\")\n        if spriteRenderer == nil then\n            return\n        end\n\n        pcall(function()\n            spriteRenderer.Color = Color(baseR, baseG, baseB, alpha)\n        end)\n    end\n\n    -- Uses cached spawn metadata first, then row fallback for placed/bound monsters.\n    @ExecSpace(\"ServerOnly\")\n    method string ResolveMonsterDeathEffectRuidServer(Entity monsterEntity)\n        if monsterEntity == nil or isvalid(monsterEntity) == false then\n            return \"\"\n        end\n\n        if self._T.SpawnMetaByEntity ~= nil then\n            local spawnMeta = self._T.SpawnMetaByEntity[monsterEntity]\n            if spawnMeta ~= nil and spawnMeta.DeathEffectRuid ~= nil then\n                local text = tostring(spawnMeta.DeathEffectRuid)\n                if text ~= \"\" then\n                    return text\n                end\n            end\n        end\n\n        local hpSystem = self:ResolveComponentSafe(monsterEntity, \"HPSystemComponent\", \"CurrentHP\")\n        if hpSystem == nil then\n            return \"\"\n        end\n\n        local rowId = self:GetPlacedMonsterDataIdFromHPServer(hpSystem)\n        if rowId == nil or rowId == \"\" then\n            return \"\"\n        end\n\n        local row = self:GetMonsterRowByIdServer(rowId)\n        if row == nil then\n            return \"\"\n        end\n\n        return self:GetRowString(row, \"death_effect_ruid\", \"\")\n    end\n\n    @ExecSpace(\"ServerOnly\")\n    method void ClearMonsterDeathRuntimeServer(Entity monsterEntity)\n        if self._T.MonsterDeathRuntimeByEntity == nil then\n            return\n        end\n        if monsterEntity == nil then\n            return\n        end\n\n        local runtime = self._T.MonsterDeathRuntimeByEntity[monsterEntity]\n        if runtime == nil then\n            return\n        end\n\n        local timerId = runtime.TimerId\n        if timerId ~= nil and timerId > 0 then\n            _TimerService:ClearTimer(timerId)\n        end\n\n        self._T.MonsterDeathRuntimeByEntity[monsterEntity] = nil\n    end\n\n    -- Runtime prune clears stale timer records when entities are externally removed first.\n    @ExecSpace(\"ServerOnly\")\n    method void PruneMonsterDeathRuntimeServer()\n        if self._T.MonsterDeathRuntimeByEntity == nil then\n            self._T.MonsterDeathRuntimeByEntity = {}\n            return\n        end\n\n        local pruned = {}\n        for trackedEntity, runtime in pairs(self._T.MonsterDeathRuntimeByEntity) do\n            if trackedEntity ~= nil and isvalid(trackedEntity) == true then\n                pruned[trackedEntity] = runtime\n                continue\n            end\n\n            if runtime ~= nil and runtime.TimerId ~= nil and runtime.TimerId > 0 then\n                _TimerService:ClearTimer(runtime.TimerId)\n            end\n        end\n\n        self._T.MonsterDeathRuntimeByEntity = pruned\n    end\n\n    -- Endplay/destroy both call this to stop all per-monster death fade timers.\n    @ExecSpace(\"ServerOnly\")\n    method void ClearMonsterDeathRuntimeTimersServer()\n        if self._T.MonsterDeathRuntimeByEntity == nil then\n            self._T.MonsterDeathRuntimeByEntity = {}\n            return\n        end\n\n        for _, runtime in pairs(self._T.MonsterDeathRuntimeByEntity) do\n            if runtime ~= nil and runtime.TimerId ~= nil and runtime.TimerId > 0 then\n                _TimerService:ClearTimer(runtime.TimerId)\n            end\n        end\n\n        self._T.MonsterDeathRuntimeByEntity = {}\n    end\n\n    -- Pruning keeps field cap checks accurate even when external systems destroy spawned entities.\n    @ExecSpace(\"ServerOnly\")\n    method void PruneSpawnedMonsters()\n        if self._T.SpawnedMonsters == nil then\n            self._T.SpawnedMonsters = {}\n        end\n\n        local oldMeta = self._T.SpawnMetaByEntity\n        local newList = {}\n        local newMeta = {}\n\n        for _, entity in pairs(self._T.SpawnedMonsters) do\n            if entity ~= nil and isvalid(entity) == true then\n                table.insert(newList, entity)\n                if oldMeta ~= nil and oldMeta[entity] ~= nil then\n                    newMeta[entity] = oldMeta[entity]\n                end\n            else\n                if oldMeta ~= nil and oldMeta[entity] ~= nil then\n                    self:HandleSpawnedMonsterRemovedServer(oldMeta[entity])\n                end\n            end\n        end\n\n        self._T.SpawnedMonsters = newList\n        self._T.SpawnMetaByEntity = newMeta\n    end\n\n    -- Removed-entity hook reports kill/clear events to InfiniteModeComponent without hard coupling.\n    @ExecSpace(\"ServerOnly\")\n    method void HandleSpawnedMonsterRemovedServer(table spawnMeta)\n        if spawnMeta == nil then\n            return\n        end\n\n        local infiniteMode = self:ResolveComponentSafe(self.Entity, \"InfiniteModeComponent\", \"CurrentScore\")\n        if infiniteMode == nil then\n            return\n        end\n\n        local monsterId = \"\"\n        local creepScore = 0\n        if spawnMeta.Id ~= nil then\n            monsterId = tostring(spawnMeta.Id)\n        end\n        if spawnMeta.CreepScore ~= nil then\n            creepScore = math.max(0, math.floor(spawnMeta.CreepScore))\n        end\n\n        if monsterId ~= \"\" and infiniteMode.OnMonsterKilledServer ~= nil then\n            pcall(function()\n                infiniteMode:OnMonsterKilledServer(monsterId, creepScore)\n            end)\n        end\n\n        if spawnMeta.IsBoss == true and infiniteMode.OnBossKilledServer ~= nil then\n            pcall(function()\n                infiniteMode:OnBossKilledServer(monsterId)\n            end)\n        end\n    end\n\n    method integer GetSpawnedMonsterCount()\n        if self._T.SpawnedMonsters == nil then\n            return 0\n        end\n        return #self._T.SpawnedMonsters\n    end\n\n    method void WarnMissingRequiredColumnOnce(string tableName, string columnName, string key)\n        if self._T.RequiredColumnWarned == nil then\n            self._T.RequiredColumnWarned = {}\n        end\n\n        local warnKey = tostring(tableName) .. \"|\" .. tostring(columnName) .. \"|\" .. tostring(key)\n        if self._T.RequiredColumnWarned[warnKey] == true then\n            return\n        end\n        self._T.RequiredColumnWarned[warnKey] = true\n\n        log_warning(\n            \"[MonsterSpawnComponent] missing required column value. table=\",\n            tostring(tableName),\n            \", column=\",\n            tostring(columnName),\n            \", key=\",\n            tostring(key)\n        )\n    end\n\n    method string GetRowString(UserDataRow row, string columnName, string fallbackValue)\n        local fallback = fallbackValue\n        if fallback == nil then\n            fallback = \"\"\n        end\n\n        if row == nil then\n            return fallback\n        end\n        if columnName == nil or columnName == \"\" then\n            return fallback\n        end\n\n        local text = nil\n        local readOk, readResult = pcall(function()\n            return row:GetItem(columnName)\n        end)\n        if readOk == true then\n            text = readResult\n        end\n        if text == nil then\n            return fallback\n        end\n\n        local normalized = tostring(text)\n        normalized = string.gsub(normalized, \"^%s+\", \"\")\n        normalized = string.gsub(normalized, \"%s+$\", \"\")\n        if normalized == \"\" then\n            return fallback\n        end\n\n        local lowered = string.lower(normalized)\n        if normalized == \"-\" or lowered == \"null\" or lowered == \"nil\" then\n            return fallback\n        end\n\n        return normalized\n    end\n\n    method integer GetRowInteger(UserDataRow row, string columnName, integer fallbackValue)\n        local text = self:GetRowString(row, columnName, \"\")\n        if text == \"\" then\n            return math.floor(fallbackValue)\n        end\n\n        local parsed = tonumber(text)\n        if parsed == nil then\n            return math.floor(fallbackValue)\n        end\n\n        return math.floor(parsed)\n    end\n\n    method number GetRowNumber(UserDataRow row, string columnName, number fallbackValue)\n        local text = self:GetRowString(row, columnName, \"\")\n        if text == \"\" then\n            return fallbackValue\n        end\n\n        local parsed = tonumber(text)\n        if parsed == nil then\n            return fallbackValue\n        end\n\n        return parsed\n    end\n\n    method boolean GetRowBoolean(UserDataRow row, string columnName, boolean fallbackValue)\n        local text = string.lower(self:GetRowString(row, columnName, \"\"))\n        if text == \"\" then\n            return fallbackValue\n        end\n        if text == \"true\" or text == \"1\" or text == \"yes\" then\n            return true\n        end\n        if text == \"false\" or text == \"0\" or text == \"no\" then\n            return false\n        end\n        return fallbackValue\n    end\n\n    -- SpawnByModelId requires model entry id; resolver tolerates name/entry-key mixed authoring.\n    method string ResolveModelIdForSpawn(string rawModelType)\n        local normalized = self:NormalizeModelIdText(rawModelType)\n        if normalized == \"\" then\n            return \"\"\n        end\n\n        if self:IsExplicitModelId(normalized) == true then\n            return normalized\n        end\n\n        local resolvedId = \"\"\n        local resolveOk, resolveResult = pcall(function()\n            return _EntryService:GetModelIdByName(normalized)\n        end)\n        if resolveOk == true and resolveResult ~= nil then\n            resolvedId = self:NormalizeModelIdText(tostring(resolveResult))\n        end\n        if resolvedId ~= \"\" then\n            return resolvedId\n        end\n\n        return normalized\n    end\n\n    method string NormalizeModelIdText(string value)\n        if value == nil then\n            return \"\"\n        end\n\n        local text = tostring(value)\n        if text == \"\" then\n            return \"\"\n        end\n\n        local prefix = \"model://\"\n        if string.sub(text, 1, #prefix) == prefix then\n            return string.sub(text, #prefix + 1)\n        end\n\n        return text\n    end\n\n    -- Explicit-id detector prevents unnecessary lookup calls for GUID/preset-style ids.\n    method boolean IsExplicitModelId(string value)\n        if value == nil or value == \"\" then\n            return false\n        end\n\n        if string.find(value, \"-\") ~= nil then\n            return true\n        end\n        if string.find(value, \"$\") ~= nil then\n            return true\n        end\n        if string.find(value, \"://\") ~= nil then\n            return true\n        end\n\n        return false\n    end\n\n    method table CloneTable(table source)\n        local clone = {}\n        if source == nil then\n            return clone\n        end\n\n        for key, value in pairs(source) do\n            clone[key] = value\n        end\n        return clone\n    end\n\n    -- Gate trace logs spawn-on/off reason transitions with throttle to keep logs readable during monitor polling.\n    @ExecSpace(\"ServerOnly\")\n    method void TraceSpawnGateServer(boolean canSpawn, string reason)\n        if self.EnableDebugLogs ~= true then\n            return\n        end\n\n        local changed = false\n        if self._T.LastSpawnGateAllowed ~= canSpawn then\n            changed = true\n        end\n        if self._T.LastSpawnGateReason ~= reason then\n            changed = true\n        end\n\n        local nowSeconds = self:GetServerNowSeconds()\n        local throttle = self.DebugLogThrottleSeconds\n        if throttle < 0 then\n            throttle = 0\n        end\n        local lastAt = self._T.LastSpawnGateLogAt\n        if lastAt == nil then\n            lastAt = -9999\n        end\n\n        if changed == false and (nowSeconds - lastAt) < throttle then\n            return\n        end\n\n        self._T.LastSpawnGateAllowed = canSpawn\n        self._T.LastSpawnGateReason = reason\n        self._T.LastSpawnGateLogAt = nowSeconds\n\n        log(\n            \"[MonsterSpawnComponent][DEBUG] gate canSpawn=\", canSpawn,\n            \", reason=\", reason,\n            \", dataReady=\", self._T.DataReady,\n            \", bossPhase=\", self.IsBossPhase,\n            \", hasParent=\", (self.MonsterParentEntity ~= nil),\n            \", lobbySafeZone=\", self:IsSafeZoneActiveServer(),\n            \", shopOpen=\", self:IsShopOpenServer(),\n            \", spawnActive=\", self.IsSpawnActive\n        )\n    end\n\n    -- Server elapsed time helper is isolated so debug throttle stays deterministic even if util lookup fails.\n    method number GetServerNowSeconds()\n        local nowSeconds = 0\n        local readOk, readValue = pcall(function()\n            return _UtilLogic.ServerElapsedSeconds\n        end)\n        if readOk == true and readValue ~= nil then\n            nowSeconds = readValue\n        end\n        return nowSeconds\n    end\n\n    method void LogError(string message)\n        local loggedOk, _ = pcall(function()\n            log_error(message)\n        end)\n        if loggedOk == false then\n            log_warning(message)\n        end\n    end\n\n    -- Utility bootstrap first; fallback lookup is retained for resilience in partially configured maps.\n    method void EnsureGRUtil()\n        if self._T.GRUtil ~= nil and self._T.GRUtil.ResolveComponent ~= nil then\n            return\n        end\n\n        local utilComponent = nil\n        if self.Entity ~= nil and isvalid(self.Entity) == true then\n            utilComponent = self.Entity:GetComponent(\"script.GRUtilModule\")\n            if utilComponent == nil then\n                utilComponent = self.Entity:GetComponent(\"GRUtilModule\")\n            end\n            if utilComponent == nil then\n                local addOk1, addResult1 = pcall(function()\n                    return self.Entity:AddComponent(\"script.GRUtilModule\")\n                end)\n                if addOk1 == true then\n                    utilComponent = addResult1\n                end\n            end\n            if utilComponent == nil then\n                local addOk2, addResult2 = pcall(function()\n                    return self.Entity:AddComponent(\"GRUtilModule\")\n                end)\n                if addOk2 == true then\n                    utilComponent = addResult2\n                end\n            end\n        end\n\n        if utilComponent ~= nil and isvalid(utilComponent) == true then\n            local bootstrapOk, utilApi = pcall(function()\n                return utilComponent:BootstrapUtil()\n            end)\n            if bootstrapOk == true and utilApi ~= nil then\n                self._T.GRUtil = utilApi\n            end\n            if self._T.GRUtil ~= nil and self._T.GRUtil.ResolveComponent ~= nil then\n                return\n            end\n        end\n\n        self._T.UseGRUtilFallback = true\n    end\n\n    method any ResolveComponentSafe(Entity targetEntity, string scriptName, string markerField)\n        if targetEntity == nil or isvalid(targetEntity) == false then\n            return nil\n        end\n\n        if self._T.GRUtil ~= nil and self._T.GRUtil.ResolveComponent ~= nil then\n            return self._T.GRUtil.ResolveComponent(targetEntity, scriptName, markerField)\n        end\n\n        local prefixedName = scriptName\n        local plainName = scriptName\n        if string.sub(scriptName, 1, 7) == \"script.\" then\n            plainName = string.sub(scriptName, 8)\n        else\n            prefixedName = \"script.\" .. scriptName\n        end\n\n        local component = targetEntity:GetComponent(prefixedName)\n        if component == nil then\n            component = targetEntity:GetComponent(plainName)\n        end\n        if component == nil then\n            return nil\n        end\n\n        if markerField ~= nil and markerField ~= \"\" then\n            local ok, _ = pcall(function()\n                return component[markerField]\n            end)\n            if ok == false then\n                return nil\n            end\n        end\n\n        return component\n    end\nend\n"
    }
  }
}