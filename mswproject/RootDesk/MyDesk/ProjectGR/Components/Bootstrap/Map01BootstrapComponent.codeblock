  "EntryKey": "codeblock://3ce28cf1-f6b2-4cc6-ad87-9ad62dfa6e36",
  "ContentType": "x-mod/codeblock",
  "Content": "",
  "Usage": 0,
  "UsePublish": 1,
  "UseService": 0,
  "CoreVersion": "26.1.0.0",
